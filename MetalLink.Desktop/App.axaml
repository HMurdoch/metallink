<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fluent="clr-namespace:Avalonia.Themes.Fluent;assembly=Avalonia.Themes.Fluent"
             xmlns:views="using:MetalLink.Desktop.Views"
             x:Class="MetalLink.Desktop.App"
             xmlns:local="clr-namespace:MetalLink.Desktop">

  <!-- Global styles -->
  <Application.Styles>
    <!-- Base control theme (provides templates for ScrollViewer, etc.) -->
    <fluent:FluentTheme />

    <!-- SukiUI styles -->
    <StyleInclude Source="avares://SukiUI/Theme/DataGridStyle.axaml" />

    <!-- Fallback DataGrid theme include (kept for safety; can be removed once we fully rely on SukiUI) -->
    <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />

    <!-- Primary button styles -->
    <Style Selector="Button.primary">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="{DynamicResource Brush.AccentGradient}" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Left" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
      <Setter Property="RenderTransform">
        <Setter.Value>
          <ScaleTransform ScaleX="1" ScaleY="1" />
        </Setter.Value>
      </Setter>

      <Setter Property="Transitions">
        <Setter.Value>
          <Transitions>
            <BrushTransition Property="Background" Duration="0:0:0.15" />
            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12" />
          </Transitions>
        </Setter.Value>
      </Setter>
    </Style>

    <Style Selector="Button.primary:pointerover">
      <Setter Property="RenderTransform">
        <Setter.Value>
          <ScaleTransform ScaleX="1.06" ScaleY="1.06" />
        </Setter.Value>
      </Setter>
      <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style Selector="Button.primary:pressed">
      <Setter Property="Background">
        <Setter.Value>
          <SolidColorBrush Color="{DynamicResource Color.PrimaryBlueDark}" />
        </Setter.Value>
      </Setter>
    </Style>

    <Style Selector="Button.primary:disabled">
      <Setter Property="Background" Value="#555A64" />
      <Setter Property="Foreground" Value="#B0B4BD" />
    </Style>

    <!-- Modern Animations & Transitions -->
    
    <!-- Default 3D-ish buttons (bevel + emboss + shadow). Nav buttons override this in MainWindow. -->
    <Style Selector="Button">
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
      <Setter Property="Background" Value="{DynamicResource Brush.MetalButtonFace}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="12,8" />

      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Grid>
              <!-- Outer chrome ring (disabled to prevent corner artifacts) -->
              <Border BorderThickness="0" CornerRadius="12">
                <Border.BorderBrush>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#99FFFFFF" Offset="0" />
                    <GradientStop Color="#55FFFFFF" Offset="0.5" />
                    <GradientStop Color="#22FFFFFF" Offset="1" />
                  </LinearGradientBrush>
                </Border.BorderBrush>
              </Border>

              <!-- Main button body (brushed metal) -->
              <Border x:Name="Body"
                      Background="{TemplateBinding Background}"
                      BorderBrush="#AA555D68"
                      BorderThickness="1"
                      CornerRadius="10"
                      Margin="0">
                <Grid>
                  <!-- Top bevel highlight (raised edge) -->
                  <Border Height="18" VerticalAlignment="Top" Margin="6,1,6,0" CornerRadius="8,8,0,0">
                    <Border.Background>
                      <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#55FFFFFF" Offset="0" />
                        <GradientStop Color="#00FFFFFF" Offset="1" />
                      </LinearGradientBrush>
                    </Border.Background>
                  </Border>

                  <!-- Bottom shadow (recess edge) -->
                  <Border Height="10" VerticalAlignment="Bottom" Margin="6,0,6,1" CornerRadius="0,0,8,8">
                    <Border.Background>
                      <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#00000000" Offset="0" />
                        <GradientStop Color="#44000000" Offset="1" />
                      </LinearGradientBrush>
                    </Border.Background>
                  </Border>

                  <ContentPresenter Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                </Grid>
              </Border>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>

      <Setter Property="Transitions">
        <Setter.Value>
          <Transitions>
            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" Easing="CubicEaseOut"/>
            <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
          </Transitions>
        </Setter.Value>
      </Setter>
    </Style>
    
    <Style Selector="Button:pointerover">
      <Setter Property="RenderTransform" Value="scale(1.02)"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.AccentGradient}" />
    </Style>
    
    <Style Selector="Button:pressed">
      <Setter Property="RenderTransform" Value="scale(0.98)"/>
      <Setter Property="Opacity" Value="0.9" />
    </Style>

    <!-- Border fade-in animation -->
    <Style Selector="Border.fade-in">
      <Style.Animations>
        <Animation Duration="0:0:0.4" FillMode="Forward">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0"/>
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1"/>
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- Slide in from left animation -->
    <Style Selector="StackPanel.slide-in-left">
      <Style.Animations>
        <Animation Duration="0:0:0.3" FillMode="Forward" Easing="CubicEaseOut">
          <KeyFrame Cue="0%">
            <Setter Property="TranslateTransform.X" Value="-50"/>
            <Setter Property="Opacity" Value="0"/>
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="TranslateTransform.X" Value="0"/>
            <Setter Property="Opacity" Value="1"/>
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- Slide in from right animation -->
    <Style Selector="StackPanel.slide-in-right">
      <Style.Animations>
        <Animation Duration="0:0:0.3" FillMode="Forward" Easing="CubicEaseOut">
          <KeyFrame Cue="0%">
            <Setter Property="TranslateTransform.X" Value="50"/>
            <Setter Property="Opacity" Value="0"/>
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="TranslateTransform.X" Value="0"/>
            <Setter Property="Opacity" Value="1"/>
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- Pulse animation for important elements -->
    <Style Selector="Border.pulse">
      <Style.Animations>
        <Animation Duration="0:0:2" IterationCount="INFINITE">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0.7"/>
          </KeyFrame>
          <KeyFrame Cue="50%">
            <Setter Property="Opacity" Value="1.0"/>
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="0.7"/>
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- Text inputs: use our own template so background/border are ALWAYS visible (theme-independent) -->
    <Style Selector="TextBox">
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
      <Setter Property="Background" Value="{DynamicResource Brush.InputBackground}" />
      <Setter Property="CaretBrush" Value="{DynamicResource Brush.TextPrimary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.InputBorder}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="10,7" />

      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Grid>
              <!-- Outer chrome bevel (3D depth) -->
              <Border BorderThickness="2" CornerRadius="12" Margin="0">
                <Border.BorderBrush>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#88FFFFFF" Offset="0" />
                    <GradientStop Color="#44FFFFFF" Offset="0.5" />
                    <GradientStop Color="#11FFFFFF" Offset="1" />
                  </LinearGradientBrush>
                </Border.BorderBrush>
              </Border>

              <!-- Glossy body (use TemplateBinding so per-window/per-control styles work, e.g. Login) -->
              <Border Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="10"
                      Margin="2">
                <Grid>
                  <!-- Inner shadow (recess effect) -->
                  <Border Margin="1" CornerRadius="9" BoxShadow="0 2 6 0 #AA000000 inset" />

                  <!-- Top specular highlight (glass shine) -->
                  <Border Height="16" VerticalAlignment="Top" Margin="8,1,8,0" CornerRadius="8,8,0,0">
                    <Border.Background>
                      <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#44FFFFFF" Offset="0" />
                        <GradientStop Color="#00FFFFFF" Offset="1" />
                      </LinearGradientBrush>
                    </Border.Background>
                  </Border>

                  <ScrollViewer Name="PART_ScrollViewer"
                                Margin="{TemplateBinding Padding}"
                                HorizontalScrollBarVisibility="Hidden"
                                VerticalScrollBarVisibility="Hidden">
                    <TextPresenter Name="PART_TextPresenter"
                                   Text="{TemplateBinding Text}"
                                   TextElement.Foreground="{TemplateBinding Foreground}"
                                   TextElement.FontSize="{TemplateBinding FontSize}"
                                   CaretBrush="{TemplateBinding CaretBrush}"
                                   SelectionBrush="{DynamicResource Brush.AccentGradient}"
                                   SelectionForegroundBrush="White" />
                  </ScrollViewer>
                </Grid>
              </Border>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>

      <Setter Property="Transitions">
        <Setter.Value>
          <Transitions>
            <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
            <ThicknessTransition Property="BorderThickness" Duration="0:0:0.2"/>
          </Transitions>
        </Setter.Value>
      </Setter>
    </Style>

    <Style Selector="TextBox:focus">
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.AccentGradient}"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <!-- Smooth transitions for combo boxes -->
    <Style Selector="ComboBox">
      <Setter Property="Transitions">
        <Setter.Value>
          <Transitions>
            <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
          </Transitions>
        </Setter.Value>
      </Setter>
    </Style>

    <Style Selector="ComboBox:focus">
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.AccentGradient}"/>
    </Style>

    <!-- DataGrid row hover + selection effects (template-level to override theme) -->

    <!-- Hover row -->
    <Style Selector="DataGridRow:pointerover /template/ Border">
      <Setter Property="Background" Value="#2a2f3a" />
      <Setter Property="Opacity" Value="0.95" />
    </Style>

    <!-- Selected row (very obvious) -->
    <Style Selector="DataGridRow:selected /template/ Border">
      <Setter Property="Background" Value="#334155" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <!-- Selected + hover -->
    <Style Selector="DataGridRow:selected:pointerover /template/ Border">
      <Setter Property="Background" Value="#3b4b66" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <!-- Selected cell (backup) -->
    <Style Selector="DataGridCell:selected /template/ Border">
      <Setter Property="Background" Value="#3b4b66" />
    </Style>

    <Style Selector="DataGridCell:selected">
      <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- Image zoom on hover -->
    <Style Selector="Image.zoomable">
      <Setter Property="Transitions">
        <Setter.Value>
          <Transitions>
            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3" Easing="CubicEaseOut"/>
          </Transitions>
        </Setter.Value>
      </Setter>
    </Style>

    <Style Selector="Image.zoomable:pointerover">
      <Setter Property="RenderTransform" Value="scale(1.05)"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- Smooth panel transitions -->
    <Style Selector="Border">
      <Setter Property="Transitions">
        <Setter.Value>
          <Transitions>
            <BrushTransition Property="Background" Duration="0:0:0.2"/>
            <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
          </Transitions>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Success feedback animation -->
    <Style Selector="Border.success-flash">
      <Style.Animations>
        <Animation Duration="0:0:0.6" FillMode="Forward">
          <KeyFrame Cue="0%">
            <Setter Property="BorderBrush" Value="#10b981"/>
            <Setter Property="BorderThickness" Value="2"/>
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="BorderBrush" Value="#4b5563"/>
            <Setter Property="BorderThickness" Value="1"/>
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

  </Application.Styles>

  <!-- Brand colors / brushes and shared styles -->
  <Application.Resources>
    <ResourceDictionary>
      <!-- Root-level switchable background for section containers (AppearanceService swaps at runtime). -->
      <SolidColorBrush x:Key="Brush.PanelBackground" Color="Transparent" />

      <ResourceDictionary.MergedDictionaries>
        <!-- SukiUI base resources (Light/Dark) -->
        <ResourceInclude Source="avares://SukiUI/Theme/Shadcn/BlackWhiteTheme.axaml" />
      </ResourceDictionary.MergedDictionaries>

      <!-- Brand colors (tune to match MetalLink logo exactly) -->
      <Color x:Key="Color.PrimaryBlue">#1E88E5</Color>
      <Color x:Key="Color.LightBlue">#8EC5FC</Color>
      <Color x:Key="Color.PrimaryBlueDark">#0D47A1</Color>

      <!-- Accent brush is theme-independent -->
      <LinearGradientBrush x:Key="Brush.AccentGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource Color.PrimaryBlue}" Offset="0" />
        <GradientStop Color="{StaticResource Color.LightBlue}" Offset="1" />
      </LinearGradientBrush>

      <!-- Theme-specific resources (single ThemeDictionaries block; avoids duplicate Light/Dark keys) -->
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <!-- Light palette -->
          <Color x:Key="Color.Background">#F2F4F7</Color>
          <Color x:Key="Color.NavBackground">#E6F2F4F7</Color>
          <Color x:Key="Color.Panel">#FFFFFF</Color>
          <Color x:Key="Color.StatusBackground">#EEF1F5</Color>
          <Color x:Key="Color.TextPrimary">#111827</Color>
          <Color x:Key="Color.TextMuted">#4B5563</Color>
          <Color x:Key="Color.BorderSubtle">#D1D5DB</Color>

          <!-- Brushes -->
          <SolidColorBrush x:Key="Brush.WindowBaseBackground" Color="{StaticResource Color.Background}" />
          <SolidColorBrush x:Key="Brush.NavBackground" Color="{StaticResource Color.NavBackground}" />

          <SolidColorBrush x:Key="Brush.SolidPanelBackground" Color="{StaticResource Color.Panel}" />

          <SolidColorBrush x:Key="Brush.StatusBackground" Color="{StaticResource Color.StatusBackground}" />
          <SolidColorBrush x:Key="Brush.BorderSubtle" Color="{StaticResource Color.BorderSubtle}" />
          <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}" />
          <SolidColorBrush x:Key="Brush.TextMuted" Color="{StaticResource Color.TextMuted}" />
          
          <!-- Glass panel for dashboard cards - translucent to show metal -->
          <SolidColorBrush x:Key="Brush.GlassPanelCrystal" Color="#40FFFFFF" />
          <SolidColorBrush x:Key="Brush.GlassPanelDarker" Color="#30FFFFFF" />
          <SolidColorBrush x:Key="Brush.GlassBorderCrystal" Color="#60000000" />

          <!-- Active (swapped by AppearanceService) -->
          <SolidColorBrush x:Key="Brush.GlassPanel" Color="#40FFFFFF" />
          <SolidColorBrush x:Key="Brush.GlassBorder" Color="#60000000" />

          <!-- Inputs -->
          <SolidColorBrush x:Key="Brush.InputBackground" Color="#F3F4F6" />
          <SolidColorBrush x:Key="Brush.InputBorder" Color="#C7CDD6" />

          <!-- Main content area - very translucent to show brushed metal -->
          <SolidColorBrush x:Key="Brush.MainBackground" Color="#33F2F4F7" />
          <SolidColorBrush x:Key="Brush.WindowBackground" Color="#FFF2F4F7" />

          <!-- App background gradient (subtle) -->
          <LinearGradientBrush x:Key="Brush.AppBackground" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F7FAFF" Offset="0" />
            <GradientStop Color="#EEF2F7" Offset="1" />
          </LinearGradientBrush>

          <!-- Brushed metal IMAGE background (silver sheet) -->
          <ImageBrush x:Key="Brush.MetalBackgroundVector"
                      Source="avares://MetalLink.Desktop/Assets/vector-brushed-metal-background.jpg"
                      Stretch="UniformToFill" />

          <ImageBrush x:Key="Brush.MetalButtonFace"
                      Source="avares://MetalLink.Desktop/Assets/brushed_button.png"
                      Stretch="None"
                      TileMode="Tile"
                      DestinationRect="0,0,256,256" />

          <!-- Active background -->
          <ImageBrush x:Key="Brush.MetalBackground"
                      Source="avares://MetalLink.Desktop/Assets/image.jpg"
                      Stretch="UniformToFill" />

          <!-- (Legacy gradient overlay kept, but we will stop using it) -->
          <LinearGradientBrush x:Key="Brush.BrushedOverlay" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#00FFFFFF" Offset="0" />
            <GradientStop Color="#66FFFFFF" Offset="0.06" />
            <GradientStop Color="#00FFFFFF" Offset="0.12" />
            <GradientStop Color="#55FFFFFF" Offset="0.18" />
            <GradientStop Color="#00FFFFFF" Offset="0.24" />
            <GradientStop Color="#44FFFFFF" Offset="0.30" />
            <GradientStop Color="#00FFFFFF" Offset="0.36" />
            <GradientStop Color="#55FFFFFF" Offset="0.42" />
            <GradientStop Color="#00FFFFFF" Offset="0.48" />
            <GradientStop Color="#3AFFFFFF" Offset="0.54" />
            <GradientStop Color="#00FFFFFF" Offset="0.60" />
            <GradientStop Color="#4AFFFFFF" Offset="0.66" />
            <GradientStop Color="#00FFFFFF" Offset="0.72" />
            <GradientStop Color="#33FFFFFF" Offset="0.78" />
            <GradientStop Color="#00FFFFFF" Offset="0.84" />
            <GradientStop Color="#22FFFFFF" Offset="0.92" />
            <GradientStop Color="#00FFFFFF" Offset="1" />
          </LinearGradientBrush>

          <!-- Diagonal sheen (adds more "metal" feel) -->
          <LinearGradientBrush x:Key="Brush.BrushedSheen" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#00FFFFFF" Offset="0" />
            <GradientStop Color="#18FFFFFF" Offset="0.35" />
            <GradientStop Color="#00FFFFFF" Offset="0.7" />
            <GradientStop Color="#12FFFFFF" Offset="1" />
          </LinearGradientBrush>
        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">
          <!-- Dark palette -->
          <Color x:Key="Color.Background">#1F2229</Color>
          <Color x:Key="Color.NavBackground">#E620232A</Color>
          <Color x:Key="Color.Panel">#252932</Color>
          <Color x:Key="Color.StatusBackground">#181A20</Color>
          <Color x:Key="Color.TextPrimary">#F5F5F5</Color>
          <Color x:Key="Color.TextMuted">#C0C4CF</Color>
          <Color x:Key="Color.BorderSubtle">#3A404A</Color>

          <!-- Brushes -->
          <SolidColorBrush x:Key="Brush.WindowBaseBackground" Color="{StaticResource Color.Background}" />
          <SolidColorBrush x:Key="Brush.NavBackground" Color="{StaticResource Color.NavBackground}" />

          <SolidColorBrush x:Key="Brush.SolidPanelBackground" Color="{StaticResource Color.Panel}" />

          <SolidColorBrush x:Key="Brush.StatusBackground" Color="{StaticResource Color.StatusBackground}" />
          <SolidColorBrush x:Key="Brush.BorderSubtle" Color="{StaticResource Color.BorderSubtle}" />
          <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}" />
          <SolidColorBrush x:Key="Brush.TextMuted" Color="{StaticResource Color.TextMuted}" />
          
          <!-- Glass panel for dashboard cards - translucent to show metal -->
          <SolidColorBrush x:Key="Brush.GlassPanelCrystal" Color="#40252932" />
          <SolidColorBrush x:Key="Brush.GlassPanelDarker" Color="#30111827" />
          <SolidColorBrush x:Key="Brush.GlassBorderCrystal" Color="#60FFFFFF" />

          <!-- Active (swapped by AppearanceService) -->
          <SolidColorBrush x:Key="Brush.GlassPanel" Color="#40252932" />
          <SolidColorBrush x:Key="Brush.GlassBorder" Color="#60FFFFFF" />

          <!-- Inputs -->
          <SolidColorBrush x:Key="Brush.InputBackground" Color="#1B1F27" />
          <SolidColorBrush x:Key="Brush.InputBorder" Color="#4B5563" />

          <!-- Main content area - very translucent to show brushed metal -->
          <SolidColorBrush x:Key="Brush.MainBackground" Color="#331F2229" />
          <SolidColorBrush x:Key="Brush.WindowBackground" Color="#FF1F2229" />

          <!-- App background gradient -->
          <LinearGradientBrush x:Key="Brush.AppBackground" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{StaticResource Color.PrimaryBlueDark}" Offset="0" />
            <GradientStop Color="{StaticResource Color.Background}" Offset="0.25" />
            <GradientStop Color="{StaticResource Color.Background}" Offset="1" />
          </LinearGradientBrush>

          <!-- Brushed metal IMAGE background (silver sheet) -->
          <ImageBrush x:Key="Brush.MetalBackgroundVector"
                      Source="avares://MetalLink.Desktop/Assets/vector-brushed-metal-background.jpg"
                      Stretch="UniformToFill" />

          <ImageBrush x:Key="Brush.MetalButtonFace"
                      Source="avares://MetalLink.Desktop/Assets/brushed_button.png"
                      Stretch="None"
                      TileMode="Tile"
                      DestinationRect="0,0,256,256" />

          <!-- Active background -->
          <ImageBrush x:Key="Brush.MetalBackground"
                      Source="avares://MetalLink.Desktop/Assets/image.jpg"
                      Stretch="UniformToFill" />

          <LinearGradientBrush x:Key="Brush.BrushedOverlay" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#00000000" Offset="0" />
            <GradientStop Color="#35FFFFFF" Offset="0.06" />
            <GradientStop Color="#00000000" Offset="0.12" />
            <GradientStop Color="#2CFFFFFF" Offset="0.18" />
            <GradientStop Color="#00000000" Offset="0.24" />
            <GradientStop Color="#24FFFFFF" Offset="0.30" />
            <GradientStop Color="#00000000" Offset="0.36" />
            <GradientStop Color="#2CFFFFFF" Offset="0.42" />
            <GradientStop Color="#00000000" Offset="0.48" />
            <GradientStop Color="#1EFFFFFF" Offset="0.54" />
            <GradientStop Color="#00000000" Offset="0.60" />
            <GradientStop Color="#28FFFFFF" Offset="0.66" />
            <GradientStop Color="#00000000" Offset="0.72" />
            <GradientStop Color="#18FFFFFF" Offset="0.78" />
            <GradientStop Color="#00000000" Offset="0.84" />
            <GradientStop Color="#12FFFFFF" Offset="0.92" />
            <GradientStop Color="#00000000" Offset="1" />
          </LinearGradientBrush>

          <LinearGradientBrush x:Key="Brush.BrushedSheen" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#00000000" Offset="0" />
            <GradientStop Color="#22FFFFFF" Offset="0.35" />
            <GradientStop Color="#00000000" Offset="0.7" />
            <GradientStop Color="#1AFFFFFF" Offset="1" />
          </LinearGradientBrush>
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>

    </ResourceDictionary>
  </Application.Resources>

</Application>
