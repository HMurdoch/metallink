<UserControl
    x:Class="MetalLink.Desktop.Views.CompanyAndSiteView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <UserControl.Resources>
    <DataTemplate x:Key="CompanyLookupTemplate">
      <TextBlock Text="{Binding CompanyName}" />
    </DataTemplate>

    <DataTemplate x:Key="SiteLookupTemplate">
      <TextBlock Text="{Binding SiteName}" />
    </DataTemplate>
  </UserControl.Resources>

  <Border Background="#1f2229" Padding="16">
    <ScrollViewer>
      <StackPanel Spacing="16">

        <!-- Header -->
        <TextBlock
            Text="Companies"
            FontSize="20"
            FontWeight="Bold"
            Foreground="#f5f5f5" />

        <!-- Search -->
        <Border Background="#252932" Padding="12" CornerRadius="4">
          <StackPanel Spacing="10">
            <TextBlock Text="Search company" Foreground="#f5f5f5" FontWeight="Bold" />

            <!-- 2-column layout, left column used -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
              <StackPanel Grid.Column="0" Spacing="6">
                <TextBlock Text="Company" Foreground="#c0c4cf" />
                <Grid ColumnDefinitions="70,*,*">
                  <ComboBox
                    Grid.Column="0"
                    ItemsSource="{Binding CompanyLetterFilters}"
                    SelectedItem="{Binding SelectedCompanyLetter}" />

                  <!-- middle column is HALF of the available width -->
                  <ComboBox
                    Grid.Column="1"
                    Margin="4,0,0,0"
                    HorizontalAlignment="Stretch"
                    ItemsSource="{Binding SearchCompanySuggestions}"
                    SelectedItem="{Binding SelectedSearchCompany}"
                    ItemTemplate="{StaticResource CompanyLookupTemplate}" />
                </Grid>
                <Button Content="Search"
                        Command="{Binding SearchCompaniesCommand}"
                        HorizontalAlignment="Left"
                        Width="100" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Results -->
        <Border Background="#252932" Padding="12" CornerRadius="4">
          <StackPanel Spacing="8">
            <TextBlock Text="Results" Foreground="#f5f5f5" FontWeight="Bold" />

            <DataGrid
              AutoGenerateColumns="False"
              ItemsSource="{Binding CompanyResults}"
              SelectedItem="{Binding SelectedCompany, Mode=TwoWay}"
              Height="220">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Company ID" Binding="{Binding CompanyId}" IsReadOnly="True" Width="120" />
                <DataGridTextColumn Header="Company Name" Binding="{Binding CompanyName}" IsReadOnly="True" Width="*" />

                <DataGridTemplateColumn Header="" Width="220">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button
                          Content="Edit"
                          Padding="6,2"
                          Command="{Binding DataContext.EditCompanyCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}" />
                        <Button
                          Content="Delete"
                          Padding="6,2"
                          Command="{Binding DataContext.DeleteCompanyCommand,
                                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}" />
                        <Button
                          Content="Sites"
                          Padding="6,2"
                          Command="{Binding DataContext.LoadSitesForCompanyCommand,
                                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}" />
                      </StackPanel>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
          </StackPanel>
        </Border>

        <!-- Create new company -->
        <Border Background="#252932" Padding="12" CornerRadius="4">
          <StackPanel Spacing="10">
            <TextBlock Text="Create New Company" Foreground="#f5f5f5" FontWeight="Bold" />
              <Border Margin="0,12,0,0"
                      Padding="12"
                      Background="#2A2F38"
                      CornerRadius="6">

                <StackPanel Spacing="8">
                  <TextBlock Text="Create New Company"
                            FontSize="16"
                            FontWeight="Bold"
                            Margin="0,0,0,6" />

                  <TextBox
                    Watermark="Company name"
                    Text="{Binding NewCompanyCreateName, Mode=TwoWay}" />

                  <TextBox
                    Watermark="Site name"
                    Text="{Binding NewCompanyCreateSiteName, Mode=TwoWay}" />

                  <Button
                    Content="Create"
                    Command="{Binding CreateCompanyCommand}"
                    IsEnabled="{Binding CanCreateCompany}" />
                </StackPanel>

              </Border>
          </StackPanel>
        </Border>

        <!-- Sites -->
        <Border Background="#252932" Padding="12" CornerRadius="4">
          <StackPanel Spacing="8">
            <TextBlock Text="Sites" Foreground="#f5f5f5" FontWeight="Bold" />

            <DataGrid
              AutoGenerateColumns="False"
              ItemsSource="{Binding SiteResults}"
              SelectedItem="{Binding SelectedSite, Mode=TwoWay}"
              Height="220">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Site ID" Binding="{Binding SiteId}" IsReadOnly="True" Width="90" />
                <DataGridTextColumn Header="Site Name" Binding="{Binding SiteName}" IsReadOnly="True" Width="*" />
                <DataGridTextColumn Header="Site Code" Binding="{Binding SiteCode}" IsReadOnly="True" Width="120" />

                <DataGridTemplateColumn Header="" Width="180">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button
                          Content="Edit"
                          Padding="6,2"
                          Command="{Binding DataContext.EditSiteCommand,
                                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}" />
                        <Button
                          Content="Delete"
                          Padding="6,2"
                          Command="{Binding DataContext.DeleteSiteCommand,
                                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}" />
                      </StackPanel>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>

          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>
  </Border>
</UserControl>
