<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Avalonia;assembly=LiveChartsCore.SkiaSharpView.Avalonia"
             x:Class="MetalLink.Desktop.Views.StockMovementView">

  <Grid RowDefinitions="Auto,*">
    <!-- Sticky Header Panel -->
    <Border Grid.Row="0" 
            Background="{DynamicResource Brush.PanelBackground}"
            Padding="12,8"
            CornerRadius="4"
            Margin="16,16,16,8"
            ZIndex="100">
      <Image Source="avares://MetalLink.Desktop/Assets/stock_movements_heading.png"
             Height="40"
             HorizontalAlignment="Left"
             Stretch="Uniform" />
    </Border>
    
    <!-- Scrollable Content -->
    <ScrollViewer Grid.Row="1" Padding="16,8,16,10">
      <StackPanel Spacing="14" Margin="0,0,0,80">

      <!-- Filters -->
      <Border Background="{DynamicResource Brush.GlassPanel}" BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1"
              CornerRadius="10" Padding="12">
        <StackPanel Spacing="10">
          <Grid PointerPressed="ToggleFilter" Cursor="Hand">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" 
                       Text="{Binding IsFilterExpanded, Converter={StaticResource SectionToViewConverter}, ConverterParameter='arrow'}" 
                       Foreground="{DynamicResource Brush.TextPrimary}" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Text="Stock Movement Filters" Foreground="{DynamicResource Brush.TextPrimary}" FontWeight="Bold" />
          </Grid>
          <StackPanel Spacing="10" IsVisible="{Binding IsFilterExpanded}">

            <!-- Product Filter (same as Stock Levels) -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
              <TextBox Grid.Column="0"
                       Watermark="Product Search"
                       Text="{Binding ProductSearchText, UpdateSourceTrigger=PropertyChanged}" />

              <Grid Grid.Column="1" ColumnDefinitions="120,*,Auto" ColumnSpacing="10">
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding ProductLetterFilters}"
                          SelectedItem="{Binding SelectedProductLetter}" />

                <ComboBox Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          ItemsSource="{Binding ProductSuggestions}"
                          SelectedItem="{Binding SelectedProduct}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding ProductName}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>

                <Button Grid.Column="2" Content="Clear" Command="{Binding ClearProductCommand}" />
              </Grid>
            </Grid>

            <!-- All history toggle -->
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" VerticalAlignment="Center">
              <TextBlock Grid.Column="0" Text="All History" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" />
              <ToggleSwitch Grid.Column="1" IsChecked="{Binding AllHistory}" HorizontalAlignment="Left" />
            </Grid>

            <!-- Date+time range (hidden when AllHistory) -->
            <Grid IsVisible="{Binding IsRangeVisible}"
                  ColumnDefinitions="Auto,Auto,*,Auto,Auto,*"
                  ColumnSpacing="10"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="8">

              <!-- FROM row -->
              <TextBlock Grid.Row="0" Grid.Column="0" Text="From" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" />
              <CheckBox Grid.Row="0" Grid.Column="1" Content="Day 0" IsChecked="{Binding FromDay0}" VerticalAlignment="Center" />

              <DatePicker Grid.Row="0" Grid.Column="2" SelectedDate="{Binding FromDate}" IsEnabled="{Binding IsFromPickerEnabled}" />

              <TextBlock Grid.Row="0" Grid.Column="3" Text="Time" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" />
              <ComboBox Grid.Row="0" Grid.Column="4" Width="90"
                        ItemsSource="{Binding TimeOptions5Min}"
                        SelectedItem="{Binding FromTime}"
                        IsEnabled="{Binding IsFromPickerEnabled}">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding StringFormat={}{0:hh\\:mm}}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>

              <!-- TO row -->
              <TextBlock Grid.Row="1" Grid.Column="0" Text="To" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" />
              <CheckBox Grid.Row="1" Grid.Column="1" Content="Now" IsChecked="{Binding ToNow}" VerticalAlignment="Center" />

              <DatePicker Grid.Row="1" Grid.Column="2" SelectedDate="{Binding ToDate}" IsEnabled="{Binding IsToPickerEnabled}" />

              <TextBlock Grid.Row="1" Grid.Column="3" Text="Time" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" />
              <ComboBox Grid.Row="1" Grid.Column="4" Width="90"
                        ItemsSource="{Binding TimeOptions5Min}"
                        SelectedItem="{Binding ToTime}"
                        IsEnabled="{Binding IsToPickerEnabled}">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding StringFormat={}{0:hh\\:mm}}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>

            </Grid>

          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Line chart: 20 products on current page -->
      <Border Background="{DynamicResource Brush.GlassPanel}" BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1"
              CornerRadius="10" Padding="12">
        <StackPanel Spacing="8">
          <Grid PointerPressed="ToggleChart" Cursor="Hand">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" 
                       Text="{Binding IsChartExpanded, Converter={StaticResource SectionToViewConverter}, ConverterParameter='arrow'}" 
                       Foreground="{DynamicResource Brush.TextPrimary}" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Text="Stock level over time" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource Brush.TextPrimary}" />
          </Grid>
          <!-- Explicit height so the chart is visible even before it has data -->
          <lvc:CartesianChart Height="300"
                             MinHeight="260"
                             Background="{DynamicResource Brush.SolidPanelBackground}"
                             Series="{Binding Series}"
                             XAxes="{Binding XAxes}"
                             IsVisible="{Binding IsChartExpanded}" />
        </StackPanel>
      </Border>

      <!-- Results grid + paging -->
      <Border Background="{DynamicResource Brush.GlassPanel}" BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1"
              CornerRadius="10" Padding="12">
        <StackPanel Spacing="8">
          <Grid PointerPressed="ToggleResults" Cursor="Hand">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" 
                       Text="{Binding IsResultsExpanded, Converter={StaticResource SectionToViewConverter}, ConverterParameter='arrow'}" 
                       Foreground="{DynamicResource Brush.TextPrimary}" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Text="Movement History" Foreground="{DynamicResource Brush.TextPrimary}" FontWeight="Bold" />
          </Grid>
          <Grid RowDefinitions="*,Auto" IsVisible="{Binding IsResultsExpanded}">
          <StackPanel Grid.Row="1" Spacing="6" Margin="0,10,0,0">
            <TextBlock Text="{Binding PaginationStatusText}" HorizontalAlignment="Center" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
              <TextBlock Text="Page size" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" />
              <ComboBox Width="90" ItemsSource="{Binding Pagination.PageSizeOptions}" SelectedItem="{Binding Pagination.PageSize}" />

              <Button Content="Prev" Command="{Binding Pagination.PreviousPageCommand}" IsEnabled="{Binding Pagination.CanGoPrevious}" />
              <TextBlock Text="{Binding Pagination.CurrentPage}" Foreground="{DynamicResource Brush.TextPrimary}" />
              <TextBlock Text="/" Foreground="{DynamicResource Brush.TextMuted}" />
              <TextBlock Text="{Binding Pagination.TotalPages}" Foreground="{DynamicResource Brush.TextPrimary}" />
              <Button Content="Next" Command="{Binding Pagination.NextPageCommand}" IsEnabled="{Binding Pagination.CanGoNext}" />
            </StackPanel>
          </StackPanel>

          <DataGrid Grid.Row="0" x:Name="MovementGrid"
                    ItemsSource="{Binding Rows}" AutoGenerateColumns="False" IsReadOnly="True"
                    FontSize="11" RowHeight="16">
            <DataGrid.Styles>
              <!-- Match Stock Levels compact rows -->
              <Style Selector="#MovementGrid DataGridRow">
                <Setter Property="Height" Value="16" />
                <Setter Property="MinHeight" Value="16" />
                <Setter Property="Padding" Value="0" />
              </Style>
              <Style Selector="#MovementGrid DataGridRow /template/ Border">
                <Setter Property="Margin" Value="0" />
                <Setter Property="Padding" Value="0" />
              </Style>
              <Style Selector="#MovementGrid DataGridCell">
                <Setter Property="Padding" Value="6,0" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
              </Style>
              <Style Selector="#MovementGrid DataGridCell TextBlock">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="VerticalAlignment" Value="Center" />
              </Style>
            </DataGrid.Styles>

            <DataGrid.Columns>
              <DataGridTextColumn Header="Code" Binding="{Binding ProductCode}" Width="120" />
              <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*" />
              <DataGridTextColumn Header="On Hand (kg)" Binding="{Binding WeightKg}" Width="180" />
            </DataGrid.Columns>
          </DataGrid>

        </Grid>
        </StackPanel>
      </Border>

        </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
