<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MetalLink.Desktop.Views.StockMovementView">

  <Border Padding="24" Background="{DynamicResource Brush.MainBackground}">
    <StackPanel Spacing="8">
      <TextBlock Text="Stock Movement" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource Brush.TextPrimary}" />
      <TextBlock Text="Placeholder screen (to be implemented)." Foreground="{DynamicResource Brush.TextMuted}" />
    </StackPanel>
  </Border>

</UserControl>
