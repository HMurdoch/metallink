<UserControl
  x:Class="MetalLink.Desktop.Views.CompanyAndSitesView"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="using:MetalLink.Desktop.Views">

  <UserControl.Resources>
    <DataTemplate x:Key="CompanyLookupTemplate">
      <TextBlock Text="{Binding CompanyName}" />
    </DataTemplate>

    <DataTemplate x:Key="SiteLookupTemplate">
      <TextBlock Text="{Binding SiteName}" />
    </DataTemplate>

    <DataTemplate x:Key="ProvinceLookupTemplate">
      <TextBlock Text="{Binding ProvinceName}" />
    </DataTemplate>

    <DataTemplate x:Key="CountryLookupTemplate">
      <TextBlock Text="{Binding CountryName}" />
    </DataTemplate>
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="TextBox">
      <Setter Property="BorderBrush" Value="#444a55" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="TextBox:focus">
      <Setter Property="BorderBrush" Value="#5c7cfa" />
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="BorderBrush" Value="#444a55" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="ComboBox:focus">
      <Setter Property="BorderBrush" Value="#5c7cfa" />
    </Style>
    <Style Selector="DataGrid">
      <Setter Property="Background" Value="{DynamicResource Brush.PanelBackground}" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
      <Setter Property="GridLinesVisibility" Value="Horizontal" />
      <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="DataGridCell">
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="DataGridColumnHeader">
      <Setter Property="Background" Value="{DynamicResource Brush.NavBackground}" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>
    <Style Selector="Button.row-action">
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
      <Setter Property="Background" Value="#30333A" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="Padding" Value="6,2" />
      <Setter Property="FontSize" Value="11" />
    </Style>
  </UserControl.Styles>

  <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,*">
    <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{DynamicResource Brush.PanelBackground}" Padding="12,8" CornerRadius="4" Margin="16,16,16,8" ZIndex="100">
      <Image Source="avares://MetalLink.Desktop/Assets/companies_and_sites_heading.png" Height="40" HorizontalAlignment="Left" Stretch="Uniform" />
    </Border>
    
    <ScrollViewer Grid.Row="1" Grid.ColumnSpan="2" Padding="16,8,16,10">
      <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="16" RowSpacing="16" Margin="0,0,0,16">
        
        <!-- ROW 1, COL 1: Search Company (Expanded on load) -->
        <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource Brush.PanelBackground}" Padding="12" CornerRadius="4" VerticalAlignment="Bottom">
          <StackPanel Spacing="10">
            <Grid PointerPressed="ToggleSearchCriteria" Cursor="Hand">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="{Binding CompanyIsSearchCriteriaExpanded, Converter={StaticResource SectionToViewConverter}, ConverterParameter='arrow'}" Foreground="{DynamicResource Brush.TextPrimary}" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="Search Company" Foreground="{DynamicResource Brush.TextPrimary}" FontWeight="Bold" />
            </Grid>
            <StackPanel IsVisible="{Binding CompanyIsSearchCriteriaExpanded}" Spacing="6">
              <TextBlock Text="Company Search" Foreground="#c0c4cf" />
              <Grid ColumnDefinitions="*,70">
                <TextBox Grid.Column="0" Text="{Binding CompanySearchText, Mode=TwoWay}" Watermark="Filter by name..." Margin="0,0,4,0"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding CompanyLetterFilters}" SelectedItem="{Binding SelectedCompanyLetter}" />
              </Grid>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ROW 1-2, COL 2: Company Results (Spans rows 1 & 2) -->
        <Border Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Background="{DynamicResource Brush.PanelBackground}" Padding="12" CornerRadius="4" VerticalAlignment="Stretch" Width="790" HorizontalAlignment="Left">
          <StackPanel Spacing="8">
            <Grid PointerPressed="ToggleSearchResults" Cursor="Hand">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="{Binding CompanyIsSearchResultsExpanded, Converter={StaticResource SectionToViewConverter}, ConverterParameter='arrow'}" Foreground="{DynamicResource Brush.TextPrimary}" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="Company Results" Foreground="{DynamicResource Brush.TextPrimary}" FontWeight="Bold" />
            </Grid>
            <StackPanel IsVisible="{Binding CompanyIsSearchResultsExpanded}" Spacing="8">
              <DataGrid ItemsSource="{Binding PagedCompanyResults}" SelectedItem="{Binding SelectedCompany, Mode=TwoWay}" Height="620" AutoGenerateColumns="False" IsReadOnly="True" Focusable="False">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="ID" Binding="{Binding CompanyId}" Width="60" />
                  <DataGridTextColumn Header="Company Name" Binding="{Binding CompanyName}" Width="*" />
                  <DataGridTextColumn Header="VAT Number" Binding="{Binding VatNumber}" Width="200" />
                  <DataGridTemplateColumn Header="" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <Button Classes="row-action" Content="Delete" Command="{Binding $parent[UserControl].DataContext.DeleteCompanyCommand}" CommandParameter="{Binding}" />
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                </DataGrid.Columns>
              </DataGrid>
              <local:PaginationControl DataContext="{Binding PaginationViewModel}" Margin="0,8,0,0"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ROW 2, COL 1: Create/Edit Company -->
        <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource Brush.PanelBackground}" Padding="12" CornerRadius="4" VerticalAlignment="Top">
          <StackPanel Spacing="10">
            <Grid PointerPressed="ToggleCreateEdit" Cursor="Hand">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="{Binding CompanyIsCreateEditExpanded, Converter={StaticResource SectionToViewConverter}, ConverterParameter='arrow'}" Foreground="{DynamicResource Brush.TextPrimary}" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="Create/Edit Company" Foreground="{DynamicResource Brush.TextPrimary}" FontWeight="Bold" />
            </Grid>
            <StackPanel IsVisible="{Binding CompanyIsCreateEditExpanded}" Spacing="10">
              <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                  <TextBlock Text="Company name" Foreground="#c0c4cf" />
                  <TextBox Watermark="Company name" Text="{Binding CompanyEditName, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6">
                  <TextBlock Text="VAT number (optional)" Foreground="#c0c4cf" />
                  <TextBox Watermark="VAT number (optional)" Text="{Binding CompanyVatNumber, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="6" IsVisible="{Binding IsCompanyInitialSiteVisible}">
                  <TextBlock Text="Initial site name" Foreground="#c0c4cf" />
                  <TextBox Watermark="Initial Site Name" Text="{Binding CompanyFormInitialSiteName, Mode=TwoWay}" />
                </StackPanel>
              </Grid>
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Width="100" Content="Clear" Command="{Binding ClearCompanyFormCommand}" />
                <Button Width="100" Content="Create" Command="{Binding CreateCompanyCommand}" IsVisible="{Binding IsCompanyCreateMode}" />
                <Button Width="100" Content="Update" Command="{Binding UpdateCompanyCommand}" IsVisible="{Binding IsCompanyEditMode}" />
              </StackPanel>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ROW 3, COL 1: Sites Results -->
        <Border Grid.Row="2" Grid.Column="0" Background="{DynamicResource Brush.PanelBackground}" Padding="12" CornerRadius="4">
          <StackPanel Spacing="8">
            <Grid PointerPressed="ToggleSites" Cursor="Hand">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="{Binding CompanyIsPanelExpanded, Converter={StaticResource SectionToViewConverter}, ConverterParameter='arrow'}" Foreground="{DynamicResource Brush.TextPrimary}" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="Site Results" Foreground="{DynamicResource Brush.TextPrimary}" FontWeight="Bold" />
            </Grid>
            <StackPanel IsVisible="{Binding CompanyIsPanelExpanded}" Spacing="8">
              <DataGrid ItemsSource="{Binding PagedSiteResults}" SelectedItem="{Binding SelectedSite, Mode=TwoWay}" Height="300" AutoGenerateColumns="False" IsReadOnly="True" Focusable="False">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="ID" Binding="{Binding SiteId}" Width="60" />
                  <DataGridTextColumn Header="Site Name" Binding="{Binding SiteName}" Width="*" />
                  <DataGridTextColumn Header="Site Code" Binding="{Binding SiteCode}" Width="250" />
                  <DataGridTemplateColumn Header="" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <Button Classes="row-action" Content="Delete" Command="{Binding $parent[UserControl].DataContext.DeleteSiteCommand}" CommandParameter="{Binding}" IsVisible="{Binding IsDeleteVisible}" />
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                </DataGrid.Columns>
              </DataGrid>
              <local:PaginationControl DataContext="{Binding SitePaginationViewModel}" Margin="0,8,0,0"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ROW 3, COL 2: Create/Edit Site -->
        <Border Grid.Row="2" Grid.Column="1" Background="{DynamicResource Brush.PanelBackground}" Padding="12" CornerRadius="4">
          <StackPanel Spacing="10">
            <Grid PointerPressed="ToggleSiteCreateEdit" Background="Transparent" Cursor="Hand">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="{Binding IsSiteCreateEditExpanded, Converter={StaticResource SectionToViewConverter}, ConverterParameter='arrow'}" Foreground="{DynamicResource Brush.TextPrimary}" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="Create/Edit Site" Foreground="{DynamicResource Brush.TextPrimary}" FontWeight="Bold" />
            </Grid>
            <StackPanel IsVisible="{Binding IsSiteCreateEditExpanded}" Spacing="10">
              <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                  <TextBlock Text="Site name" Foreground="#c0c4cf" />
                  <TextBox Text="{Binding SiteName, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6">
                  <TextBlock Text="Site code" Foreground="#c0c4cf" />
                  <TextBox Text="{Binding SiteCode, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="6">
                  <TextBlock Text="Address line 1" Foreground="#c0c4cf" />
                  <TextBox Text="{Binding AddressLine1, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                  <TextBlock Text="Address line 2" Foreground="#c0c4cf" />
                  <TextBox Text="{Binding AddressLine2, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="0" Spacing="6">
                  <TextBlock Text="Suburb" Foreground="#c0c4cf" />
                  <TextBox Text="{Binding Suburb, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" Spacing="6">
                  <TextBlock Text="City" Foreground="#c0c4cf" />
                  <TextBox Text="{Binding City, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Row="3" Grid.Column="0" Spacing="6">
                  <TextBlock Text="Postal code" Foreground="#c0c4cf" />
                  <TextBox Text="{Binding PostalCode, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Row="3" Grid.Column="1" Spacing="6">
                  <TextBlock Text="Province" Foreground="#c0c4cf" HorizontalAlignment="Left" />
                  <ComboBox Width="250" HorizontalAlignment="Left" ItemsSource="{Binding Provinces}" SelectedItem="{Binding SelectedProvince, Mode=TwoWay}" ItemTemplate="{StaticResource ProvinceLookupTemplate}" />
                </StackPanel>
                <StackPanel Grid.Row="4" Grid.Column="0" Spacing="6">
                  <TextBlock Text="Country" Foreground="#c0c4cf" HorizontalAlignment="Left" />
                  <ComboBox Width="250" HorizontalAlignment="Left" ItemsSource="{Binding Countries}" SelectedItem="{Binding SelectedCountry, Mode=TwoWay}" ItemTemplate="{StaticResource CountryLookupTemplate}" />
                </StackPanel>
              </Grid>
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Width="100" Content="Clear" Command="{Binding ClearSiteFormCommand}" />
                <Button Width="100" Content="Create" Command="{Binding CreateOrUpdateSiteCommand}" IsVisible="{Binding !IsSiteEditMode}" />
                <Button Width="100" Content="Update" Command="{Binding CreateOrUpdateSiteCommand}" IsVisible="{Binding IsSiteEditMode}" />
              </StackPanel>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ROW 4, COL 1-2: Site Documentation -->
        <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Background="{DynamicResource Brush.PanelBackground}" Padding="12" CornerRadius="4">
          <StackPanel Spacing="10">
            <Grid PointerPressed="ToggleSiteDocumentation" Background="Transparent" Cursor="Hand">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="{Binding IsSiteDocumentationExpanded, Converter={StaticResource SectionToViewConverter}, ConverterParameter='arrow'}" Foreground="{DynamicResource Brush.TextPrimary}" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="Site Documentation" Foreground="{DynamicResource Brush.TextPrimary}" FontWeight="Bold" />
            </Grid>
            
            <StackPanel IsVisible="{Binding IsSiteDocumentationExpanded}" Spacing="16">
              <!-- Site Documentation Row (All 5 next to each other) -->
              <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                <!-- CIPC Document -->
                <StackPanel Spacing="8" Width="180">
                  <TextBlock Text="CIPC Document" HorizontalAlignment="Center" Foreground="#c0c4cf" FontSize="11" />
                  <Border Width="160" Height="120" BorderBrush="#444a55" BorderThickness="1" Background="#1a1c1e">
                    <Panel>
                      <Image Source="{Binding SelectedCipcDocument}" Stretch="Uniform" />
                      <TextBlock Text="No Document" IsVisible="{Binding SelectedCipcDocument, Converter={x:Static ObjectConverters.IsNull}}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#666" FontSize="11" />
                    </Panel>
                  </Border>
                  <Button Width="160" Height="28" Content="Scan CIPC" HorizontalAlignment="Center" Command="{Binding UploadCipcDocumentCommand}" Background="#30333A" Foreground="White" BorderBrush="#444a55" BorderThickness="1" CornerRadius="3" FontSize="11" />
                </StackPanel>

                <!-- Trading License -->
                <StackPanel Spacing="8" Width="180">
                  <TextBlock Text="Trading License" HorizontalAlignment="Center" Foreground="#c0c4cf" FontSize="11" />
                  <Border Width="160" Height="120" BorderBrush="#444a55" BorderThickness="1" Background="#1a1c1e">
                    <Panel>
                      <Image Source="{Binding SelectedTradingLicense}" Stretch="Uniform" />
                      <TextBlock Text="No Document" IsVisible="{Binding SelectedTradingLicense, Converter={x:Static ObjectConverters.IsNull}}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#666" FontSize="11" />
                    </Panel>
                  </Border>
                  <Button Width="160" Height="28" Content="Scan License" HorizontalAlignment="Center" Command="{Binding UploadTradingLicenseCommand}" Background="#30333A" Foreground="White" BorderBrush="#444a55" BorderThickness="1" CornerRadius="3" FontSize="11" />
                </StackPanel>

                <!-- VAT Registration Certificate -->
                <StackPanel Spacing="8" Width="180">
                  <TextBlock Text="VAT Registration Cert" HorizontalAlignment="Center" Foreground="#c0c4cf" FontSize="11" />
                  <Border Width="160" Height="120" BorderBrush="#444a55" BorderThickness="1" Background="#1a1c1e">
                    <Panel>
                      <Image Source="{Binding SelectedVatDocument}" Stretch="Uniform" />
                      <TextBlock Text="No Document" IsVisible="{Binding SelectedVatDocument, Converter={x:Static ObjectConverters.IsNull}}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#666" FontSize="11" />
                    </Panel>
                  </Border>
                  <Button Width="160" Height="28" Content="Scan VAT" HorizontalAlignment="Center" Command="{Binding UploadVatDocumentCommand}" Background="#30333A" Foreground="White" BorderBrush="#444a55" BorderThickness="1" CornerRadius="3" FontSize="11" />
                </StackPanel>

                <!-- Tax Clearance Certificate -->
                <StackPanel Spacing="8" Width="180">
                  <TextBlock Text="Tax Clearance Cert" HorizontalAlignment="Center" Foreground="#c0c4cf" FontSize="11" />
                  <Border Width="160" Height="120" BorderBrush="#444a55" BorderThickness="1" Background="#1a1c1e">
                    <Panel>
                      <Image Source="{Binding SelectedTaxDocument}" Stretch="Uniform" />
                      <TextBlock Text="No Document" IsVisible="{Binding SelectedTaxDocument, Converter={x:Static ObjectConverters.IsNull}}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#666" FontSize="11" />
                    </Panel>
                  </Border>
                  <Button Width="160" Height="28" Content="Scan Tax" HorizontalAlignment="Center" Command="{Binding UploadTaxDocumentCommand}" Background="#30333A" Foreground="White" BorderBrush="#444a55" BorderThickness="1" CornerRadius="3" FontSize="11" />
                </StackPanel>

                <!-- B-BBEE Compliance Certificate -->
                <StackPanel Spacing="8" Width="180">
                  <TextBlock Text="B-BBEE Compliance Cert" HorizontalAlignment="Center" Foreground="#c0c4cf" FontSize="11" />
                  <Border Width="160" Height="120" BorderBrush="#444a55" BorderThickness="1" Background="#1a1c1e">
                    <Panel>
                      <Image Source="{Binding SelectedBbeeDocument}" Stretch="Uniform" />
                      <TextBlock Text="No Document" IsVisible="{Binding SelectedBbeeDocument, Converter={x:Static ObjectConverters.IsNull}}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#666" FontSize="11" />
                    </Panel>
                  </Border>
                  <Button Width="160" Height="28" Content="Scan B-BBEE" HorizontalAlignment="Center" Command="{Binding UploadBbeeDocumentCommand}" Background="#30333A" Foreground="White" BorderBrush="#444a55" BorderThickness="1" CornerRadius="3" FontSize="11" />
                </StackPanel>
              </StackPanel>
              
              <Button Content="Commit Site Documents" Command="{Binding CommitSiteDocumentsCommand}" HorizontalAlignment="Right" Width="200" Classes="primary" IsEnabled="{Binding IsSiteEditMode}" />
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
    </ScrollViewer>
  </Grid>
</UserControl>