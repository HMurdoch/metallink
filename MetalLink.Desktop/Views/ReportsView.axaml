<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="MetalLink.Desktop.Views.ReportsView">
  
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="20" Spacing="20">
      
      <!-- Header -->
      <TextBlock Text="Reports" 
                 FontSize="28" 
                 FontWeight="Bold" 
                 Margin="0,0,0,10"/>
      
      <!-- Stock Reports Section -->
      <Border Background="#F5F5F5" 
              CornerRadius="8" 
              Padding="20">
        <StackPanel Spacing="15">
          
          <TextBlock Text="Stock Reports" 
                     FontSize="20" 
                     FontWeight="SemiBold"
                     Foreground="#2196F3"/>
          
          <!-- Stock on Hand Report -->
          <Border Background="White" 
                  CornerRadius="4" 
                  Padding="15"
                  BoxShadow="0 2 4 0 #10000000">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Spacing="5">
                <TextBlock Text="Stock on Hand Summary" 
                           FontSize="16" 
                           FontWeight="SemiBold"/>
                <TextBlock Text="View current inventory levels by product and site" 
                           FontSize="12" 
                           Foreground="#666666"/>
              </StackPanel>
              <StackPanel Grid.Column="1" 
                          Orientation="Horizontal" 
                          Spacing="10"
                          VerticalAlignment="Center">
                <Button Content="View Report" 
                        Classes="primary"
                        Width="120"
                        Command="{Binding ViewStockOnHandCommand}"/>
                <Button Content="Export PDF" 
                        Classes="accent"
                        Width="120"
                        Command="{Binding ExportStockOnHandPdfCommand}"/>
              </StackPanel>
            </Grid>
          </Border>
          
          <!-- Stock Movement Report -->
          <Border Background="White" 
                  CornerRadius="4" 
                  Padding="15"
                  BoxShadow="0 2 4 0 #10000000">
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="5">
                  <TextBlock Text="Stock Movement Report" 
                             FontSize="16" 
                             FontWeight="SemiBold"/>
                  <TextBlock Text="View all stock IN/OUT transactions with filters" 
                             FontSize="12" 
                             Foreground="#666666"/>
                </StackPanel>
                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            Spacing="10"
                            VerticalAlignment="Center">
                  <Button Content="View Report" 
                          Classes="primary"
                          Width="120"
                          Command="{Binding ViewStockMovementCommand}"/>
                  <Button Content="Export PDF" 
                          Classes="accent"
                          Width="120"
                          Command="{Binding ExportStockMovementPdfCommand}"/>
                </StackPanel>
              </Grid>
              
              <!-- Filters -->
              <Border Background="#F9F9F9" 
                      CornerRadius="4" 
                      Padding="10"
                      Margin="0,10,0,0">
                <Grid ColumnDefinitions="Auto,200,Auto,200,Auto,*" 
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="10"
                      RowSpacing="10">
                  
                  <!-- Date Range -->
                  <TextBlock Grid.Column="0" Grid.Row="0" 
                             Text="From Date:" 
                             VerticalAlignment="Center"/>
                  <DatePicker Grid.Column="1" Grid.Row="0" 
                              SelectedDate="{Binding StockMovementFromDate}"/>
                  
                  <TextBlock Grid.Column="2" Grid.Row="0" 
                             Text="To Date:" 
                             VerticalAlignment="Center"/>
                  <DatePicker Grid.Column="3" Grid.Row="0" 
                              SelectedDate="{Binding StockMovementToDate}"/>
                  
                  <!-- Product Filter -->
                  <TextBlock Grid.Column="0" Grid.Row="1" 
                             Text="Product:" 
                             VerticalAlignment="Center"/>
                  <ComboBox Grid.Column="1" Grid.Row="1" 
                            ItemsSource="{Binding Products}"
                            SelectedItem="{Binding SelectedProduct}"
                            PlaceholderText="All Products">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding ProductName}"/>
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  
                  <TextBlock Grid.Column="2" Grid.Row="1" 
                             Text="Site:" 
                             VerticalAlignment="Center"/>
                  <ComboBox Grid.Column="3" Grid.Row="1" 
                            ItemsSource="{Binding Sites}"
                            SelectedItem="{Binding SelectedSite}"
                            PlaceholderText="All Sites">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding SiteName}"/>
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  
                </Grid>
              </Border>
            </StackPanel>
          </Border>
          
        </StackPanel>
      </Border>
      
      <!-- Ticket Reports Section -->
      <Border Background="#F5F5F5" 
              CornerRadius="8" 
              Padding="20">
        <StackPanel Spacing="15">
          
          <TextBlock Text="Ticket Reports" 
                     FontSize="20" 
                     FontWeight="SemiBold"
                     Foreground="#4CAF50"/>
          
          <!-- Ticket Report (Existing) -->
          <Border Background="White" 
                  CornerRadius="4" 
                  Padding="15"
                  BoxShadow="0 2 4 0 #10000000">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Spacing="5">
                <TextBlock Text="Ticket Report" 
                           FontSize="16" 
                           FontWeight="SemiBold"/>
                <TextBlock Text="Generate detailed ticket report with PDF export" 
                           FontSize="12" 
                           Foreground="#666666"/>
              </StackPanel>
              <Button Grid.Column="1" 
                      Content="Generate Report" 
                      Classes="primary"
                      Width="150"
                      VerticalAlignment="Center"
                      Command="{Binding GenerateTicketReportCommand}"/>
            </Grid>
          </Border>
          
        </StackPanel>
      </Border>
      
      <!-- Admin Actions -->
      <Border Background="#FFF3E0" 
              CornerRadius="8" 
              Padding="20">
        <StackPanel Spacing="15">
          
          <TextBlock Text="Administrative Actions" 
                     FontSize="20" 
                     FontWeight="SemiBold"
                     Foreground="#FF9800"/>
          
          <Border Background="White" 
                  CornerRadius="4" 
                  Padding="15"
                  BoxShadow="0 2 4 0 #10000000">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Spacing="5">
                <TextBlock Text="Recalculate Stock on Hand" 
                           FontSize="16" 
                           FontWeight="SemiBold"/>
                <TextBlock Text="Rebuild stock levels from all movements (use if data appears incorrect)" 
                           FontSize="12" 
                           Foreground="#666666"/>
              </StackPanel>
              <Button Grid.Column="1" 
                      Content="Recalculate Stock" 
                      Classes="warning"
                      Width="150"
                      VerticalAlignment="Center"
                      Command="{Binding RecalculateStockCommand}"/>
            </Grid>
          </Border>
          
        </StackPanel>
      </Border>
      
      <!-- Help Text -->
      <Border Background="#E3F2FD" 
              CornerRadius="4" 
              Padding="15">
        <StackPanel Spacing="5">
          <TextBlock Text="ℹ️ Report Tips:" 
                     FontWeight="SemiBold"
                     Foreground="#1976D2"/>
          <TextBlock TextWrapping="Wrap" 
                     Foreground="#333333">
            • Stock on Hand: Shows current inventory across all products and sites
          </TextBlock>
          <TextBlock TextWrapping="Wrap" 
                     Foreground="#333333">
            • Stock Movement: Filter by date range, product, or site to see all IN/OUT transactions
          </TextBlock>
          <TextBlock TextWrapping="Wrap" 
                     Foreground="#333333">
            • PDF Export: All reports can be exported and printed directly from the browser
          </TextBlock>
          <TextBlock TextWrapping="Wrap" 
                     Foreground="#333333">
            • Recalculate: Only use if stock numbers seem incorrect - rebuilds from all movements
          </TextBlock>
        </StackPanel>
      </Border>
      
    </StackPanel>
  </ScrollViewer>
  
</UserControl>
