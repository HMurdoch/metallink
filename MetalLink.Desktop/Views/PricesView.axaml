<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MetalLink.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="MetalLink.Desktop.Views.PricesView">
    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource Brush.PanelBackground}" Padding="16,8">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <PathIcon Data="{StaticResource Sell}" Width="24" Height="24" Foreground="{DynamicResource Brush.Accent}" />
                <TextBlock Text="Prices" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="16">
            <TextBlock Text="Prices implementation coming soon..." 
                       HorizontalAlignment="Center" VerticalAlignment="Center" 
                       FontSize="16" Opacity="0.7" />
        </ScrollViewer>
    </Grid>
</UserControl>
