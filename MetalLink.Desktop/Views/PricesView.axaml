<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MetalLink.Desktop.ViewModels"
             xmlns:local="clr-namespace:MetalLink.Desktop.Views"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="900"
             x:Class="MetalLink.Desktop.Views.PricesView"
             Name="PricesViewControl">

  <UserControl.Styles>
    <Style Selector="TextBox">
      <Setter Property="BorderBrush" Value="#444a55" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="SelectionBrush" Value="#3b82f6" />
      <Setter Property="SelectionForegroundBrush" Value="White" />
    </Style>
    <Style Selector="TextBox:focus">
      <Setter Property="BorderBrush" Value="#5c7cfa" />
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="BorderBrush" Value="#444a55" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="ComboBox:focus">
      <Setter Property="BorderBrush" Value="#5c7cfa" />
    </Style>
    <Style Selector="DataGrid">
      <Setter Property="Background" Value="{DynamicResource Brush.PanelBackground}" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
      <Setter Property="GridLinesVisibility" Value="Horizontal" />
      <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="DataGridCell">
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="DataGridColumnHeader">
      <Setter Property="Background" Value="{DynamicResource Brush.NavBackground}" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="SeparatorBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="Padding" Value="12,4" />
    </Style>
    <Style Selector="DataGridRow">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="DataGridRow:pointerover">
      <Setter Property="Background" Value="#20FFFFFF" />
    </Style>
    <Style Selector="DataGridRow:selected">
      <Setter Property="Background" Value="#303B82F6" />
    </Style>
    <!-- Price cell highlight when editable -->
    <Style Selector="DataGridCell.price-cell">
      <Setter Property="Background" Value="#10FFFFFF" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*">
    <!-- Sticky Header -->
    <Border Grid.Row="0"
            Background="{DynamicResource Brush.PanelBackground}"
            Padding="12,8"
            CornerRadius="4"
            Margin="16,16,16,8"
            ZIndex="100">
      <Image Source="avares://MetalLink.Desktop/Assets/prices_heading.png"
             Height="40"
             HorizontalAlignment="Left"
             Stretch="Uniform" />
    </Border>

    <ScrollViewer Grid.Row="1" Padding="16,8,16,16">
      <StackPanel Spacing="16" Margin="0,0,0,100">

        <!-- ===== Section 1: Price List Selection ===== -->
        <Border Background="{DynamicResource Brush.PanelBackground}" Padding="12" CornerRadius="4">
          <StackPanel Spacing="8">
            <Grid Background="Transparent" PointerPressed="TogglePriceListSelection" ColumnDefinitions="Auto,*">
              <TextBlock Grid.Column="0"
                         Text="{Binding PricesIsPriceListSelectionExpanded, Converter={StaticResource SectionToViewConverter}, ConverterParameter='arrow'}"
                         Foreground="{DynamicResource Brush.TextPrimary}" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="Price List Selection" Foreground="{DynamicResource Brush.TextPrimary}" FontWeight="Bold" />
            </Grid>

            <StackPanel Spacing="12" IsVisible="{Binding PricesIsPriceListSelectionExpanded}" Margin="0,8,0,0">

              <!-- Entity Type -->
              <StackPanel Spacing="4" Width="200" HorizontalAlignment="Left">
                <TextBlock Text="Entity Type" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" />
                <ComboBox SelectedItem="{Binding PricesEntityType}">
                  <x:String>Customer</x:String>
                  <x:String>Buyer</x:String>
                </ComboBox>
              </StackPanel>

              <!-- 4 Price List dropdowns -->
              <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
                <!-- Slot 1 -->
                <StackPanel Grid.Column="0" Spacing="4">
                  <TextBlock Text="Price List 1" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" />
                  <ComboBox ItemsSource="{Binding PricesAvailableList1}"
                            SelectedItem="{Binding SelectedPricesList1}"
                            PlaceholderText="Select price list...">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding ProductPriceListName}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <Button Content="✕ Clear"
                          Command="{Binding ClearPricesList1Command}"
                          IsVisible="{Binding IsPriceColumn1Visible}"
                          FontSize="10" Padding="6,2"
                          HorizontalAlignment="Left" />
                </StackPanel>

                <!-- Slot 2 -->
                <StackPanel Grid.Column="1" Spacing="4">
                  <TextBlock Text="Price List 2" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" />
                  <ComboBox ItemsSource="{Binding PricesAvailableList2}"
                            SelectedItem="{Binding SelectedPricesList2}"
                            PlaceholderText="Select price list...">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding ProductPriceListName}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <Button Content="✕ Clear"
                          Command="{Binding ClearPricesList2Command}"
                          IsVisible="{Binding IsPriceColumn2Visible}"
                          FontSize="10" Padding="6,2"
                          HorizontalAlignment="Left" />
                </StackPanel>

                <!-- Slot 3 -->
                <StackPanel Grid.Column="2" Spacing="4">
                  <TextBlock Text="Price List 3" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" />
                  <ComboBox ItemsSource="{Binding PricesAvailableList3}"
                            SelectedItem="{Binding SelectedPricesList3}"
                            PlaceholderText="Select price list...">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding ProductPriceListName}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <Button Content="✕ Clear"
                          Command="{Binding ClearPricesList3Command}"
                          IsVisible="{Binding IsPriceColumn3Visible}"
                          FontSize="10" Padding="6,2"
                          HorizontalAlignment="Left" />
                </StackPanel>

                <!-- Slot 4 -->
                <StackPanel Grid.Column="3" Spacing="4">
                  <TextBlock Text="Price List 4" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" />
                  <ComboBox ItemsSource="{Binding PricesAvailableList4}"
                            SelectedItem="{Binding SelectedPricesList4}"
                            PlaceholderText="Select price list...">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding ProductPriceListName}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <Button Content="✕ Clear"
                          Command="{Binding ClearPricesList4Command}"
                          IsVisible="{Binding IsPriceColumn4Visible}"
                          FontSize="10" Padding="6,2"
                          HorizontalAlignment="Left" />
                </StackPanel>
              </Grid>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ===== Section 2: Product Filters ===== -->
        <Border Background="{DynamicResource Brush.PanelBackground}" Padding="12" CornerRadius="4">
          <StackPanel Spacing="8">
            <Grid Background="Transparent" PointerPressed="ToggleFilters" ColumnDefinitions="Auto,*">
              <TextBlock Grid.Column="0"
                         Text="{Binding PricesIsFilterExpanded, Converter={StaticResource SectionToViewConverter}, ConverterParameter='arrow'}"
                         Foreground="{DynamicResource Brush.TextPrimary}" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="Product Filters" Foreground="{DynamicResource Brush.TextPrimary}" FontWeight="Bold" />
            </Grid>

            <StackPanel Spacing="12" IsVisible="{Binding PricesIsFilterExpanded}" Margin="0,8,0,0">
              <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Product Group" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" />
                    <ComboBox Width="200"
                              ItemsSource="{Binding PricesProductGroups}"
                              SelectedItem="{Binding SelectedPricesProductGroup}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding ProductGroupName}" />
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                  </StackPanel>

                  <StackPanel Spacing="4">
                    <TextBlock Text="Search" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" />
                    <TextBox Width="260" Watermark="Search name or code..." Text="{Binding PricesSearchTerm}" />
                  </StackPanel>

                  <StackPanel Spacing="4">
                    <TextBlock Text="First Letter" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" />
                    <ComboBox Width="80"
                              ItemsSource="{Binding PricesLetterFilters}"
                              SelectedItem="{Binding SelectedPricesLetter}" />
                  </StackPanel>
                </StackPanel>

                <Button Grid.Column="1" Content="Reset" VerticalAlignment="Bottom"
                        Command="{Binding ResetPricesFiltersCommand}" Width="80"
                        HorizontalContentAlignment="Center" />
              </Grid>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ===== Section 3: Product Prices DataGrid ===== -->
        <Border Background="{DynamicResource Brush.PanelBackground}" Padding="12" CornerRadius="4">
          <StackPanel Spacing="8">
            <Grid Background="Transparent" PointerPressed="ToggleResults" ColumnDefinitions="Auto,*,Auto">
              <TextBlock Grid.Column="0"
                         Text="{Binding PricesIsResultsExpanded, Converter={StaticResource SectionToViewConverter}, ConverterParameter='arrow'}"
                         Foreground="{DynamicResource Brush.TextPrimary}" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="Product Prices" Foreground="{DynamicResource Brush.TextPrimary}" FontWeight="Bold" />
              <TextBlock Grid.Column="2"
                         Text="(double-click a price cell to edit)"
                         FontSize="10" Foreground="{DynamicResource Brush.TextMuted}"
                         VerticalAlignment="Center" />
            </Grid>

            <StackPanel IsVisible="{Binding PricesIsResultsExpanded}" Margin="0,8,0,0">
              <DataGrid Name="PricesDataGrid"
                        ItemsSource="{Binding PricesResults}"
                        IsReadOnly="False"
                        AutoGenerateColumns="False"
                        CanUserResizeColumns="True"
                        CanUserSortColumns="True"
                        SelectionMode="Single"
                        MinHeight="400">
                <DataGrid.Columns>
                  <!-- Always-visible: HTS Code -->
                  <DataGridTextColumn Header="HTS Code"
                                      Binding="{Binding HtsCode}"
                                      IsReadOnly="True"
                                      Width="140" />
                  <!-- Always-visible: Group -->
                  <DataGridTextColumn Header="Group"
                                      Binding="{Binding GroupName}"
                                      IsReadOnly="True"
                                      Width="180" />
                  <!-- Always-visible: ISRI Name / Alias -->
                  <DataGridTextColumn Header="ISRI Name / Alias"
                                      Binding="{Binding DisplayName}"
                                      IsReadOnly="True"
                                      Width="500" />
                  <!-- Always-visible: ISRI Code -->
                  <DataGridTextColumn Header="ISRI Code"
                                      Binding="{Binding IsriCode}"
                                      IsReadOnly="True"
                                      Width="140" />
                  <!-- Price columns (visibility set from code-behind) -->
                  <!-- DataGridTemplateColumn: display uses F2 format; editing template has no StringFormat so typing 23.11 stays 23.11 -->
                  <DataGridTemplateColumn Header="Price List 1" IsVisible="False" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Price1, StringFormat={}{0:F2}}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0" />
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                      <DataTemplate>
                        <!-- OneWay: provides initial value but never writes back on keystroke.
                             The code-behind saves the final value exactly once in CellEditEnded. -->
                        <TextBox Text="{Binding Price1, Mode=OneWay, StringFormat={}{0:F2}}" TextAlignment="Right" />
                      </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTemplateColumn Header="Price List 2" IsVisible="False" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Price2, StringFormat={}{0:F2}}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0" />
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                      <DataTemplate>
                        <TextBox Text="{Binding Price2, Mode=OneWay, StringFormat={}{0:F2}}" TextAlignment="Right" />
                      </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTemplateColumn Header="Price List 3" IsVisible="False" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Price3, StringFormat={}{0:F2}}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0" />
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                      <DataTemplate>
                        <TextBox Text="{Binding Price3, Mode=OneWay, StringFormat={}{0:F2}}" TextAlignment="Right" />
                      </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTemplateColumn Header="Price List 4" IsVisible="False" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Price4, StringFormat={}{0:F2}}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0" />
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                      <DataTemplate>
                        <TextBox Text="{Binding Price4, Mode=OneWay, StringFormat={}{0:F2}}" TextAlignment="Right" />
                      </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                  </DataGridTemplateColumn>
                </DataGrid.Columns>
              </DataGrid>

              <!-- Pagination -->
              <Border BorderThickness="0,1,0,0" BorderBrush="{DynamicResource Brush.BorderSubtle}" Padding="0,8,0,0">
                <local:PaginationControl DataContext="{Binding PricesPagination}" HorizontalAlignment="Center" />
              </Border>
            </StackPanel>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
