<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MetalLink.Desktop.Views.StockLevelsView">

  <Border Padding="24" Background="{StaticResource Brush.MainBackground}">
    <StackPanel Spacing="8">
      <TextBlock Text="Stock Levels" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Brush.TextPrimary}" />
      <TextBlock Text="Placeholder screen (to be implemented)." Foreground="{StaticResource Brush.TextMuted}" />
    </StackPanel>
  </Border>

</UserControl>
