<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MetalLink.Desktop.ViewModels"
        xmlns:views="using:MetalLink.Desktop.Views"
        xmlns:converters="using:MetalLink.Desktop.Views"
        x:Class="MetalLink.Desktop.Views.MainWindow"
        Width="1500"
        Height="800"
        MinWidth="1150"
        MinHeight="700"
        Title="Metal Link Desktop"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brush.AppBackground}">

  <Window.Resources>
    <converters:SectionToViewConverter x:Key="SectionToViewConverter"/>
  </Window.Resources>

  <!-- Nav button styling with subtle blue selection stripe -->
  <Window.Styles>

    <!-- Base nav button -->
    <Style Selector="Button.NavButton">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="12,10" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
      <Setter Property="FontSize" Value="14" />

      <Setter Property="Transitions">
        <Setter.Value>
          <Transitions>
            <BrushTransition Property="Background" Duration="0:0:0.12" />
          </Transitions>
        </Setter.Value>
      </Setter>

      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Grid>
              <Border x:Name="Stripe"
                      Width="3"
                      HorizontalAlignment="Left"
                      Background="{StaticResource Brush.AccentGradient}"
                      Opacity="0" />

              <Border Margin="6,0,0,0"
                      Background="{TemplateBinding Background}"
                      CornerRadius="4">
                <ContentPresenter Content="{TemplateBinding Content}"
                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                  Margin="{TemplateBinding Padding}"
                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  VerticalAlignment="Center" />
              </Border>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Sub-nav item under Customers -->
    <Style Selector="Button.SubNavButton">
      <Setter Property="Padding" Value="28,8" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}" />
    </Style>

    <!-- Hover / pressed / focus backgrounds -->
    <Style Selector="Button.NavButton:pointerover">
      <!-- Remove default gray flash by taking full control of hover visual -->
      <Setter Property="Background" Value="#262B35" />
      <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
      <!-- Disable extra background transitions on hover -->
      <Setter Property="Transitions">
        <Setter.Value>
          <Transitions />
        </Setter.Value>
      </Setter>
    </Style>

    <Style Selector="Button.NavButton:pressed">
      <Setter Property="Background" Value="#2E3440" />
    </Style>

    <Style Selector="Button.NavButton:focus">
      <Setter Property="Background" Value="#262B35" />
    </Style>

    <!-- Show blue stripe when hovered / pressed / focused -->
    <Style Selector="Button.NavButton:pointerover /template/ Border#Stripe">
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Button.NavButton:pressed /template/ Border#Stripe">
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Button.NavButton:focus /template/ Border#Stripe">
      <Setter Property="Opacity" Value="1" />
    </Style>

  </Window.Styles>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="260"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Left navigation -->
    <Border Grid.Column="0" Grid.RowSpan="2" Background="{StaticResource Brush.NavBackground}">
      <DockPanel>

        <!-- Top header -->
        <StackPanel DockPanel.Dock="Top" Margin="12,12,12,8" Spacing="3">
          <TextBlock Text="Metal Link Desktop" FontSize="16" FontWeight="Bold" Foreground="White"/>
          <TextBlock Text="{Binding LoggedInUserDisplay}" FontSize="12" Foreground="#b7bcc9"/>
        </StackPanel>

        <!-- Navigation items -->
        <StackPanel Margin="16,12,12,12" Spacing="8">
          <Button Content="Dashboard" Command="{Binding ShowDashboardCommand}" Classes="NavButton"/>

          <Button Content="Entities" Classes="NavButton"/>
          <Button Content="Customers"
                  Command="{Binding ShowCustomersCommand}"
                  Classes="NavButton SubNavButton"/>
          <Button Content="Companies &amp; Sites"
                  Command="{Binding ShowCompanyAndSitesCommand}"
                  Classes="NavButton SubNavButton"/>
          <Button Content="Products &amp; Prices"
                  Command="{Binding ShowProductsAndPricesCommand}"
                  Classes="NavButton SubNavButton" />                  

          <Button Content="Tickets" Command="{Binding ShowTicketsCommand}" Classes="NavButton"/>
          <Button Content="Documents" Command="{Binding ShowDocumentsCommand}" Classes="NavButton"/>
          <Button Content="Camera" Command="{Binding ShowCameraCommand}" Classes="NavButton"/>
          <Button Content="Reports" Command="{Binding ShowReportsCommand}" Classes="NavButton"/>
          <Button Content="Settings" Command="{Binding ShowSettingsCommand}" Classes="NavButton"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Margin="12,8,12,12" Spacing="8">
          <!-- Footer actions if needed -->
        </StackPanel>

      </DockPanel>
    </Border>

    <!-- Main content -->
    <Grid Grid.Column="1" Grid.Row="0" Background="{StaticResource Brush.MainBackground}">
      <TransitioningContentControl Content="{Binding CurrentSection, Converter={StaticResource SectionToViewConverter}}">
        <TransitioningContentControl.PageTransition>
          <CrossFade Duration="0:0:0.18" />
        </TransitioningContentControl.PageTransition>
      </TransitioningContentControl>
    </Grid>

    <!-- Bottom status bar -->
    <Border Grid.Row="1" Grid.ColumnSpan="2" Background="{StaticResource Brush.StatusBackground}" Padding="8,4">
      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="16">
        <!-- Main status message -->
        <TextBlock Grid.Column="0"
                   Text="{Binding StatusMessage}"
                   Foreground="#c0c4cf"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" />

        <!-- Customers loaded this session -->
        <TextBlock Grid.Column="1"
                   Text="{Binding CustomersLoadedCount, StringFormat='Customers loaded: {0}'}"
                   Foreground="#9fa4b2"
                   VerticalAlignment="Center" />

        <!-- Tickets created this session -->
        <TextBlock Grid.Column="2"
                   Text="{Binding TicketsCreatedCount, StringFormat='Tickets created: {0}'}"
                   Foreground="#9fa4b2"
                   VerticalAlignment="Center" />
      </Grid>
    </Border>
  </Grid>
</Window>
