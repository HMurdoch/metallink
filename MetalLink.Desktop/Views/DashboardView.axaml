<UserControl
    x:Class="MetalLink.Desktop.Views.DashboardView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Avalonia;assembly=LiveChartsCore.SkiaSharpView.Avalonia">

  <!-- Keep brushed aluminium visible behind; section blocks use Brush.PanelBackground -->
  <Border Background="{DynamicResource Brush.MainBackground}">
    <DockPanel>
      <!-- Sticky Header Panel -->
      <Border DockPanel.Dock="Top" 
              Background="{DynamicResource Brush.PanelBackground}"
              Padding="12,8"
              CornerRadius="4"
              Margin="16,16,16,8">
        <Image Source="avares://MetalLink.Desktop/Assets/dashboard_heading.png"
               Height="40"
               HorizontalAlignment="Left"
               Stretch="Uniform" />
      </Border>
      
      <!-- Scrollable Content -->
      <ScrollViewer Padding="16,8,16,16">
        <StackPanel Spacing="12">

        <TextBlock
            Text="Quick overview"
            Foreground="#9fa4b2"
            FontSize="13" />

        <!-- Two-column stats layout -->
        <Grid ColumnDefinitions="*,*"
              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
              ColumnSpacing="12"
              RowSpacing="12">

          <!-- Row 0: Logged in as (full width) -->
          <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                  Background="{DynamicResource Brush.GlassPanel}" BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Padding="10" CornerRadius="4">
      <StackPanel Spacing="4">
              <TextBlock Text="Logged in as:" Foreground="#9fa4b2" FontSize="12" />
              <TextBlock Text="{Binding LoggedInUser}" Foreground="#f5f5f5" />
            </StackPanel>
          </Border>

          <!-- Row 1: Total customers & total tickets in DB -->
          <Border Grid.Row="1" Grid.Column="0"
                  Background="{DynamicResource Brush.GlassPanel}" BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Padding="10" CornerRadius="4">
            <StackPanel>
              <TextBlock Text="Total customers in system:"
                         Foreground="#9fa4b2" FontSize="12" />
              <TextBlock Text="{Binding AnimatedTotalCustomersInDb}"
                         Foreground="#f5f5f5"
                         FontSize="18"
                         FontWeight="Bold" />
            </StackPanel>
          </Border>

          <Border Grid.Row="1" Grid.Column="1"
                  Background="{DynamicResource Brush.GlassPanel}" BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Padding="10" CornerRadius="4">
            <StackPanel>
              <TextBlock Text="Total tickets in system:"
                         Foreground="#9fa4b2" FontSize="12" />
              <TextBlock Text="{Binding AnimatedTotalTicketsInDb}"
                         Foreground="#f5f5f5"
                         FontSize="18"
                         FontWeight="Bold" />
            </StackPanel>
          </Border>

          <Border Grid.Row="2" Grid.Column="0"
                  Background="{DynamicResource Brush.GlassPanel}" BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Padding="10" CornerRadius="4">
            <StackPanel>
              <TextBlock Text="Total companies in system:"
                         Foreground="#9fa4b2" FontSize="12" />
              <TextBlock Text="{Binding AnimatedTotalCompaniesInDb}"
                         Foreground="#f5f5f5"
                         FontSize="18"
                         FontWeight="Bold" />
            </StackPanel>
          </Border>

          <Border Grid.Row="2" Grid.Column="1"
                  Background="{DynamicResource Brush.GlassPanel}" BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Padding="10" CornerRadius="4">
            <StackPanel>
              <TextBlock Text="Total products in system:"
                         Foreground="#9fa4b2" FontSize="12" />
              <TextBlock Text="{Binding AnimatedTotalProductsInDb}"
                         Foreground="#f5f5f5"
                         FontSize="18"
                         FontWeight="Bold" />
            </StackPanel>
          </Border>

          <Border Grid.Row="3" Grid.Column="0"
                  Background="{DynamicResource Brush.GlassPanel}" BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Padding="10" CornerRadius="4">
            <StackPanel>
              <TextBlock Text="Total sites in system:"
                         Foreground="#9fa4b2" FontSize="12" />
              <TextBlock Text="{Binding AnimatedTotalSitesInDb}"
                         Foreground="#f5f5f5"
                         FontSize="18"
                         FontWeight="Bold" />
            </StackPanel>
          </Border>

          <!-- Row 3: Last customer / last ticket -->
          <Border Grid.Row="4" Grid.Column="0"
                  Background="{DynamicResource Brush.GlassPanel}" BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Padding="10" CornerRadius="4">
      <StackPanel Spacing="4">
              <TextBlock Text="Last customer loaded:" Foreground="#9fa4b2" FontSize="12" />
              <TextBlock Text="{Binding FoundCustomerSummary}"
                         Foreground="#f5f5f5"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <Border Grid.Row="4" Grid.Column="1"
                  Background="{DynamicResource Brush.GlassPanel}" BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Padding="10" CornerRadius="4">
      <StackPanel Spacing="4">
              <TextBlock Text="Last ticket created:" Foreground="#9fa4b2" FontSize="12" />
              <TextBlock Text="{Binding LastCreatedTicketSummary}"
                         Foreground="#f5f5f5"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <!-- Row 4: Session counters -->
          <Border Grid.Row="5" Grid.Column="0"
                  Background="{DynamicResource Brush.GlassPanel}" BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Padding="10" CornerRadius="4">
            <StackPanel>
              <TextBlock Text="Customers loaded this session:"
                         Foreground="#9fa4b2"
                         FontSize="12" />
              <TextBlock Text="{Binding CustomersLoadedCount}"
                         Foreground="#f5f5f5"
                         FontSize="18"
                         FontWeight="Bold" />
            </StackPanel>
          </Border>

          <Border Grid.Row="5" Grid.Column="1"
                  Background="{DynamicResource Brush.GlassPanel}" BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Padding="10" CornerRadius="4">
            <StackPanel>
              <TextBlock Text="Tickets created this session:"
                         Foreground="#9fa4b2"
                         FontSize="12" />
              <TextBlock Text="{Binding TicketsCreatedCount}"
                         Foreground="#f5f5f5"
                         FontSize="18"
                         FontWeight="Bold" />
            </StackPanel>
          </Border>

          <!-- Row 5: Documents summary (full width) -->
          <Border Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                  Background="{DynamicResource Brush.GlassPanel}" BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Padding="10" CornerRadius="4">
      <StackPanel Spacing="6">
              <TextBlock Text="Documents summary:" Foreground="#9fa4b2" FontSize="12" />
              <TextBox Text="{Binding DocumentsSummary}"
                       IsReadOnly="True"
                       AcceptsReturn="True"
                       Height="120"
                       TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </Grid>

        <!-- Visual overview title -->
        <TextBlock Text="Visual overview"
                   Margin="0,16,0,4"
                   Foreground="#9fa4b2"
                   FontSize="13" />

        <!-- Tickets by type (pie) -->
        <Border Background="{DynamicResource Brush.PanelBackground}" Padding="10" CornerRadius="8">
    <StackPanel Spacing="8">
            <TextBlock Text="Tickets by type"
                       Foreground="#f5f5f5"
                       FontSize="14"
                       FontWeight="Bold" />
            <lvc:PieChart Series="{Binding TicketsByTypeSeries}"
                          LegendPosition="Right"
                          Height="220" />
          </StackPanel>
        </Border>

        <!-- Tickets per day (line chart) -->
        <Border Background="{DynamicResource Brush.PanelBackground}" Padding="10" CornerRadius="8" Margin="0,8,0,0">
    <StackPanel Spacing="8">
            <TextBlock Text="Tickets per day (last 7 days)"
                       Foreground="#f5f5f5"
                       FontSize="14"
                       FontWeight="Bold" />
            <lvc:CartesianChart Series="{Binding TicketsPerDaySeries}"
                                XAxes="{Binding TicketsPerDayXAxis}"
                                Height="220" />
          </StackPanel>
        </Border>

        </StackPanel>
      </ScrollViewer>
    </DockPanel>
  </Border>
</UserControl>
