<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MetalLink.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="MetalLink.Desktop.Views.PriceListStockMovementsView"
             x:DataType="vm:PriceListStockMovementsViewModel">
  <Design.DataContext>
    <vm:PriceListStockMovementsViewModel />
  </Design.DataContext>

  <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">
    <!-- Header -->
    <TextBlock Grid.Row="0" Text="Price List Stock Movements" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" />

    <!-- Entity Type Selection -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
      <TextBlock Text="Entity Type:" VerticalAlignment="Center" Margin="0,0,10,0" />
      <ComboBox ItemsSource="{Binding EntityTypes}" SelectedItem="{Binding SelectedEntityType}" Width="150" />
    </StackPanel>

    <!-- Price List Selection -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
      <TextBlock Text="Price Lists:" VerticalAlignment="Center" Margin="0,0,10,0" />
      <ListBox ItemsSource="{Binding AvailablePriceLists}" SelectionMode="Multiple" Width="300" Height="100">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}" />
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
      <Button Content="Select All" Command="{Binding SelectAllPriceListsCommand}" Margin="10,0,0,0" />
      <Button Content="Clear All" Command="{Binding ClearAllPriceListsCommand}" Margin="10,0,0,0" />
    </StackPanel>

    <!-- Filters -->
    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,20">
      <TextBlock Text="From Date:" VerticalAlignment="Center" Margin="0,0,10,0" />
      <DatePicker SelectedDate="{Binding FromDate}" Width="120" />
      <TextBlock Text="To Date:" VerticalAlignment="Center" Margin="20,0,10,0" />
      <DatePicker SelectedDate="{Binding ToDate}" Width="120" />
      <TextBlock Text="Movement Type:" VerticalAlignment="Center" Margin="20,0,10,0" />
      <ComboBox ItemsSource="{Binding MovementTypes}" SelectedItem="{Binding SelectedMovementType}" Width="120" />
      <Button Content="Apply Filters" Command="{Binding ApplyFiltersCommand}" Margin="20,0,0,0" />
    </StackPanel>

    <!-- Data Grid -->
    <DataGrid Grid.Row="4" ItemsSource="{Binding StockMovements}" AutoGenerateColumns="False" IsReadOnly="True">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Date" Binding="{Binding MovementDate, StringFormat=d}" Width="100" />
        <DataGridTextColumn Header="Product Code" Binding="{Binding ProductCode}" Width="120" />
        <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*" />
        <DataGridTextColumn Header="Price List" Binding="{Binding PriceListName}" Width="150" />
        <DataGridTextColumn Header="Type" Binding="{Binding MovementType}" Width="80" />
        <DataGridTextColumn Header="Weight (kg)" Binding="{Binding WeightKg, StringFormat=N2}" Width="100" />
        <DataGridTextColumn Header="Ticket" Binding="{Binding TicketNumber}" Width="100" />
        <DataGridTextColumn Header="Line" Binding="{Binding LineNumber}" Width="50" />
        <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="200" />
      </DataGrid.Columns>
    </DataGrid>

    <!-- Pagination -->
    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
      <Button Content="Previous" Command="{Binding PreviousPageCommand}" IsEnabled="{Binding CanGoPrevious}" />
      <TextBlock Text="{Binding CurrentPageInfo}" VerticalAlignment="Center" Margin="20,0" />
      <Button Content="Next" Command="{Binding NextPageCommand}" IsEnabled="{Binding CanGoNext}" />
    </StackPanel>
  </Grid>
</UserControl>