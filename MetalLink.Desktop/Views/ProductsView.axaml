<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MetalLink.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="MetalLink.Desktop.Views.ProductsView">
    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource Brush.PanelBackground}" Padding="16,8">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <PathIcon Data="{StaticResource Inventory}" Width="24" Height="24" Foreground="{DynamicResource Brush.Accent}" />
                <TextBlock Text="Products" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" RowDefinitions="Auto,*,Auto">
            <!-- Filter Bar -->
            <Border Grid.Row="0" Background="{DynamicResource Brush.PanelBackground}" Padding="16,12" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource Brush.Border}">
                <Grid ColumnDefinitions="*,*,Auto" RowDefinitions="Auto,Auto">
                    <!-- Row 1: Filters -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Product Group" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" />
                            <ComboBox Width="200" 
                                      ItemsSource="{Binding ProductGroups}" 
                                      SelectedItem="{Binding SelectedProductGroup}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ProductGroupName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        
                        <StackPanel Spacing="4">
                            <TextBlock Text="Product Search" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" />
                            <TextBox Width="250" Watermark="Search name or code..." Text="{Binding ProductSearchTerm}" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="First Letter" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" />
                            <ComboBox ItemsSource="{Binding ProductLetterFilters}" 
                                      SelectedItem="{Binding SelectedProductLetter}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Row 2: Non-Starred Toggle -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0" VerticalAlignment="Center">
                        <ToggleSwitch IsChecked="{Binding ShowNonStarred}" OnContent="All Products" OffContent="Starred Only" />
                    </StackPanel>
                    
                    <Button Grid.Row="0" Grid.Column="2" Grid.RowSpan="2" Command="{Binding RefreshProductsCommand}" VerticalAlignment="Center">
                        <PathIcon Data="{StaticResource Refresh}" />
                    </Button>
                </Grid>
            </Border>

            <!-- Results Grid -->
            <DataGrid Grid.Row="1" ItemsSource="{Binding ProductResults}" SelectedItem="{Binding SelectedProduct}" 
                      IsReadOnly="True" AutoGenerateColumns="False" CanUserResizeColumns="True">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Starred" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ToggleSwitch IsChecked="{Binding StarredProduct}" 
                                              Command="{Binding $parent[UserControl].DataContext.ToggleStarredCommand}"
                                              CommandParameter="{Binding}"
                                              Margin="8,0" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="HTS" Binding="{Binding HtsCode}" Width="100" />
                    <DataGridTextColumn Header="ISRI Code" Binding="{Binding ProductCode}" Width="100" />
                    <DataGridTextColumn Header="ISRI Name" Binding="{Binding ProductName}" Width="*" />
                    <DataGridCheckBoxColumn Header="ISRI" Binding="{Binding IsriProduct}" Width="Auto" />
                    <DataGridTextColumn Header="Group" Binding="{Binding ProductGroupName}" Width="150" />
                    <DataGridTextColumn Header="Spec Flag" Binding="{Binding ProductSpecificationFlagId}" Width="100" />
                    <DataGridTextColumn Header="Alias" Binding="{Binding StarredProductAlias}" Width="150" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- Create/Edit Form -->
            <Border Grid.Row="2" Background="{DynamicResource Brush.PanelBackground}" Padding="16" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource Brush.Border}">
                <StackPanel Spacing="16">
                    <TextBlock Text="{Binding ProductSaveButtonText, StringFormat='\{0\} Product'}" FontSize="16" FontWeight="SemiBold" />
                    
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="24" RowSpacing="12">
                        <!-- Column 1 -->
                        <StackPanel Grid.Column="0" Grid.Row="0" Spacing="4">
                            <TextBlock Text="HTS Code" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" />
                            <TextBox Text="{Binding ProductHtsCode}" />
                        </StackPanel>

                        <StackPanel Grid.Column="0" Grid.Row="1" Orientation="Horizontal" Spacing="12">
                            <CheckBox IsChecked="{Binding ProductIsIsri}" Content="ISRI Product" />
                            <CheckBox IsChecked="{Binding ProductStarred}" Content="Starred" />
                            <CheckBox IsChecked="{Binding ProductMustDeclare}" Content="Must Declare" />
                        </StackPanel>

                        <StackPanel Grid.Column="0" Grid.Row="2" Spacing="4">
                            <TextBlock Text="Product Group" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" />
                            <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding ProductGroups}" 
                                      SelectedValue="{Binding ProductGroupId}" SelectedValueBinding="{Binding ProductGroupId}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ProductGroupName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="0" Grid.Row="3" Spacing="4">
                            <TextBlock Text="Starred Alias" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" />
                            <TextBox Text="{Binding ProductStarredAlias}" />
                        </StackPanel>

                        <!-- Column 2 -->
                        <StackPanel Grid.Column="1" Grid.Row="0" Spacing="4">
                            <TextBlock Text="ISRI Name" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" />
                            <TextBox Text="{Binding ProductIsriName}" IsEnabled="{Binding ProductIsIsri}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Grid.Row="1" Spacing="4">
                            <TextBlock Text="ISRI Code" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" />
                            <TextBox Text="{Binding ProductIsriCode}" IsEnabled="{Binding ProductIsIsri}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Grid.Row="2" Spacing="4">
                            <TextBlock Text="ISRI URL" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" />
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox Text="{Binding ProductIsriUrl}" IsEnabled="{Binding ProductIsIsri}" />
                                <Button Grid.Column="1" Command="{Binding OpenIsriUrlCommand}" Margin="4,0,0,0">
                                    <PathIcon Data="{StaticResource Refresh}" />
                                </Button>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Grid.Row="3" Spacing="4">
                            <TextBlock Text="Description" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" />
                            <TextBox Text="{Binding ProductIsriDescription}" Height="60" AcceptsReturn="True" IsEnabled="{Binding ProductIsIsri}" />
                        </StackPanel>

                        <!-- Actions -->
                        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                            <Button Content="Clear" Command="{Binding ClearProductFormCommand}" />
                            <Button Content="{Binding ProductSaveButtonText}" Classes="Accent" 
                                    Command="{Binding UpdateProductCommand}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
