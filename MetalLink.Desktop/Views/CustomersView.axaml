<UserControl
    x:Class="MetalLink.Desktop.Views.CustomersView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:MetalLink.Desktop.Views"
    mc:Ignorable="d">

  <!-- Templates for lookup DTOs -->
  <UserControl.Resources>
    <DataTemplate x:Key="CompanyLookupTemplate">
      <TextBlock Text="{Binding CompanyName}" />
    </DataTemplate>

    <DataTemplate x:Key="SiteLookupTemplate">
      <TextBlock Text="{Binding SiteName}" />
    </DataTemplate>
  </UserControl.Resources>

  <UserControl.Styles>
    <!-- Default textbox border -->
    <Style Selector="TextBox">
      <Setter Property="BorderBrush" Value="#444a55" />
      <Setter Property="BorderThickness" Value="1" />
      <!-- Match button text size -->
      <Setter Property="FontSize" Value="11" />
    </Style>

    <Style Selector="TextBox:focus">
      <Setter Property="BorderBrush" Value="#5c7cfa" />
    </Style>

    <!-- Make ComboBox look/size similar to TextBox -->
    <Style Selector="ComboBox">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="BorderBrush" Value="#444a55" />
      <Setter Property="BorderThickness" Value="1" />
      <!-- Match button text size -->
      <Setter Property="FontSize" Value="11" />
    </Style>

    <Style Selector="ComboBox:focus">
      <Setter Property="BorderBrush" Value="#5c7cfa" />
    </Style>

    <!-- DataGrid overall -->
    <Style Selector="DataGrid">
      <Setter Property="Background" Value="{DynamicResource Brush.PanelBackground}" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
      <Setter Property="GridLinesVisibility" Value="Horizontal" />
      <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- DataGrid cells: force same font size as row-action buttons -->
    <Style Selector="DataGridCell">
      <Setter Property="FontSize" Value="11" />
    </Style>

    <!-- Header row (slightly larger + bold) -->
    <Style Selector="DataGridColumnHeader">
      <Setter Property="Background" Value="{DynamicResource Brush.NavBackground}" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <!-- Rows: subtle hover + blue selection -->
    <Style Selector="DataGridRow">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Transitions">
        <Setter.Value>
          <Transitions>
            <BrushTransition Property="Background" Duration="0:0:0.12" />
          </Transitions>
        </Setter.Value>
      </Setter>
    </Style>

    <Style Selector="DataGridRow:pointerover">
      <Setter Property="Background" Value="#20FFFFFF" />
    </Style>

    <Style Selector="DataGridRow:selected">
      <Setter Property="Background" Value="#303B82F6" />
    </Style>

    <!-- Row action buttons in the results grid -->
    <Style Selector="Button.row-action">
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
      <Setter Property="Background" Value="#30333A" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="Padding" Value="6,2" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
      <Setter Property="RenderTransform">
        <Setter.Value>
          <ScaleTransform ScaleX="1" ScaleY="1" />
        </Setter.Value>
      </Setter>

      <Setter Property="Transitions">
        <Setter.Value>
          <Transitions>
            <BrushTransition Property="Background" Duration="0:0:0.10" />
            <BrushTransition Property="BorderBrush" Duration="0:0:0.10" />
          </Transitions>
        </Setter.Value>
      </Setter>
    </Style>

    <Style Selector="Button.row-action:pointerover">
      <Setter Property="Background" Value="#3A4150" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.AccentGradient}" />
    </Style>

    <Style Selector="Button.row-action:pressed">
      <Setter Property="RenderTransform">
        <Setter.Value>
          <ScaleTransform ScaleX="0.97" ScaleY="0.97" />
        </Setter.Value>
      </Setter>
    </Style>

    <Style Selector="Button.row-action:disabled">
      <Setter Property="Background" Value="#2A2D34" />
      <Setter Property="Foreground" Value="#80838C" />
      <Setter Property="BorderBrush" Value="#3A3D45" />
    </Style>
  </UserControl.Styles>

  <!-- Keep brushed aluminium visible behind; section blocks use Brush.PanelBackground -->
  <Border Background="{DynamicResource Brush.MainBackground}" Padding="16">
    <StackPanel Spacing="16">

        <!-- Header -->
        <Image Source="avares://MetalLink.Desktop/Assets/customers_heading.png"
               Height="40"
               HorizontalAlignment="Left"
               Margin="0,0,0,4"
               Stretch="Uniform" />

        <!-- BLOCK 1: SEARCH CRITERIA -->
        <Border Background="{DynamicResource Brush.PanelBackground}" Padding="12" CornerRadius="4">
          <StackPanel Spacing="8">
            <Grid PointerPressed="ToggleSearchCriteria" Cursor="Hand">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" x:Name="SearchCriteriaArrow" Text="▼" Foreground="{DynamicResource Brush.TextPrimary}" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="Search Existing Customer" Foreground="{DynamicResource Brush.TextPrimary}" FontWeight="Bold" />
            </Grid>

            <!-- 4-column search grid (250px each = 1000px total) -->
            <Grid x:Name="SearchCriteriaContent" Margin="0,8,0,0" Width="1000" HorizontalAlignment="Left">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="300" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <!-- Row 0: Customer ID / ID Number / First Name / Last Name -->
              <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2" Margin="0,0,8,0">
                <TextBlock Text="Customer ID" Foreground="#c0c4cf" />
                <TextBox Text="{Binding SearchCustomerIdText}" />
              </StackPanel>
              <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2" Margin="0,0,8,0">
                <TextBlock Text="ID Number" Foreground="#c0c4cf" />
                <TextBox Text="{Binding SearchIdNumberText}" />
              </StackPanel>
              <StackPanel Grid.Row="0" Grid.Column="2" Spacing="2" Margin="0,0,8,0">
                <TextBlock Text="First Name" Foreground="#c0c4cf" />
                <TextBox Text="{Binding SearchFirstNameText}" />
              </StackPanel>
              <StackPanel Grid.Row="0" Grid.Column="3" Spacing="2">
                <TextBlock Text="Last Name" Foreground="#c0c4cf" />
                <TextBox Text="{Binding SearchLastNameText}" />
              </StackPanel>

              <!-- Row 1: Company / Site / Account Number / Price Code -->
              <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2" Margin="0,0,8,0">
                <TextBlock Text="Company" Foreground="#c0c4cf" />
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>

                  <!-- Letter dropdown -->
                  <ComboBox
                      Grid.Column="0"
                      Width="70"
                      ItemsSource="{Binding CompanyLetterFilters}"
                      SelectedItem="{Binding SelectedCompanyLetter}"
                      HorizontalAlignment="Stretch" />

                  <!-- Companies for selected letter -->
                  <ComboBox
                      Grid.Column="1"
                      Margin="4,0,0,0"
                      ItemsSource="{Binding SearchCompanySuggestions}"
                      SelectedItem="{Binding SelectedSearchCompany}"
                      HorizontalContentAlignment="Stretch"
                      ItemTemplate="{StaticResource CompanyLookupTemplate}" />
                </Grid>
              </StackPanel>

              <!-- Site -->
              <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2" Margin="0,0,8,0">
                <TextBlock Text="Site" Foreground="#c0c4cf" />
                <ComboBox
                    ItemsSource="{Binding SearchSiteSuggestions}"
                    SelectedItem="{Binding SelectedSearchSite}"
                    IsEnabled="{Binding IsSearchSiteEnabled}"
                    HorizontalContentAlignment="Stretch"
                    ItemTemplate="{StaticResource SiteLookupTemplate}" />
              </StackPanel>

              <!-- Account Number -->
              <StackPanel Grid.Row="1" Grid.Column="2" Spacing="2" Margin="0,0,8,0">
                <TextBlock Text="Account Number" Foreground="#c0c4cf" />
                <TextBox Text="{Binding SearchAccountNumberText, Mode=TwoWay}" />
              </StackPanel>

              <!-- Price Code -->
              <StackPanel Grid.Row="1" Grid.Column="3" Spacing="2">
                <TextBlock Text="Price Code" Foreground="#c0c4cf" />
                <ComboBox
                  ItemsSource="{Binding PriceCodeOptions}"
                  SelectedItem="{Binding SearchPriceCode, Mode=TwoWay}"
                  HorizontalAlignment="Stretch">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Label}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>

              <!-- Row 2: Phone / Mobile / Email / (empty) -->
              <StackPanel Grid.Row="2" Grid.Column="0" Spacing="2" Margin="0,0,8,0">
                <TextBlock Text="Phone" Foreground="#c0c4cf" />
                <TextBox Text="{Binding SearchPhoneNumberText}" />
              </StackPanel>
              <StackPanel Grid.Row="2" Grid.Column="1" Spacing="2" Margin="0,0,8,0">
                <TextBlock Text="Mobile" Foreground="#c0c4cf" />
                <TextBox Text="{Binding SearchMobileNumberText}" />
              </StackPanel>
              <StackPanel Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Spacing="2">
                <TextBlock Text="Email" Foreground="#c0c4cf" />
                <TextBox Text="{Binding SearchEmailText}" />
              </StackPanel>

              <!-- Row 4: Search button -->
              <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
                <Button
                  HorizontalAlignment="Center"
                  Width="100"
                  Content="Clear"
                  Command="{Binding ClearCustomerSearchCommand}" />
                <Button
                  x:Name="SearchCustomersButton"
                  Classes="primary"
                  HorizontalAlignment="Center"
                  Width="100"
                  Content="Search"
                  Command="{Binding SearchCustomerCommand}" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <!-- BLOCKS 2 & 3: SEARCH RESULTS AND CUSTOMER DETAILS SIDE-BY-SIDE -->
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="500" />
          </Grid.ColumnDefinitions>

          <!-- BLOCK 2: SEARCH RESULTS (Left Column) -->
          <Border Grid.Column="0" Background="{DynamicResource Brush.PanelBackground}" Padding="12" CornerRadius="4" Margin="0,0,8,0">
            <StackPanel Spacing="8">
              <Grid PointerPressed="ToggleSearchResults" Cursor="Hand">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="SearchResultsArrow" Text="▶" Foreground="{DynamicResource Brush.TextPrimary}" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" /><!-- Collapsed on load -->
                <TextBlock Grid.Column="1" Text="Customer Search Results" Foreground="{DynamicResource Brush.TextPrimary}" FontWeight="Bold" />
              </Grid>
                <Grid x:Name="SearchResultsContent" IsVisible="False">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  
                <DataGrid
                    Grid.Row="0"
                    Margin="0,8,0,0"
                    HorizontalAlignment="Stretch"
                    AutoGenerateColumns="False"
                    ItemsSource="{Binding PagedCustomerSearchResults}"
                    SelectedItem="{Binding FoundCustomer, Mode=TwoWay}"
                    CanUserReorderColumns="False"
                    CanUserResizeColumns="True"
                    IsReadOnly="True"
                    Focusable="False">
              <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding CustomerId}" IsReadOnly="True" Width="40" />
                <DataGridTextColumn Header="First Name"
                                    Binding="{Binding FirstName}" />
                <DataGridTextColumn Header="Last Name"
                                    Binding="{Binding LastName}" />
                <DataGridTextColumn Header="Company" Binding="{Binding CompanyName}" IsReadOnly="True" Width="140" />
                <DataGridTextColumn Header="Site" Binding="{Binding SiteName}" IsReadOnly="True" Width="140" />
                <DataGridTextColumn Header="Account" Binding="{Binding AccountNumberFormatted}" IsReadOnly="True" />
                <DataGridTextColumn Header="Mobile" Binding="{Binding MobileNumber}" IsReadOnly="True" />
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*" IsReadOnly="True" />

                <!-- Action buttons -->
                <DataGridTemplateColumn Header="Actions" Width="170">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <Button
                            Classes="row-action"
                            Content="Log Ticket"
                            Command="{Binding DataContext.LogTicketCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}" />
                        <Button
                            Classes="row-action"
                            Content="Delete"
                            Command="{Binding DataContext.DeleteCustomerCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}" />
                      </StackPanel>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
                </DataGrid>

                  <!-- Pagination Control -->
                  <local:PaginationControl Grid.Row="1" DataContext="{Binding PaginationViewModel}" Margin="0,8,0,0" />
                </Grid>
            </StackPanel>
          </Border>

          <!-- BLOCK 3: CUSTOMER DETAILS (Right Column) -->
          <Border Grid.Column="1" Background="{DynamicResource Brush.PanelBackground}" Padding="12" CornerRadius="4">
            <StackPanel Spacing="8">
              <Grid PointerPressed="ToggleCustomerDetails" Cursor="Hand">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="CustomerDetailsArrow" Text="▶" Foreground="{DynamicResource Brush.TextPrimary}" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" /><!-- Collapsed on load -->
                <TextBlock Grid.Column="1" Text="Customer Details" Foreground="{DynamicResource Brush.TextPrimary}" FontWeight="Bold" />
              </Grid>
            <StackPanel x:Name="CustomerDetailsContent" IsVisible="False"><!-- Collapsed on load -->
              <Border Margin="0,8,0,0" Padding="8" Background="{DynamicResource Brush.PanelBackground}" CornerRadius="4">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Customer ID" Foreground="#c0c4cf" Margin="0,0,8,2" />
                <TextBlock Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Text="{Binding SelectedCustomerIdDisplay}" Foreground="#f5f5f5" FontSize="11" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="First Name" Foreground="#c0c4cf" Margin="0,4,8,2" />
                <TextBlock Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Text="{Binding SelectedFirstName}" Foreground="#f5f5f5" FontSize="11" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Last Name" Foreground="#c0c4cf" Margin="0,4,8,2" />
                <TextBlock Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Text="{Binding SelectedLastName}" Foreground="#f5f5f5" FontSize="11" />

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Company Name" Foreground="#c0c4cf" Margin="0,4,8,2" />
                <TextBlock Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Text="{Binding SelectedCompanyName}" Foreground="#f5f5f5" FontSize="11" />

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Site Name" Foreground="#c0c4cf" Margin="0,4,8,2" />
                <TextBlock Grid.Row="4" Grid.Column="1" VerticalAlignment="Center" Text="{Binding SelectedSiteName}" Foreground="#f5f5f5" FontSize="11" />

                <!-- NEW: Taxable under Company Name -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Taxable" Foreground="#c0c4cf" Margin="0,4,8,2" />
                <TextBlock Grid.Row="5" Grid.Column="1" VerticalAlignment="Center" Text="{Binding SelectedTaxable}" Foreground="#f5f5f5" FontSize="11" />

                <TextBlock Grid.Row="6" Grid.Column="0" Text="ID Number" Foreground="#c0c4cf" Margin="0,4,8,2" />
                <TextBlock Grid.Row="6" Grid.Column="1" VerticalAlignment="Center" Text="{Binding SelectedIdNumber}" Foreground="#f5f5f5" FontSize="11" />

                <TextBlock Grid.Row="7" Grid.Column="0" Text="Account Number" Foreground="#c0c4cf" Margin="0,4,8,2" />
                <TextBlock Grid.Row="7" Grid.Column="1" VerticalAlignment="Center" Text="{Binding SelectedAccountNumberFormatted}" Foreground="#f5f5f5" FontSize="11" />

                <TextBlock Grid.Row="8" Grid.Column="0" Text="Price Code" Foreground="#c0c4cf" Margin="0,4,8,2" />
                <TextBlock Grid.Row="8" Grid.Column="1" VerticalAlignment="Center" Text="{Binding SelectedPriceCode}" Foreground="#f5f5f5" FontSize="11" />

                <TextBlock Grid.Row="9" Grid.Column="0" Text="Phone" Foreground="#c0c4cf" Margin="0,4,8,2" />
                <TextBlock Grid.Row="9" Grid.Column="1" VerticalAlignment="Center" Text="{Binding SelectedPhoneNumber}" Foreground="#f5f5f5" FontSize="11" />

                <TextBlock Grid.Row="10" Grid.Column="0" Text="Mobile" Foreground="#c0c4cf" Margin="0,4,8,2" />
                <TextBlock Grid.Row="10" Grid.Column="1" VerticalAlignment="Center" Text="{Binding SelectedMobileNumber}" Foreground="#f5f5f5" FontSize="11" />

                <TextBlock Grid.Row="11" Grid.Column="0" Text="Email" Foreground="#c0c4cf" Margin="0,4,8,0" />
                <TextBlock Grid.Row="11" Grid.Column="1" VerticalAlignment="Center" Text="{Binding SelectedEmail}" Foreground="#f5f5f5" FontSize="11" />

                <!-- Site address (read-only, from Site/CAS) -->
                <TextBlock Grid.Row="12" Grid.Column="0" Text="Site Address" Foreground="#c0c4cf" Margin="0,4,8,2" />
                <TextBlock Grid.Row="12" Grid.Column="1" VerticalAlignment="Center" Text="{Binding CustomerSiteAddressSummary}" Foreground="#f5f5f5" FontSize="11" TextWrapping="Wrap" />
              </Grid>
            </Border>

            <!-- Customer Images Display -->
            <Border Margin="0,12,0,0" 
                    Padding="12" 
                    Background="{DynamicResource Brush.GlassPanel}" 
                    CornerRadius="4"
                    BorderBrush="{DynamicResource Brush.GlassBorder}"
                    BorderThickness="1"
                    IsVisible="{Binding SelectedCustomer, Converter={x:Static ObjectConverters.IsNotNull}}">
              <StackPanel Spacing="8">
                <TextBlock Text="Customer Images" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource Brush.TextPrimary}"
                           FontSize="13"/>
                
                <UniformGrid Rows="2" Columns="3">
                  <!-- ID Card -->
                  <Border BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Margin="4" Background="{DynamicResource Brush.GlassPanelDarker}" Padding="5">
                    <StackPanel>
                      <TextBlock Text="ID Card" FontSize="11" Foreground="#c0c4cf" Margin="0,0,0,4" FontWeight="SemiBold"/>
                      <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                        <Image Source="{Binding SelectedIdCardImage}" Width="120" Height="120" Stretch="Uniform"/>
                      </Viewbox>
                    </StackPanel>
                  </Border>
                  
                  <!-- Driver License -->
                  <Border BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Margin="4" Background="{DynamicResource Brush.GlassPanelDarker}" Padding="5">
                    <StackPanel>
                      <TextBlock Text="Driver License" FontSize="11" Foreground="#c0c4cf" Margin="0,0,0,4" FontWeight="SemiBold"/>
                      <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                        <Image Source="{Binding SelectedDriverLicenseImage}" Width="120" Height="120" Stretch="Uniform"/>
                      </Viewbox>
                    </StackPanel>
                  </Border>
                  
                  <!-- Photo -->
                  <Border BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Margin="4" Background="{DynamicResource Brush.GlassPanelDarker}" Padding="5">
                    <StackPanel>
                      <TextBlock Text="Photo" FontSize="11" Foreground="#c0c4cf" Margin="0,0,0,4" FontWeight="SemiBold"/>
                      <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                        <Image Source="{Binding SelectedPhotoImage}" Width="120" Height="120" Stretch="Uniform"/>
                      </Viewbox>
                    </StackPanel>
                  </Border>
                  
                  <!-- Signature -->
                  <Border BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Margin="4" Background="{DynamicResource Brush.GlassPanelDarker}" Padding="5">
                    <StackPanel>
                      <TextBlock Text="Signature" FontSize="11" Foreground="#c0c4cf" Margin="0,0,0,4" FontWeight="SemiBold"/>
                      <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                        <Image Source="{Binding SelectedSignatureImage}" Width="120" Height="120" Stretch="Uniform"/>
                      </Viewbox>
                    </StackPanel>
                  </Border>
                  
                  <!-- Fingerprint -->
                  <Border BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Margin="4" Background="{DynamicResource Brush.GlassPanelDarker}" Padding="5">
                    <StackPanel>
                      <TextBlock Text="Fingerprint" FontSize="11" Foreground="#c0c4cf" Margin="0,0,0,4" FontWeight="SemiBold"/>
                      <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                        <Image Source="{Binding SelectedFingerprintImage}" Width="120" Height="120" Stretch="Uniform"/>
                      </Viewbox>
                    </StackPanel>
                  </Border>
                </UniformGrid>
              </StackPanel>
              </Border>
            </StackPanel>
          </StackPanel>
        </Border>
        </Grid>

        <!-- BLOCK 4: CREATE NEW CUSTOMER -->
        <Border Background="{DynamicResource Brush.PanelBackground}" Padding="12" CornerRadius="4">
          <StackPanel Spacing="8">
            <Grid PointerPressed="ToggleCreateEdit" Cursor="Hand">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" x:Name="CreateEditArrow" Text="▶" Foreground="{DynamicResource Brush.TextPrimary}" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" /><!-- Collapsed on load -->
              <TextBlock Grid.Column="1" Text="Create/Edit Customer" Foreground="{DynamicResource Brush.TextPrimary}" FontWeight="Bold" />
            </Grid>

            <!-- 4-column form grid -->
            <Grid x:Name="CreateEditContent" IsVisible="False" Margin="0,8,0,0"><!-- Collapsed on load -->
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="275" />
                  <ColumnDefinition Width="275" />
                  <ColumnDefinition Width="275" />
                  <ColumnDefinition Width="275" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Row 0: First Name / Last Name / ID Number / (empty) -->
                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2" Margin="0,0,12,0">
                  <TextBlock Text="First Name" Foreground="#c0c4cf" />
                  <TextBox Text="{Binding NewFirstName}" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2" Margin="0,0,12,0">
                  <TextBlock Text="Last Name" Foreground="#c0c4cf" />
                  <TextBox Text="{Binding NewLastName}" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Spacing="2" Margin="0,0,12,0">
                  <TextBlock Text="ID Number" Foreground="#c0c4cf" />
                  <TextBox Text="{Binding NewIdNumber}" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="3" Spacing="2">
                  <!-- Empty column -->
                </StackPanel>

                <!-- Row 1: Company / Site / Account Number / Price Code -->
                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2" Margin="0,0,12,0">
                  <TextBlock Text="Company" Foreground="#c0c4cf" />
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="70" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ComboBox
                        Grid.Column="0"
                        Width="70"
                        ItemsSource="{Binding CompanyLetterFilters}"
                        SelectedItem="{Binding SelectedNewCompanyLetter}"
                        IsEnabled="{Binding NewIsCompany}"
                        HorizontalAlignment="Stretch" />
                    <ComboBox
                        Grid.Column="1"
                        Margin="4,0,0,0"
                        ItemsSource="{Binding NewCompanySuggestions}"
                        SelectedItem="{Binding SelectedNewCompany}"
                        IsEnabled="{Binding NewIsCompany}"
                        HorizontalContentAlignment="Stretch"
                        ItemTemplate="{StaticResource CompanyLookupTemplate}" />
                  </Grid>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2" Margin="0,0,12,0">
                  <TextBlock Text="Site" Foreground="#c0c4cf" />
                  <ComboBox
                      HorizontalAlignment="Stretch"
                      ItemsSource="{Binding NewSiteSuggestions}"
                      SelectedItem="{Binding SelectedNewSite}"
                      IsEnabled="{Binding NewIsCompany}"
                      HorizontalContentAlignment="Stretch"
                      ItemTemplate="{StaticResource SiteLookupTemplate}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2" Spacing="2" Margin="0,0,12,0">
                  <TextBlock Text="Account Number" Foreground="#c0c4cf" />
                  <TextBox
                    Text="{Binding NewAccountNumberDisplay}"
                    IsReadOnly="True"
                    IsTabStop="False"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="3" Spacing="2">
                  <TextBlock Text="Price Code" Foreground="#c0c4cf" />
                  <ComboBox
                    ItemsSource="{Binding PriceCodeOptions}"
                    SelectedItem="{Binding SelectedPriceCodeChar, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Label}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </StackPanel>

                <!-- Row 2: Is Company / Taxable / Phone / Mobile / Email -->
                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Spacing="8" Margin="0,0,12,0">
                  <CheckBox Content="Is Company" IsChecked="{Binding NewIsCompany}" />
                  <CheckBox Content="Taxable" IsChecked="{Binding NewTaxable}" Margin="12,0,0,0" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" Spacing="2" Margin="0,0,12,0">
                  <TextBlock Text="Phone" Foreground="#c0c4cf" />
                  <TextBox Text="{Binding NewPhoneNumber}" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="2" Spacing="2" Margin="0,0,12,0">
                  <TextBlock Text="Mobile" Foreground="#c0c4cf" />
                  <TextBox Text="{Binding NewMobileNumber}" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="3" Spacing="2">
                  <TextBlock Text="Email" Foreground="#c0c4cf" />
                  <TextBox Text="{Binding NewEmail}" />
                </StackPanel>

              <!-- Customer Images Row (Single row of 5 images) -->
              <StackPanel Grid.Column="0" Grid.Row="3" Grid.ColumnSpan="4" Margin="0,16,0,0" Spacing="8">
                <TextBlock Text="Customer Images (Optional)" 
                          FontWeight="Bold" 
                          Foreground="{DynamicResource Brush.TextPrimary}"
                          FontSize="13" />
                
                <UniformGrid Rows="1" Columns="5" Width="1100" HorizontalAlignment="Left">
                  <!-- ID Card -->
                  <StackPanel Spacing="4" Margin="0,0,8,0">
                    <TextBlock Text="ID Card" Foreground="#c0c4cf" FontSize="10" FontWeight="SemiBold"/>
                    <Border BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Background="{DynamicResource Brush.GlassPanelDarker}" Width="150" Height="150" Padding="5">
                      <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                        <Image Source="{Binding IdCardImage}" Width="150" Height="150" Stretch="Uniform"/>
                      </Viewbox>
                    </Border>
                    <Button Content="📄 Scan ID" Command="{Binding CaptureIdCardCommand}" HorizontalAlignment="Stretch" FontSize="9" Padding="4,4" Cursor="Hand" Width="180" Height="20" />
                  </StackPanel>
                  
                  <!-- Driver License -->
                  <StackPanel Spacing="4" Margin="0,0,8,0">
                    <TextBlock Text="Driver License" Foreground="#c0c4cf" FontSize="10" FontWeight="SemiBold"/>
                    <Border BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Background="{DynamicResource Brush.GlassPanelDarker}" Width="150" Height="150" Padding="5">
                      <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                        <Image Source="{Binding DriverLicenseImage}" Width="150" Height="150" Stretch="Uniform"/>
                      </Viewbox>
                    </Border>
                    <Button Content="📄 License" Command="{Binding CaptureDriverLicenseCommand}" HorizontalAlignment="Stretch" FontSize="9" Padding="4,4" Cursor="Hand" Width="180" Height="20" />
                  </StackPanel>
                  
                  <!-- Photo -->
                  <StackPanel Spacing="4" Margin="0,0,8,0">
                    <TextBlock Text="Photo" Foreground="#c0c4cf" FontSize="10" FontWeight="SemiBold"/>
                    <Border BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Background="{DynamicResource Brush.GlassPanelDarker}" Width="150" Height="150" Padding="5">
                      <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                        <Image Source="{Binding PhotoImage}" Width="150" Height="150" Stretch="Uniform"/>
                      </Viewbox>
                    </Border>
                    <Button Content="📷 Take Photo" Command="{Binding CapturePhotoCommand}" HorizontalAlignment="Stretch" FontSize="9" Padding="4,4" Cursor="Hand" Width="180" Height="20" />
                  </StackPanel>

                  <!-- Signature -->
                  <StackPanel Spacing="4" Margin="0,0,8,0">
                    <TextBlock Text="Signature" Foreground="#c0c4cf" FontSize="10" FontWeight="SemiBold"/>
                    <Border BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Background="{DynamicResource Brush.GlassPanelDarker}" Width="150" Height="150" Padding="5">
                      <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                        <Image Source="{Binding SignatureImage}" Width="150" Height="150" Stretch="Uniform"/>
                      </Viewbox>
                    </Border>
                    <Button Content="✍ Signature" Command="{Binding CaptureSignatureCommand}" HorizontalAlignment="Stretch" FontSize="9" Padding="4,4" Cursor="Hand" Width="180" Height="20" />
                  </StackPanel>

                  <!-- Fingerprint -->
                  <StackPanel Spacing="4" Margin="0,0,8,0">
                    <TextBlock Text="Fingerprint" Foreground="#c0c4cf" FontSize="10" FontWeight="SemiBold"/>
                    <Border BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Background="{DynamicResource Brush.GlassPanelDarker}" Width="150" Height="150" Padding="5">
                      <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                        <Image Source="{Binding FingerprintImage}" Width="150" Height="150" Stretch="Uniform"/>
                      </Viewbox>
                    </Border>
                    <Button Content="👆 Fingerprint" Command="{Binding CaptureFingerprintCommand}" HorizontalAlignment="Stretch" FontSize="9" Padding="4,4" Cursor="Hand" Width="180" Height="20"/>
                  </StackPanel>
                </UniformGrid>
              </StackPanel>

              <!-- Action Buttons -->
              <StackPanel Grid.Row="4"
                          Grid.ColumnSpan="4"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Spacing="8"
                  Margin="0,20,0,0">

                <Button
                    Name="ClearCustomerButton"
                    Width="100"
                    Content="Clear"
                    Command="{Binding ClearNewCustomerCommand}"
                    Classes="primary"
                    IsEnabled="True"
                    ToolTip.Tip="Clear form" />

                <Button
                    Name="CreateCustomerButton"
                    Classes="primary"
                    Width="100"
                    Content="Create"
                    Command="{Binding CreateCustomerCommand}"
                    IsVisible="{Binding IsCreateMode}"
                    IsEnabled="True"
                    ToolTip.Tip="Create new customer" />

                <Button
                    Name="UpdateCustomerButton"
                    Classes="primary"
                    Width="100"
                    Content="Update"
                    Command="{Binding UpdateCustomerCommand}"
                    IsVisible="{Binding IsEditMode}"
                    IsEnabled="True"
                    ToolTip.Tip="Update customer" />
              </StackPanel>
            </Grid>

            <TextBlock
                Margin="0,4,0,0"
                Text="First/Last name is required."
                Foreground="#ff6b6b"
                FontSize="11"
                IsVisible="{Binding IsNewCustomerFullNameInvalid}" />
          </StackPanel>
        </Border>
    </StackPanel>

  </Border>
</UserControl>
