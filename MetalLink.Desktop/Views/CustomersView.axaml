<UserControl
    x:Class="MetalLink.Desktop.Views.CustomersView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <UserControl.Styles>
    <!-- Default textbox border -->
    <Style Selector="TextBox">
      <Setter Property="BorderBrush" Value="#444a55" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="TextBox:focus">
      <Setter Property="BorderBrush" Value="#5c7cfa" />
    </Style>

    <!-- Full name invalid -->
    <!-- <Style Selector="#NewFullNameBox">
      <Setter Property="BorderBrush" Value="#444a55" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsNewCustomerFullNameInvalid}" Value="True">
          <Setter Property="BorderBrush" Value="#ff5555" />
        </DataTrigger>
      </Style.Triggers>
    </Style> -->
  </UserControl.Styles>

  <Border Background="#1f2229" Padding="16">
    <ScrollViewer>
      <StackPanel Spacing="16">

        <TextBlock
            Text="Customers"
            FontSize="22"
            FontWeight="Bold"
            Foreground="#f5f5f5" />

        <!-- Search customer -->
        <Border Background="#252932" Padding="12" CornerRadius="4">
          <StackPanel Spacing="8">
            <TextBlock Text="Search existing customer" Foreground="#f5f5f5" FontWeight="Bold" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBox
                  Width="150"
                  Watermark="Customer ID"
                  Text="{Binding SearchCustomerIdText}" />
              <Button
                  Content="Search"
                  Command="{Binding SearchCustomerCommand}" />
            </StackPanel>
            <TextBlock
                Text="{Binding FoundCustomerSummary}"
                Foreground="#c0c4cf"
                TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <!-- New customer -->
        <Border Background="#252932" Padding="12" CornerRadius="4">
          <StackPanel Spacing="8">
            <TextBlock Text="Create new customer" Foreground="#f5f5f5" FontWeight="Bold" />

            <!-- Unsaved changes hint -->
            <StackPanel Orientation="Horizontal"
                        Spacing="4"
                        Margin="0,2,0,6"
                        IsVisible="{Binding HasUnsavedNewCustomer}">
            <TextBlock Text="●"
                        Foreground="#ffa94d"
                        FontSize="10"
                        VerticalAlignment="Center" />
            <TextBlock Text="You have unsaved customer changes."
                        Foreground="#ffa94d"
                        FontSize="11" />
            </StackPanel>

            <StackPanel Spacing="6">
              <TextBlock Text="Full name" Foreground="#c0c4cf" />
              <TextBox
                  x:Name="NewFullNameBox"
                  Text="{Binding NewFullName}" />
              <TextBlock
                  Foreground="#ff8888"
                  FontSize="11"
                  Text="Full name is required."
                  IsVisible="{Binding IsNewCustomerFullNameInvalid}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
              <CheckBox
                  Content="Is Company"
                  IsChecked="{Binding NewIsCompany}" />
              <TextBox
                  Width="200"
                  Watermark="Company Name"
                  Text="{Binding NewCompanyName}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBox
                  Width="180"
                  Watermark="ID Number"
                  Text="{Binding NewIdNumber}" />
              <TextBox
                  Width="150"
                  Watermark="Account Number"
                  Text="{Binding NewAccountNumber}" />
              <TextBox
                  Width="120"
                  Watermark="Price Code"
                  Text="{Binding NewPriceCode}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBox
                  Width="150"
                  Watermark="Phone"
                  Text="{Binding NewPhoneNumber}" />
              <TextBox
                  Width="150"
                  Watermark="Mobile"
                  Text="{Binding NewMobileNumber}" />
              <TextBox
                  Width="220"
                  Watermark="Email"
                  Text="{Binding NewEmail}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
              <Button
                  Content="Create Customer"
                  Command="{Binding CreateCustomerCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>
  </Border>
</UserControl>
