<UserControl
    x:Class="MetalLink.Desktop.Views.TicketsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <UserControl.Styles>
    <Style Selector="TextBox">
      <Setter Property="BorderBrush" Value="#444a55" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="TextBox:focus">
      <Setter Property="BorderBrush" Value="#5c7cfa" />
    </Style>

    <!-- Customer ID -->
    <!-- <Style Selector="#TicketCustomerIdBox">
      <Setter Property="BorderBrush" Value="#444a55" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsTicketCustomerIdInvalid}" Value="True">
          <Setter Property="BorderBrush" Value="#ff5555" />
        </DataTrigger>
      </Style.Triggers>
    </Style> -->

    <!-- Ticket number -->
    <!-- <Style Selector="#TicketNumberBox">
      <Setter Property="BorderBrush" Value="#444a55" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsTicketNumberInvalid}" Value="True">
          <Setter Property="BorderBrush" Value="#ff5555" />
        </DataTrigger>
      </Style.Triggers>
    </Style> -->

    <!-- Unit price -->
    <!-- <Style Selector="#TicketUnitPriceBox">
      <Setter Property="BorderBrush" Value="#444a55" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsTicketUnitPriceInvalid}" Value="True">
          <Setter Property="BorderBrush" Value="#ff5555" />
        </DataTrigger>
      </Style.Triggers>
    </Style> -->
  </UserControl.Styles>

  <Border Background="#1f2229" Padding="16">
    <ScrollViewer>
      <StackPanel Spacing="16">

        <TextBlock
            Text="Tickets"
            FontSize="22"
            FontWeight="Bold"
            Foreground="#f5f5f5" />

        <!-- Unsaved ticket changes hint -->
        <StackPanel Orientation="Horizontal"
                    Spacing="4"
                    Margin="0,2,0,6"
                    IsVisible="{Binding HasUnsavedTicket}">
        <TextBlock Text="●"
                    Foreground="#ffa94d"
                    FontSize="10"
                    VerticalAlignment="Center" />
        <TextBlock Text="You have unsaved ticket changes."
                    Foreground="#ffa94d"
                    FontSize="11" />
        </StackPanel>


        <Border Background="#252932" Padding="12" CornerRadius="4">
          <StackPanel Spacing="8">

            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBox
                  x:Name="TicketCustomerIdBox"
                  Width="150"
                  Watermark="Customer ID"
                  Text="{Binding TicketCustomerIdText}" />
              <TextBox
                  x:Name="TicketNumberBox"
                  Width="140"
                  Watermark="Ticket Number"
                  Text="{Binding TicketNumber}" />
              <TextBox
                  Width="120"
                  Watermark="Type (weighbridge)"
                  Text="{Binding TicketType}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock
                  Text="Customer ID and Ticket Number are required."
                  Foreground="#ff8888"
                  FontSize="11"
                  VerticalAlignment="Center"
                  IsVisible="{Binding IsTicketCustomerIdInvalid}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
              <TextBox
                  Width="120"
                  Watermark="First Weight (kg)"
                  Text="{Binding TicketFirstWeightText}" />
              <TextBox
                  Width="120"
                  Watermark="Second Weight (kg)"
                  Text="{Binding TicketSecondWeightText}" />

              <Button
                  Content="Read Weighbridge"
                  Command="{Binding ReadWeighbridgeCommand}" />
              <Button
                  Content="Read Platform"
                  Command="{Binding ReadPlatformCommand}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBox
                  x:Name="TicketUnitPriceBox"
                  Width="120"
                  Watermark="Unit Price /kg"
                  Text="{Binding TicketUnitPriceText}" />
              <TextBox
                  Width="80"
                  Watermark="Currency"
                  Text="{Binding TicketCurrencyCode}" />
              <TextBox
                  Width="240"
                  Watermark="Product Description"
                  Text="{Binding TicketProductDescription}" />
            </StackPanel>

            <TextBlock
                Text="Unit price is required and must be numeric."
                Foreground="#ff8888"
                FontSize="11"
                IsVisible="{Binding IsTicketUnitPriceInvalid}" />

            <StackPanel Spacing="4" Margin="0,8,0,0">
              <TextBlock Text="Notes" Foreground="#c0c4cf" />
              <TextBox
                  Text="{Binding TicketNotes}"
                  AcceptsReturn="True"
                  TextWrapping="Wrap"
                  Height="80" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
              <Button
                  Content="Create Ticket"
                  Command="{Binding CreateTicketCommand}" />
            </StackPanel>

            <Border Background="#1f2229" Padding="8" CornerRadius="4" Margin="0,8,0,0">
              <TextBlock
                  Text="{Binding LastCreatedTicketSummary}"
                  Foreground="#c0c4cf"
                  TextWrapping="Wrap" />
            </Border>

            <Border Background="#252932"
                    Padding="10"
                    CornerRadius="4"
                    Margin="0,12,0,0">
              <StackPanel Spacing="6">

                <TextBlock Text="Ticket Report (PDF)"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="#f5f5f5" />

                <StackPanel Orientation="Horizontal" Spacing="10">
                  <TextBlock Text="Ticket ID:"
                             Width="100"
                             VerticalAlignment="Center"
                             Foreground="#c0c4cf" />
                  <TextBox Text="{Binding TicketReportTicketIdText}"
                           Width="150"
                           Watermark="Ticket ID" />
                  <Button Content="Download Ticket PDF"
                          Width="180"
                          Command="{Binding DownloadTicketReportCommand}" />
                </StackPanel>

                <TextBlock Text="Last Ticket PDF Path:"
                           FontWeight="Bold"
                           Margin="0,6,0,0"
                           Foreground="#c0c4cf" />
                <TextBlock Text="{Binding LastTicketReportPath}"
                           TextWrapping="Wrap"
                           Foreground="#c0c4cf"
                           FontSize="11" />
                </StackPanel>
            </Border>
          </StackPanel>
        </Border>

      <Border Background="#252932"
              Padding="12"
              CornerRadius="4"
              Margin="0,10,0,0">
        <StackPanel Margin="2" Spacing="8">
          <TextBlock Text="Ticket Report (PDF)"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="#f5f5f5"
                     Margin="0,0,0,4"/>

          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="Ticket ID:"
                       Width="100"
                       VerticalAlignment="Center"
                       Foreground="#c0c4cf" />
            <TextBox Text="{Binding TicketReportTicketIdText}"
                     Width="120" />
            <Button Content="Download Ticket PDF"
                    Width="170"
                    Command="{Binding DownloadTicketReportCommand}" />
          </StackPanel>

          <TextBlock Text="Last Ticket PDF Path:"
                     FontWeight="Bold"
                     Foreground="#c0c4cf"
                     Margin="0,10,0,0" />
          <TextBlock Text="{Binding LastTicketReportPath}"
                     TextWrapping="Wrap"
                     Foreground="#e5e7eb" />
        </StackPanel>
      </Border>

      </StackPanel>
    </ScrollViewer>
  </Border>
</UserControl>
