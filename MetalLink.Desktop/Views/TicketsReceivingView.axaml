<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:MetalLink.Desktop.Views"
             x:Class="MetalLink.Desktop.Views.TicketsReceivingView">

  <Grid RowDefinitions="Auto,*">
    <!-- Sticky Header -->
    <Border Grid.Row="0" Background="{DynamicResource Brush.PanelBackground}" Padding="12,8" CornerRadius="4" Margin="16,16,16,8" ZIndex="100">
      <Image Source="avares://MetalLink.Desktop/Assets/receiving_heading.png" Height="40" HorizontalAlignment="Left" Stretch="Uniform" />
    </Border>
    
    <!-- Scrollable Content -->
    <ScrollViewer Grid.Row="1" x:Name="TicketsScrollViewer" Padding="16,8,16,10">
      <StackPanel Spacing="16" Margin="0,0,0,100">

          <!-- SEARCH TICKETS -->
          <Border Background="{DynamicResource Brush.PanelBackground}" Padding="12" CornerRadius="4">
            <StackPanel Spacing="8">
              <Grid PointerPressed="ToggleSearchCriteria" Cursor="Hand">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" 
                           Text="{Binding Receiving.ReceivingIsSearchCriteriaExpanded, Converter={StaticResource SectionToViewConverter}, ConverterParameter=\'arrow\'}" 
                           Foreground="{DynamicResource Brush.TextPrimary}" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="Search Tickets" Foreground="{DynamicResource Brush.TextPrimary}" FontWeight="Bold" />
              </Grid>

              <StackPanel Spacing="8" IsVisible="{Binding Receiving.ReceivingIsSearchCriteriaExpanded}">
                <CheckBox Content="New Customer?" IsChecked="{Binding IsNewCustomerOnly}" />
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" Margin="0,8,0,0" ColumnSpacing="10" RowSpacing="10">
                  <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                    <TextBlock Text="Customer ID" Foreground="#c0c4cf" />
                    <TextBox Text="{Binding SearchReceivingTicketCustomerIdText}" />
                  </StackPanel>
                  <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                    <TextBlock Text="ID Number" Foreground="#c0c4cf" />
                    <TextBox Text="{Binding SearchReceivingTicketIdNumberText}" />
                  </StackPanel>
                  <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2">
                    <TextBlock Text="First Name" Foreground="#c0c4cf" />
                    <TextBox Text="{Binding SearchReceivingTicketFirstNameText}" />
                  </StackPanel>
                  <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
                    <TextBlock Text="Last Name" Foreground="#c0c4cf" />
                    <TextBox Text="{Binding SearchReceivingTicketLastNameText}" />
                  </StackPanel>
                  <!-- Add more fields as needed -->
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
                  <Button Width="100" Content="Clear" Command="{Binding ClearReceivingTicketSearchCommand}" />
                  <Button Classes="primary" Width="100" Content="Search" Command="{Binding SearchReceivingTicketsCommand}" />
                </StackPanel>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- TICKET RESULTS -->
          <Border Background="{DynamicResource Brush.PanelBackground}" Padding="12" CornerRadius="4">
            <StackPanel Spacing="8">
              <Grid PointerPressed="ToggleSearchResults" Cursor="Hand">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" 
                           Text="{Binding Receiving.ReceivingIsSearchResultsExpanded, Converter={StaticResource SectionToViewConverter}, ConverterParameter=\'arrow\'}" 
                           Foreground="{DynamicResource Brush.TextPrimary}" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="Ticket Results" Foreground="{DynamicResource Brush.TextPrimary}" FontWeight="Bold" />
              </Grid>
              <DataGrid x:Name="ReceivingTicketsGrid" AutoGenerateColumns="False" ItemsSource="{Binding ReceivingTicketSearchResults}"
                        SelectedItem="{Binding SelectedReceivingTicket, Mode=TwoWay}" IsVisible="{Binding Receiving.ReceivingIsSearchResultsExpanded}"
                        SelectionChanged="ReceivingTicketsGrid_SelectionChanged" Height="250">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Ticket #" Binding="{Binding TicketNumber}" Width="140" />
                  <DataGridTextColumn Header="First Name" Binding="{Binding FirstName}" Width="120" />
                  <DataGridTextColumn Header="Last Name" Binding="{Binding LastName}" Width="120" />
                </DataGrid.Columns>
              </DataGrid>
            </StackPanel>
          </Border>

          <!-- TICKET DETAILS -->
          <Border Background="{DynamicResource Brush.PanelBackground}" Padding="12" CornerRadius="4" IsVisible="{Binding ShouldShowTicketDetails}">
            <StackPanel Spacing="12">
              <Grid PointerPressed="ToggleDetails" Cursor="Hand">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" 
                           Text="{Binding Receiving.ReceivingIsDetailsExpanded, Converter={StaticResource SectionToViewConverter}, ConverterParameter=\'arrow\'}" 
                           Foreground="{DynamicResource Brush.TextPrimary}" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="Ticket Details" Foreground="{DynamicResource Brush.TextPrimary}" FontSize="13" FontWeight="Bold" />
              </Grid>
              <StackPanel Spacing="12" IsVisible="{Binding Receiving.ReceivingIsDetailsExpanded}">
                <TextBlock Text="Ticket details content goes here" Foreground="#f5f5f5" />
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- CREATE / EDIT TICKET -->
          <Border Background="{DynamicResource Brush.PanelBackground}" Padding="12" CornerRadius="4">
            <StackPanel Spacing="12">
              <Grid PointerPressed="ToggleCreateEdit" Cursor="Hand">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" 
                           Text="{Binding Receiving.ReceivingIsCreateEditExpanded, Converter={StaticResource SectionToViewConverter}, ConverterParameter=\'arrow\'}" 
                           Foreground="{DynamicResource Brush.TextPrimary}" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="Create Ticket" Foreground="{DynamicResource Brush.TextPrimary}" FontSize="13" FontWeight="Bold" />
              </Grid>
              <StackPanel Spacing="12" IsVisible="{Binding Receiving.ReceivingIsCreateEditExpanded}">
                <TextBlock Text="Create ticket form goes here" Foreground="#f5f5f5" />
              </StackPanel>
            </StackPanel>
          </Border>

        </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
