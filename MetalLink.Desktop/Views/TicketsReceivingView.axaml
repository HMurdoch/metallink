<UserControl
    x:Class="MetalLink.Desktop.Views.TicketsReceivingView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <UserControl.Styles>
    <!-- Default textbox border + font to match Customers view -->
    <Style Selector="TextBox">
      <Setter Property="BorderBrush" Value="#444a55" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontSize" Value="11" />
    </Style>

    <Style Selector="TextBox:focus">
      <Setter Property="BorderBrush" Value="#5c7cfa" />
    </Style>

    <!-- Make ComboBox look/size similar to TextBox -->
    <Style Selector="ComboBox">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="BorderBrush" Value="#444a55" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontSize" Value="11" />
    </Style>

    <Style Selector="ComboBox:focus">
      <Setter Property="BorderBrush" Value="#5c7cfa" />
    </Style>

    <!-- DataGrid overall styling to match Customers grid -->
    <Style Selector="DataGrid">
      <Setter Property="Background" Value="{StaticResource Brush.PanelBackground}" />
      <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
      <Setter Property="GridLinesVisibility" Value="Horizontal" />
      <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Brush.BorderSubtle}" />
      <Setter Property="VerticalGridLinesBrush" Value="{StaticResource Brush.BorderSubtle}" />
      <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="DataGridCell">
      <Setter Property="FontSize" Value="11" />
    </Style>

    <Style Selector="DataGridColumnHeader">
      <Setter Property="Background" Value="{StaticResource Brush.NavBackground}" />
      <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style Selector="DataGridRow">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Transitions">
        <Setter.Value>
          <Transitions>
            <BrushTransition Property="Background" Duration="0:0:0.12" />
          </Transitions>
        </Setter.Value>
      </Setter>
    </Style>

    <Style Selector="DataGridRow:pointerover">
      <Setter Property="Background" Value="#20FFFFFF" />
    </Style>

    <Style Selector="DataGridRow:selected">
      <Setter Property="Background" Value="#303B82F6" />
    </Style>

    <!-- Row action buttons (for Delete in Receiving lines grid) -->
    <Style Selector="Button.row-action">
      <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
      <Setter Property="Background" Value="#30333A" />
      <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="Padding" Value="6,2" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
      <Setter Property="RenderTransform">
        <Setter.Value>
          <ScaleTransform ScaleX="1" ScaleY="1" />
        </Setter.Value>
      </Setter>
      <Setter Property="Transitions">
        <Setter.Value>
          <Transitions>
            <BrushTransition Property="Background" Duration="0:0:0.10" />
            <BrushTransition Property="BorderBrush" Duration="0:0:0.10" />
          </Transitions>
        </Setter.Value>
      </Setter>
    </Style>

    <Style Selector="Button.row-action:pointerover">
      <Setter Property="Background" Value="#3A4150" />
      <Setter Property="BorderBrush" Value="{StaticResource Brush.AccentGradient}" />
    </Style>

    <Style Selector="Button.row-action:pressed">
      <Setter Property="RenderTransform">
        <Setter.Value>
          <ScaleTransform ScaleX="0.97" ScaleY="0.97" />
        </Setter.Value>
      </Setter>
    </Style>

    <Style Selector="Button.row-action:disabled">
      <Setter Property="Background" Value="#2A2D34" />
      <Setter Property="Foreground" Value="#80838C" />
      <Setter Property="BorderBrush" Value="#3A3D45" />
    </Style>
  </UserControl.Styles>

  <UserControl.Resources>
    <DataTemplate x:Key="ReceivingProductLookupTemplate">
      <TextBlock Text="{Binding ProductName}" />
    </DataTemplate>
  </UserControl.Resources>

  <Border Background="{StaticResource Brush.MainBackground}" Padding="16">
    <ScrollViewer x:Name="TicketsScrollViewer">
      <StackPanel Spacing="16">

        <!-- Header with animated glow (matching Customers header) -->
        <StackPanel Spacing="4">
          <Grid>
            <TextBlock
                Text="Ticket Receiving"
                FontSize="20"
                FontWeight="Bold"
                Foreground="{StaticResource Brush.TextPrimary}" />
            <!-- Animated glow overlay -->
            <TextBlock
                Text="Ticket Receiving"
                FontSize="20"
                FontWeight="Bold"
                Foreground="#4a9eff"
                Opacity="0">
              <TextBlock.Styles>
                <Style Selector="TextBlock">
                  <Style.Animations>
                    <Animation Duration="0:0:5" IterationCount="INFINITE" Delay="0:0:0">
                      <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0" />
                      </KeyFrame>
                      <KeyFrame Cue="10%">
                        <Setter Property="Opacity" Value="0.8" />
                      </KeyFrame>
                      <KeyFrame Cue="30%">
                        <Setter Property="Opacity" Value="0.8" />
                      </KeyFrame>
                      <KeyFrame Cue="40%">
                        <Setter Property="Opacity" Value="0" />
                      </KeyFrame>
                      <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="0" />
                      </KeyFrame>
                    </Animation>
                  </Style.Animations>
                </Style>
              </TextBlock.Styles>
            </TextBlock>
          </Grid>
          <Border Height="2"
                  Margin="0,0,0,8"
                  CornerRadius="1">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                <LinearGradientBrush.GradientStops>
                  <GradientStop Color="#1E88E5" Offset="0" />
                  <GradientStop Color="#8EC5FC" Offset="0.5" />
                  <GradientStop Color="#1E88E5" Offset="1" />
                </LinearGradientBrush.GradientStops>
              </LinearGradientBrush>
            </Border.Background>
          </Border>
        </StackPanel>

        <!-- SEARCH TICKETS -->
        <Border Background="{StaticResource Brush.PanelBackground}" Padding="12" CornerRadius="4">
          <StackPanel Spacing="8">
            <TextBlock Text="Search tickets"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       FontWeight="Bold" />

            <Grid Margin="0,8,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <!-- Row 0: Customer ID / ID Number -->
              <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                <TextBlock Text="Customer ID" Foreground="#c0c4cf" />
                <TextBox Text="{Binding SearchReceivingTicketCustomerIdText}" />
              </StackPanel>
              <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                <TextBlock Text="ID Number" Foreground="#c0c4cf" />
                <TextBox Text="{Binding SearchReceivingTicketIdNumberText}" />
              </StackPanel>

              <!-- Row 1: First / Last name -->
              <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2">
                <TextBlock Text="First Name" Foreground="#c0c4cf" />
                <TextBox Text="{Binding SearchReceivingTicketFirstNameText}" />
              </StackPanel>
              <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
                <TextBlock Text="Last Name" Foreground="#c0c4cf" />
                <TextBox Text="{Binding SearchReceivingTicketLastNameText}" />
              </StackPanel>

              <!-- Row 2: Company (Letter + Dropdown in single column) / Account Number -->
              <StackPanel Grid.Row="2" Grid.Column="0" Spacing="2">
                <TextBlock Text="Company" Foreground="#c0c4cf" />
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <ComboBox Grid.Column="0"
                            ItemsSource="{Binding CompanyLetterFilters}"
                            SelectedItem="{Binding SearchTicketCompanyLetter}"
                            Margin="0,0,4,0" />
                  <ComboBox Grid.Column="1"
                            ItemsSource="{Binding SearchCompanySuggestions}"
                            SelectedItem="{Binding SearchTicketSelectedCompany}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding CompanyName}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </Grid>
              </StackPanel>
              <StackPanel Grid.Row="2" Grid.Column="1" Spacing="2">
                <TextBlock Text="Account Number" Foreground="#c0c4cf" />
                <TextBox Text="{Binding SearchReceivingTicketAccountNumberText}" />
              </StackPanel>

              <!-- Row 3: Site / [can be used for something else or blank] -->
              <StackPanel Grid.Row="3" Grid.Column="0" Spacing="2">
                <TextBlock Text="Site" Foreground="#c0c4cf" />
                <ComboBox
                    ItemsSource="{Binding SearchTicketSiteSuggestions}"
                    SelectedItem="{Binding SearchTicketSelectedSite}"
                    HorizontalAlignment="Stretch">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding SiteName}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>

              <!-- Row 4: Ticket Number / Ticket type -->
              <StackPanel Grid.Row="4" Grid.Column="0" Spacing="2">
                <TextBlock Text="Ticket Number" Foreground="#c0c4cf" />
                <TextBox Text="{Binding SearchReceivingTicketNumberText}" />
              </StackPanel>
              <StackPanel Grid.Row="4" Grid.Column="1" Spacing="2">
                <TextBlock Text="Ticket Type" Foreground="#c0c4cf" />
                <ComboBox
                    ItemsSource="{Binding TicketTypeOptions}"
                    SelectedItem="{Binding SelectedSearchTicketTypeOption}"
                    HorizontalAlignment="Stretch">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Display}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>
            </Grid>

            <!-- Search buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8"
                        Margin="0,8,0,0">
              <Button
                  Width="100"
                  Content="Clear"
                  Command="{Binding ClearReceivingTicketSearchCommand}" />
              <Button
                  Classes="primary"
                  Width="100"
                  Content="Search"
                  Command="{Binding SearchReceivingTicketsCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- RESULTS TABLE -->
        <Border Background="{StaticResource Brush.PanelBackground}" Padding="12" CornerRadius="4" Margin="0,8,0,0">
          <StackPanel Spacing="8">
            <TextBlock Text="Ticket results"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       FontWeight="Bold" />

            <DataGrid
                AutoGenerateColumns="False"
                ItemsSource="{Binding ReceivingTicketSearchResults}"
                SelectedItem="{Binding SelectedReceivingTicket, Mode=TwoWay}">
              <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding TicketId}" Width="80" IsReadOnly="True" />
                <DataGridTextColumn Header="Ticket #" Binding="{Binding TicketNumber}" Width="140" IsReadOnly="True" />
                <DataGridTextColumn Header="Type" Binding="{Binding TicketType}" Width="100" IsReadOnly="True" />
                <DataGridTextColumn Header="Customer ID" Binding="{Binding CustomerId}" Width="100" IsReadOnly="True" />
                <DataGridTextColumn Header="First Name" Binding="{Binding FirstName}" Width="120" IsReadOnly="True" />
                <DataGridTextColumn Header="Last Name" Binding="{Binding LastName}" Width="120" IsReadOnly="True" />
                <DataGridTextColumn Header="Account #" Binding="{Binding AccountNumber}" Width="100" IsReadOnly="True" />
                <DataGridTextColumn Header="Company" Binding="{Binding CompanyName}" Width="*" IsReadOnly="True" />
                <DataGridTextColumn Header="Site" Binding="{Binding SiteName}" Width="160" IsReadOnly="True" />
                <DataGridTextColumn Header="Net KG" Binding="{Binding NetWeightKg, StringFormat='{}{0:N2}'}" Width="100" IsReadOnly="True" />
                <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat='{}{0:N2}'}" Width="100" IsReadOnly="True" />
                <DataGridTextColumn Header="Total excl VAT" Binding="{Binding TotalExclVat, StringFormat='{}{0:N2}'}" Width="120" IsReadOnly="True" />
                <DataGridTextColumn Header="VAT" Binding="{Binding VatAmount, StringFormat='{}{0:N2}'}" Width="100" IsReadOnly="True" />
                <DataGridTextColumn Header="Total incl VAT" Binding="{Binding TotalInclVat, StringFormat='{}{0:N2}'}" Width="130" IsReadOnly="True" />
                <DataGridTextColumn Header="Created" Binding="{Binding CreatedTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="150" IsReadOnly="True" />
                <DataGridTemplateColumn Header="" Width="140">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <Button
                            Classes="row-action"
                            Content="Edit"
                            Command="{Binding DataContext.EditTicketCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}" />
                        <Button
                            Classes="row-action"
                            Content="Delete"
                            Command="{Binding DataContext.DeleteReceivingTicketCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}" />
                      </StackPanel>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
          </StackPanel>
        </Border>

        <!-- SELECTED TICKET DETAILS + LINES -->
        <Border Background="{StaticResource Brush.PanelBackground}" 
                Padding="12" 
                CornerRadius="4" 
                Margin="0,8,0,0"
                IsVisible="{Binding HasSelectedReceivingTicket}">
          <StackPanel Spacing="12">
            
            <!-- Ticket Details Header -->
            <TextBlock Text="Ticket Details"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       FontSize="13"
                       FontWeight="Bold" />

            <!-- Ticket Details Grid (3 columns) -->
            <Grid IsVisible="{Binding SelectedReceivingTicketDetails, Converter={x:Static ObjectConverters.IsNotNull}}">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <!-- Row 0 -->
              <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                <TextBlock Text="Ticket Number" Foreground="#c0c4cf" FontSize="13" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedReceivingTicketDetails.TicketNumber}" Foreground="#f5f5f5" FontSize="11" />
              </StackPanel>
              <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                <TextBlock Text="Ticket Type" Foreground="#c0c4cf" FontSize="13" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedReceivingTicketDetails.TicketType}" Foreground="#f5f5f5" FontSize="11" />
              </StackPanel>
              <StackPanel Grid.Row="0" Grid.Column="2" Spacing="2">
                <TextBlock Text="Customer ID" Foreground="#c0c4cf" FontSize="13" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedReceivingTicketDetails.CustomerId, StringFormat='{}{0:D8}'}" Foreground="#f5f5f5" FontSize="11" />
              </StackPanel>

              <!-- Row 1 -->
              <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2" Margin="0,8,0,0">
                <TextBlock Text="Vehicle Registration" Foreground="#c0c4cf" FontSize="13" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedReceivingTicketDetails.VehicleRegistration}" Foreground="#f5f5f5" FontSize="11" />
              </StackPanel>
              <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2" Margin="0,8,0,0">
                <TextBlock Text="OFM Weighbridge Ticket" Foreground="#c0c4cf" FontSize="13" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedReceivingTicketDetails.OfmWeighbridgeTicket}" Foreground="#f5f5f5" FontSize="11" />
              </StackPanel>
              <StackPanel Grid.Row="1" Grid.Column="2" Spacing="2" Margin="0,8,0,0">
                <TextBlock Text="Foreign Ticket" Foreground="#c0c4cf" FontSize="13" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedReceivingTicketDetails.ForeignTicket}" Foreground="#f5f5f5" FontSize="11" />
              </StackPanel>

              <!-- Row 2 -->
              <StackPanel Grid.Row="2" Grid.Column="0" Spacing="2" Margin="0,8,0,0">
                <TextBlock Text="First Weight (kg)" Foreground="#c0c4cf" FontSize="13" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedReceivingTicketDetails.FirstWeightKg, StringFormat='{}{0:N2}'}" Foreground="#f5f5f5" FontSize="11" />
              </StackPanel>
              <StackPanel Grid.Row="2" Grid.Column="1" Spacing="2" Margin="0,8,0,0">
                <TextBlock Text="Second Weight (kg)" Foreground="#c0c4cf" FontSize="13" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedReceivingTicketDetails.SecondWeightKg, StringFormat='{}{0:N2}'}" Foreground="#f5f5f5" FontSize="11" />
              </StackPanel>
              <StackPanel Grid.Row="2" Grid.Column="2" Spacing="2" Margin="0,8,0,0">
                <TextBlock Text="Net Weight (kg)" Foreground="#c0c4cf" FontSize="13" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedReceivingTicketDetails.NetWeightKg, StringFormat='{}{0:N2}'}" 
                           Foreground="#4a9eff" 
                           FontWeight="Bold" 
                           FontSize="13" />
              </StackPanel>

              <!-- Row 3 -->
              <StackPanel Grid.Row="3" Grid.Column="0" Spacing="2" Margin="0,8,0,0">
                <TextBlock Text="Unit Price /kg" Foreground="#c0c4cf" FontSize="13" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedReceivingTicketDetails.UnitPricePerKg, StringFormat='{}{0:N2}'}" Foreground="#f5f5f5" FontSize="11" />
              </StackPanel>
              <StackPanel Grid.Row="3" Grid.Column="1" Spacing="2" Margin="0,8,0,0">
              </StackPanel>
              <StackPanel Grid.Row="3" Grid.Column="2" Spacing="2" Margin="0,8,0,0">
                <TextBlock Text="Currency" Foreground="#c0c4cf" FontSize="13" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedReceivingTicketDetails.CurrencyCode}" Foreground="#f5f5f5" FontSize="11" />
              </StackPanel>

              <!-- Row 4 -->
              <StackPanel Grid.Row="4" Grid.Column="0" Spacing="2" Margin="0,8,0,0">
                <TextBlock Text="Total (ex VAT)" Foreground="#c0c4cf" FontSize="13" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedReceivingTicketDetails.TotalAmount, StringFormat='{}{0:N2}'}" Foreground="#f5f5f5" FontSize="11" />
              </StackPanel>
              <StackPanel Grid.Row="4" Grid.Column="1" Spacing="2" Margin="0,8,0,0">
                <TextBlock Text="VAT Amount" Foreground="#c0c4cf" FontSize="13" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedReceivingTicketDetails.VatAmount, StringFormat='{}{0:N2}'}" Foreground="#f5f5f5" FontSize="11" />
              </StackPanel>
              <StackPanel Grid.Row="4" Grid.Column="2" Spacing="2" Margin="0,8,0,0">
                <TextBlock Text="Total (incl VAT)" Foreground="#c0c4cf" FontSize="13" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedReceivingTicketDetails.TotalInclVat, StringFormat='{}{0:N2}'}" 
                           Foreground="#4a9eff" 
                           FontWeight="Bold" 
                           FontSize="13" />
              </StackPanel>
            </Grid>

            <!-- Ticket Lines -->
            <StackPanel Spacing="8" Margin="0,8,0,0">
              <TextBlock Text="Ticket Line Items"
                         Foreground="{StaticResource Brush.TextPrimary}"
                         FontSize="13"
                         FontWeight="Bold" />

              <DataGrid
                  AutoGenerateColumns="False"
                  ItemsSource="{Binding SelectedReceivingTicketLines}"
                  HeadersVisibility="Column"
                  MaxHeight="250">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*" />
                  <DataGridTextColumn Header="Weight (kg)" Binding="{Binding WeightKg, StringFormat='{}{0:N2}'}" Width="120" />
                  <DataGridTextColumn Header="Unit Price /kg" Binding="{Binding UnitPricePerKg, StringFormat='{}{0:N2}'}" Width="130" />
                  <DataGridTextColumn Header="Line Total (ex VAT)" Binding="{Binding LineTotal, StringFormat='{}{0:N2}'}" Width="150" />
                  <DataGridTextColumn Header="VAT" Binding="{Binding VatAmount, StringFormat='{}{0:N2}'}" Width="100" />
                  <DataGridTextColumn Header="Total (incl VAT)" Binding="{Binding TotalInclVat, StringFormat='{}{0:N2}'}" Width="140" />
                  <DataGridTemplateColumn Header="" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                          <Button
                              Classes="row-action"
                              Content="Edit"
                              Command="{Binding DataContext.EditTicketLineCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                              CommandParameter="{Binding}" />
                          <Button
                              Classes="row-action"
                              Content="Delete"
                              Command="{Binding DataContext.DeleteTicketLineCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                              CommandParameter="{Binding}" />
                        </StackPanel>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                </DataGrid.Columns>
              </DataGrid>

              <!-- Empty state -->
              <TextBlock Text="No line items for this ticket."
                         Foreground="#c0c4cf"
                         FontStyle="Italic"
                         Margin="8"
                         IsVisible="{Binding !SelectedTicketLines.Count}" />

              <!-- Edit Line Item Panel -->
              <Border Background="#1f2937"
                      BorderBrush="#4b5563"
                      BorderThickness="1"
                      Padding="12"
                      CornerRadius="4"
                      Margin="0,8,0,0"
                      IsVisible="{Binding IsEditingTicketLine}">
                <StackPanel Spacing="8">
                  <TextBlock Text="Edit Line Item"
                             Foreground="{StaticResource Brush.TextPrimary}"
                             FontSize="13"
                             FontWeight="Bold" />
                  
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Product Search -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                      <TextBlock Text="Product Search" Foreground="#c0c4cf" />
                      <TextBox Text="{Binding EditLineProductSearchText, UpdateSourceTrigger=PropertyChanged}" 
                               Watermark="Search products..." />
                    </StackPanel>

                    <!-- Product Letter + Dropdown -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                      <TextBlock Text="Product" Foreground="#c0c4cf" />
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="80" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding ProductLetterFilters}"
                                  SelectedItem="{Binding EditLineSelectedProductLetter}"
                                  Margin="0,0,4,0" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding EditLineProductSuggestions}"
                                  SelectedItem="{Binding EditLineSelectedProduct}">
                          <ComboBox.ItemTemplate>
                            <DataTemplate>
                              <TextBlock Text="{Binding ProductName}" />
                            </DataTemplate>
                          </ComboBox.ItemTemplate>
                        </ComboBox>
                      </Grid>
                    </StackPanel>

                    <!-- Weight -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2" Margin="0,8,0,0">
                      <TextBlock Text="Weight (kg)" Foreground="#c0c4cf" />
                      <TextBox Text="{Binding EditLineWeightText}" 
                               Watermark="Enter weight..." />
                    </StackPanel>
                  </Grid>

                  <!-- Action Buttons -->
                  <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="Cancel" 
                            Command="{Binding CancelEditTicketLineCommand}" 
                            Width="100" />
                    <Button Content="Save Changes" 
                            Command="{Binding SaveEditedTicketLineCommand}" 
                            Width="120" 
                            Classes="primary" />
                  </StackPanel>
                </StackPanel>
              </Border>

              <!-- Totals Summary for Selected Ticket Lines -->
              <StackPanel Orientation="Vertical"
                          HorizontalAlignment="Right"
                          Spacing="8"
                          Margin="0,8,0,0"
                          IsVisible="{Binding SelectedTicketLines.Count}">
                <StackPanel Orientation="Horizontal" Spacing="16">
                  <StackPanel Spacing="2">
                    <TextBlock Text="Total ex VAT"
                               Foreground="#c0c4cf"
                               FontSize="11" />
                    <TextBlock Text="{Binding SelectedReceivingTicketLinesTotalExVat, StringFormat='{}{0:N2}'}"
                               Foreground="#4a9eff"
                               FontWeight="Bold" />
                  </StackPanel>
                  <StackPanel Spacing="2">
                    <TextBlock Text="VAT"
                               Foreground="#c0c4cf"
                               FontSize="11" />
                    <TextBlock Text="{Binding SelectedReceivingTicketLinesTotalVat, StringFormat='{}{0:N2}'}"
                               Foreground="#4a9eff"
                               FontWeight="Bold" />
                  </StackPanel>
                  <StackPanel Spacing="2">
                    <TextBlock Text="Total incl VAT"
                               Foreground="#c0c4cf"
                               FontSize="11" />
                    <TextBlock Text="{Binding SelectedReceivingTicketLinesTotalInclVat, StringFormat='{}{0:N2}'}"
                               Foreground="#4a9eff"
                               FontWeight="Bold" />
                  </StackPanel>
                </StackPanel>
              </StackPanel>
            </StackPanel>

          </StackPanel>
        </Border>

        <!-- CREATE / EDIT TICKET -->
        <Border Background="{StaticResource Brush.PanelBackground}" Padding="12" CornerRadius="4">
          <StackPanel Spacing="12">
            
            <!-- Header -->
            <TextBlock Text="Create / Edit Ticket"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       FontSize="13"
                       FontWeight="Bold" />

            <!-- Ticket Form - 2 Column Grid -->
            <Grid Margin="0,8,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <!-- Row 0: Customer ID / Ticket Number (auto-generated, read-only) -->
              <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                <TextBlock Text="Customer ID" Foreground="#c0c4cf" />
                <TextBox Text="{Binding TicketCustomerIdText}" IsReadOnly="True" />
              </StackPanel>
              <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                <TextBlock Text="Ticket Number" Foreground="#c0c4cf" />
                <TextBox Text="{Binding TicketNumber}" IsReadOnly="True" />
              </StackPanel>

              <!-- Row 1: Ticket Type / [blank] -->
              <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2">
                <TextBlock Text="Ticket Type" Foreground="#c0c4cf" />
                <ComboBox
                    ItemsSource="{Binding TicketTypeOptions}"
                    SelectedItem="{Binding SelectedTicketTypeOption}"
                    HorizontalAlignment="Stretch">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Display}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>

              <!-- Row 2: Product Search Text / Product Letter + Dropdown -->
              <StackPanel Grid.Row="2" Grid.Column="0" Spacing="2" IsEnabled="{Binding IsProductSelectionEnabled}">
                <TextBlock Text="Product Search" Foreground="#c0c4cf" />
                <TextBox Text="{Binding TicketProductSearchText}" Watermark="Search products..." />
              </StackPanel>
              <StackPanel Grid.Row="2" Grid.Column="1" Spacing="2" IsEnabled="{Binding IsProductSelectionEnabled}">
                <TextBlock Text="Product" Foreground="#c0c4cf" />
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <ComboBox Grid.Column="0"
                            ItemsSource="{Binding ProductLetterFilters}"
                            SelectedItem="{Binding SelectedTicketProductLetter}"
                            Margin="0,0,4,0" />
                  <ComboBox Grid.Column="1"
                            ItemsSource="{Binding TicketProductSuggestions}"
                            SelectedItem="{Binding SelectedTicketProduct}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding ProductName}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </Grid>
              </StackPanel>

              <!-- Row 3: First + Second Weight (same column) / Unit Price (auto, read-only) -->
              <StackPanel Grid.Row="3" Grid.Column="0" Spacing="4" IsEnabled="{Binding AreWeightsEnabled}">
                <StackPanel Spacing="2">
                  <TextBlock Text="First Weight (kg)" Foreground="#c0c4cf" />
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBox Text="{Binding TicketFirstWeightText}" Width="150" />
                    <Button Content="Read Weight" Command="{Binding ReadWeighbridgeCommand}" />
                  </StackPanel>
                </StackPanel>
                <StackPanel Spacing="2">
                  <TextBlock Text="Second Weight (kg)" Foreground="#c0c4cf" />
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBox Text="{Binding TicketSecondWeightText}" Width="150" />
                    <Button Content="Read Weight" Command="{Binding ReadPlatformCommand}" />
                  </StackPanel>
                </StackPanel>
              </StackPanel>
              <StackPanel Grid.Row="3" Grid.Column="1" Spacing="2">
                <TextBlock Text="Unit Price /kg (auto)" Foreground="#c0c4cf" />
                <TextBox Text="{Binding TicketUnitPriceText}" IsReadOnly="True" />
              </StackPanel>

              <!-- Row 4: Currency Dropdown / Vehicle Registration -->
              <StackPanel Grid.Row="4" Grid.Column="0" Spacing="2">
                <TextBlock Text="Currency" Foreground="#c0c4cf" />
                <ComboBox
                    ItemsSource="{Binding CurrencyOptions}"
                    SelectedItem="{Binding SelectedCurrency}"
                    HorizontalAlignment="Stretch">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>
              <StackPanel Grid.Row="4" Grid.Column="1" Spacing="2" IsEnabled="{Binding AreVehicleFieldsEnabled}">
                <TextBlock Text="Vehicle Registration" Foreground="#c0c4cf" />
                <TextBox Text="{Binding TicketVehicleRegistration}" />
              </StackPanel>

              <!-- Row 5: Trailer Registration / Driver Name -->
              <StackPanel Grid.Row="5" Grid.Column="0" Spacing="2" IsEnabled="{Binding AreVehicleFieldsEnabled}">
                <TextBlock Text="Trailer Registration" Foreground="#c0c4cf" />
                <TextBox Text="{Binding TicketTrailerRegistration}" />
              </StackPanel>
              <StackPanel Grid.Row="5" Grid.Column="1" Spacing="2" IsEnabled="{Binding AreVehicleFieldsEnabled}">
                <TextBlock Text="Driver Name" Foreground="#c0c4cf" />
                <TextBox Text="{Binding TicketDriverName}" />
              </StackPanel>

              <!-- Row 6: OFM Ticket / Foreign Ticket -->
              <StackPanel Grid.Row="6" Grid.Column="0" Spacing="2" IsEnabled="{Binding AreVehicleFieldsEnabled}">
                <TextBlock Text="OFM Weighbridge Ticket" Foreground="#c0c4cf" />
                <TextBox Text="{Binding TicketOfmWeighbridgeTicket}" />
              </StackPanel>
              <StackPanel Grid.Row="6" Grid.Column="1" Spacing="2">
                <TextBlock Text="Foreign Ticket" Foreground="#c0c4cf" />
                <TextBox Text="{Binding TicketForeignTicket}" />
              </StackPanel>
              
              <!-- Row 7: CK Number / Delivery Number -->
              <StackPanel Grid.Row="7" Grid.Column="0" Spacing="2">
                <TextBlock Text="CK Number" Foreground="#c0c4cf" />
                <TextBox Text="{Binding TicketCkNumber}" />
              </StackPanel>
              <StackPanel Grid.Row="7" Grid.Column="1" Spacing="2">
                <TextBlock Text="Delivery Number" Foreground="#c0c4cf" />
                <TextBox Text="{Binding TicketDeliveryNumber}" />
              </StackPanel>
            </Grid>

            <!-- Notes (full width) -->
            <StackPanel Spacing="2" Margin="0,8,0,0">
              <TextBlock Text="Notes" Foreground="#c0c4cf" />
              <TextBox
                  Text="{Binding TicketNotes}"
                  AcceptsReturn="True"
                  TextWrapping="Wrap"
                  Height="80" />
            </StackPanel>

            <!-- Validation messages -->
            <TextBlock
                Text="Customer ID and Ticket Number are required."
                Foreground="#ff8888"
                FontSize="11"
                IsVisible="{Binding IsTicketCustomerIdInvalid}" />
            <TextBlock
                Text="Unit price is required and must be numeric."
                Foreground="#ff8888"
                FontSize="11"
                IsVisible="{Binding IsTicketUnitPriceInvalid}" />

            <!-- Action buttons -->
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
              <Button Content="Clear" Command="{Binding ClearTicketCommand}" Width="120" />
              <Button Content="{Binding CreateOrUpdateButtonText}" Command="{Binding ScrollToAddLinesCommand}" Width="150" />
            </StackPanel>

            <!-- Last created summary -->
            <Border Background="#1f2229" Padding="8" CornerRadius="4" Margin="0,8,0,0">
              <TextBlock
                  Text="{Binding LastCreatedTicketSummary}"
                  Foreground="#c0c4cf"
                  TextWrapping="Wrap" />
            </Border>

          </StackPanel>
        </Border>

        <!-- ADD PRODUCT LINES -->
        <Border x:Name="AddProductLinesSection" Background="{StaticResource Brush.PanelBackground}" Padding="12" CornerRadius="4">
          <StackPanel Spacing="8">
            <TextBlock Text="Add Product Lines"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       FontSize="13"
                       FontWeight="Bold" />

            <!-- Product Selection Controls -->
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <!-- Row 0: Product Search / Product Letter + Dropdown -->
              <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                <TextBlock Text="Product Search" Foreground="#c0c4cf" />
                <TextBox Text="{Binding ReceivingProductSearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Watermark="Search products..." />
              </StackPanel>
              <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                <TextBlock Text="Product" Foreground="#c0c4cf" />
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <ComboBox Grid.Column="0"
                            ItemsSource="{Binding ProductLetterFilters}"
                            SelectedItem="{Binding SelectedReceivingProductLetter}"
                            Margin="0,0,4,0" />
                  <ComboBox Grid.Column="1"
                            ItemsSource="{Binding ReceivingProductSuggestions}"
                            SelectedItem="{Binding ReceivingSelectedProduct}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding ProductName}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </Grid>
              </StackPanel>

              <!-- Row 1: Weight -->
              <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2" Margin="0,8,0,0">
                <TextBlock Text="Weight (kg)" Foreground="#c0c4cf" />
                <TextBox Text="{Binding ReceivingWeightText}" 
                         Watermark="Enter weight..." />
              </StackPanel>

              <!-- Row 2: Add Line Button -->
              <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,12,0,0">
                <Button Content="Add Line"
                        Command="{Binding AddLineCommand}"
                        HorizontalAlignment="Left"
                        Width="150" />
              </StackPanel>
            </Grid>

                <DataGrid AutoGenerateColumns="False"
                          ItemsSource="{Binding ReceivingLines}"
                          HeadersVisibility="Column"
                          Margin="0,8,0,0"
                          Height="200">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Product"
                                        Binding="{Binding ProductName}"
                                        Width="*" />
                    <DataGridTextColumn Header="Weight (kg)"
                                        Binding="{Binding WeightKg, StringFormat='{}{0:N2}'}"
                                        Width="120" />
                    <DataGridTextColumn Header="Unit Price /kg"
                                        Binding="{Binding UnitPricePerKg, StringFormat='{}{0:N2}'}"
                                        Width="140" />
                    <DataGridTextColumn Header="Amount ex VAT"
                                        Binding="{Binding LineTotal, StringFormat='{}{0:N2}'}"
                                        Width="140" />
                    <DataGridTextColumn Header="VAT (15%)"
                                        Binding="{Binding VatAmount, StringFormat='{}{0:N2}'}"
                                        Width="120" />
                    <DataGridTextColumn Header="Amount incl VAT"
                                        Binding="{Binding TotalInclVat, StringFormat='{}{0:N2}'}"
                                        Width="150" />
                    <DataGridTemplateColumn Header="" Width="90">
                      <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                          <Button
                            Classes="row-action"
                            Content="Delete"
                            Padding="6,2"
                            Command="{Binding DataContext.RemoveReceivingLineCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}" />
                        </DataTemplate>
                      </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                  </DataGrid.Columns>
                </DataGrid>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="16">
                  <StackPanel Spacing="2">
                    <TextBlock Text="Total ex VAT"
                               Foreground="#c0c4cf"
                               FontSize="11" />
                    <TextBlock Text="{Binding ReceivingTotalExclVat, StringFormat='{}{0:N2}'}"
                               Foreground="#f5f5f5"
                               FontWeight="Bold" />
                  </StackPanel>
                  <StackPanel Spacing="2">
                    <TextBlock Text="VAT"
                               Foreground="#c0c4cf"
                               FontSize="11" />
                    <TextBlock Text="{Binding ReceivingTotalVat, StringFormat='{}{0:N2}'}"
                               Foreground="#f5f5f5"
                               FontWeight="Bold" />
                  </StackPanel>
                  <StackPanel Spacing="2">
                    <TextBlock Text="Total incl VAT"
                               Foreground="#c0c4cf"
                               FontSize="11" />
                    <TextBlock Text="{Binding ReceivingTotalInclVat, StringFormat='{}{0:N2}'}"
                               Foreground="#f5f5f5"
                               FontWeight="Bold" />
                  </StackPanel>
                </StackPanel>

                <!-- Create Ticket Button -->
                <Button Content="Create Ticket"
                        Command="{Binding CreateTicketCommand}"
                        HorizontalAlignment="Left"
                        Width="150"
                        Margin="0,12,0,0" />
          </StackPanel>
        </Border>

        <!-- TICKET REPORT (PDF) -->
        <Border Background="{StaticResource Brush.PanelBackground}" Padding="12" CornerRadius="4">
          <StackPanel Spacing="8">
            <TextBlock Text="Ticket Report (PDF)"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       FontSize="13"
                       FontWeight="Bold" />

            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="Ticket ID:"
                         Width="100"
                         VerticalAlignment="Center"
                         Foreground="#c0c4cf" />
              <TextBox Text="{Binding TicketReportTicketIdText}"
                       Width="120" />
              <Button Content="Download Ticket PDF"
                      Width="170"
                      Command="{Binding DownloadTicketReportCommand}" />
            </StackPanel>

            <TextBlock Text="Last Ticket PDF Path:"
                       FontWeight="Bold"
                       Foreground="#c0c4cf"
                       Margin="0,10,0,0" />
            <TextBlock Text="{Binding LastTicketReportPath}"
                       TextWrapping="Wrap"
                       Foreground="#e5e7eb" />
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>
  </Border>
</UserControl>
