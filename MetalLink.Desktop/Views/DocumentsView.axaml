<UserControl
    x:Class="MetalLink.Desktop.Views.DocumentsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <UserControl.Styles>
    <Style Selector="TextBox">
      <Setter Property="BorderBrush" Value="#444a55" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="TextBox:focus">
      <Setter Property="BorderBrush" Value="#5c7cfa" />
    </Style>

    <!-- <Style Selector="#DocsCustomerIdBox">
      <Setter Property="BorderBrush" Value="#444a55" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsDocumentsCustomerIdInvalid}" Value="True">
          <Setter Property="BorderBrush" Value="#ff5555" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style Selector="#NewDocTypeBox">
      <Setter Property="BorderBrush" Value="#444a55" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsNewDocumentTypeInvalid}" Value="True">
          <Setter Property="BorderBrush" Value="#ff5555" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style Selector="#NewDocPathBox">
      <Setter Property="BorderBrush" Value="#444a55" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsNewDocumentFilePathInvalid}" Value="True">
          <Setter Property="BorderBrush" Value="#ff5555" />
        </DataTrigger>
      </Style.Triggers>
    </Style> -->
  </UserControl.Styles>

  <Border Background="#1f2229" Padding="16">
    <ScrollViewer>
      <StackPanel Spacing="16">

        <TextBlock
            Text="Customer Documents"
            FontSize="22"
            FontWeight="Bold"
            Foreground="#f5f5f5" />

        <!-- Load docs -->
        <Border Background="#252932" Padding="12" CornerRadius="4">
          <StackPanel Spacing="8">
            <TextBlock Text="Load documents for customer" Foreground="#f5f5f5" FontWeight="Bold" />

            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBox
                  x:Name="DocsCustomerIdBox"
                  Width="150"
                  Watermark="Customer ID"
                  Text="{Binding DocumentsCustomerIdText}" />
              <Button
                  Content="Load Documents"
                  Command="{Binding LoadCustomerDocumentsCommand}" />
            </StackPanel>

            <TextBlock
                Text="Customer ID must be a valid numeric ID."
                Foreground="#ff8888"
                FontSize="11"
                IsVisible="{Binding IsDocumentsCustomerIdInvalid}" />

            <TextBox
                Text="{Binding DocumentsSummary}"
                AcceptsReturn="True"
                TextWrapping="Wrap"
                Height="160"
                IsReadOnly="True" />
          </StackPanel>
        </Border>

        <!-- Upload docs -->
        <Border Background="#252932" Padding="12" CornerRadius="4">
          <StackPanel Spacing="8">
            <TextBlock Text="Upload new document" Foreground="#f5f5f5" FontWeight="Bold" />

            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBox
                  x:Name="NewDocTypeBox"
                  Width="200"
                  Watermark="Document type (e.g. id_front)"
                  Text="{Binding NewDocumentType}" />
              <TextBox
                  x:Name="NewDocPathBox"
                  Width="320"
                  Watermark="File path"
                  Text="{Binding NewDocumentFilePath}" />
            </StackPanel>

            <StackPanel Spacing="2">
              <TextBlock
                  Text="Document type is required."
                  Foreground="#ff8888"
                  FontSize="11"
                  IsVisible="{Binding IsNewDocumentTypeInvalid}" />
              <TextBlock
                  Text="File path is required."
                  Foreground="#ff8888"
                  FontSize="11"
                  IsVisible="{Binding IsNewDocumentFilePathInvalid}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
              <Button
                  Content="Upload"
                  Command="{Binding UploadCustomerDocumentCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>

      <!-- Signature Capture (Signature Pad → Customer Document) -->
      <Border Background="#252932"
              Padding="12"
              CornerRadius="4"
              Margin="0,12,0,0">
        <StackPanel Spacing="6">

          <TextBlock Text="Signature Capture (Pad → Customer Document)"
                     FontSize="14"
                     FontWeight="Bold"
                     Foreground="#f5f5f5" />

          <TextBlock Text="Uses the same Customer ID as above."
                     Foreground="#c0c4cf"
                     FontSize="12" />
          <TextBlock Text="Make sure 'Customer ID' is filled before capturing."
                     Foreground="#c0c4cf"
                     FontSize="11"
                     FontStyle="Italic" />

          <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
            <Button Content="Capture Signature (Pad)"
                    Width="200"
                    Command="{Binding CaptureSignatureCommand}" />
          </StackPanel>

          <TextBlock Text="Last Signature Capture:"
                     FontWeight="Bold"
                     Margin="0,10,0,0"
                     Foreground="#c0c4cf" />
          <TextBlock Text="{Binding LastSignatureCaptureSummary}"
                     TextWrapping="Wrap"
                     Foreground="#c0c4cf"
                     FontSize="11" />

        </StackPanel>
      </Border>

      </StackPanel>
    </ScrollViewer>
  </Border>
</UserControl>
