<UserControl
    x:Class="MetalLink.Desktop.Views.TicketsSendingView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    DataContext="{Binding Sending}"
    xmlns:local="using:MetalLink.Desktop.Views"
    xmlns:Primitives="clr-namespace:Avalonia.Controls.Primitives;assembly=Avalonia.Controls.DataGrid">

  <UserControl.Resources>
    <ResourceDictionary>
      <!-- Custom DataGridRow template with shimmer overlay (selected row emphasis) -->
      <ControlTheme x:Key="ShimmerDataGridRowTheme" TargetType="DataGridRow">
      <Setter Property="Template">
        <ControlTemplate>
          <Grid>
            <!-- Base row background -->
            <Border x:Name="RowBackground"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}" />

            <!-- Shimmer overlay (animated when selected) -->
            <Border x:Name="Shimmer"
                    Opacity="0"
                    IsHitTestVisible="False">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                  <GradientStop Color="#00FFFFFF" Offset="0" />
                  <GradientStop Color="#33FFFFFF" Offset="0.45" />
                  <GradientStop Color="#66B0E0FF" Offset="0.50" />
                  <GradientStop Color="#33FFFFFF" Offset="0.55" />
                  <GradientStop Color="#00FFFFFF" Offset="1" />
                </LinearGradientBrush>
              </Border.Background>
              <Border.RenderTransform>
                <TranslateTransform X="-400" />
              </Border.RenderTransform>
            </Border>

            <!-- Cells presenter -->
            <Primitives:DataGridCellsPresenter />
          </Grid>
        </ControlTemplate>
      </Setter>
    </ControlTheme>
    </ResourceDictionary>
  </UserControl.Resources>

  <UserControl.Styles>

    <!-- Default textbox border + font to match Customers view -->
    <Style Selector="TextBox">
      <Setter Property="BorderBrush" Value="#444a55" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontSize" Value="11" />
    </Style>

    <Style Selector="TextBox:focus">
      <Setter Property="BorderBrush" Value="#5c7cfa" />
    </Style>

    <!-- Make ComboBox look/size similar to TextBox -->
    <Style Selector="ComboBox">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="BorderBrush" Value="#444a55" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontSize" Value="11" />
    </Style>

    <Style Selector="ComboBox:focus">
      <Setter Property="BorderBrush" Value="#5c7cfa" />
    </Style>

    <!-- DataGrid overall styling to match Customers grid -->
    <Style Selector="DataGrid">
      <Setter Property="Background" Value="{DynamicResource Brush.PanelBackground}" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
      <Setter Property="GridLinesVisibility" Value="Horizontal" />
      <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="DataGridCell">
      <Setter Property="FontSize" Value="11" />
    </Style>

    <Style Selector="DataGridColumnHeader">
      <Setter Property="Background" Value="{DynamicResource Brush.NavBackground}" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <!-- Animate the actual row background presenter (template Border) for the tickets grid -->
    <Style Selector="DataGrid#SendingTicketsGrid /template/ DataGridRow /template/ Border">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.45" />
          <DoubleTransition Property="Opacity" Duration="0:0:0.45" />
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="DataGrid#SendingTicketsGrid /template/ DataGridRow:pointerover /template/ Border">
      <Setter Property="Background" Value="#20FFFFFF" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="DataGrid#SendingTicketsGrid /template/ DataGridRow:selected /template/ Border">
      <!-- Selected row emphasis -->
      <Setter Property="Background" Value="#334155" />
    </Style>

    <!-- Animate the selected row background so it visibly "breathes" -->
    <Style Selector="DataGrid#SendingTicketsGrid /template/ DataGridRow:selected">
      <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- Keep selection solid; animated effects are unreliable with current DataGrid template -->
    <!-- Use our shimmer row theme for the tickets grid -->
    <Style Selector="DataGrid#SendingTicketsGrid /template/ DataGridRow">
      <Setter Property="Theme" Value="{StaticResource ShimmerDataGridRowTheme}" />
    </Style>

    <!-- Selected row base color -->
    <Style Selector="DataGrid#SendingTicketsGrid /template/ DataGridRow:selected">
      <Setter Property="Background" Value="#334155" />
    </Style>

    <!-- Shimmer animation when selected -->
    <Style Selector="DataGrid#SendingTicketsGrid /template/ DataGridRow:selected /template/ Border#Shimmer">
      <Setter Property="Opacity" Value="0.75" />
      <Style.Animations>
        <Animation Duration="0:0:2.6" IterationCount="Infinite">
          <KeyFrame Cue="0%">
            <Setter Property="RenderTransform">
              <TranslateTransform X="-400" />
            </Setter>
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="RenderTransform">
              <TranslateTransform X="400" />
            </Setter>
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- Non-selected: shimmer hidden -->
    <Style Selector="DataGrid#SendingTicketsGrid /template/ DataGridRow:not(:selected) /template/ Border#Shimmer">
      <Setter Property="Opacity" Value="0" />
    </Style>

    <!-- Row action buttons (for Delete in Sending lines grid) -->
    <Style Selector="Button.row-action">
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
      <Setter Property="Background" Value="#30333A" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="Padding" Value="6,2" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
      <Setter Property="RenderTransform">
        <Setter.Value>
          <ScaleTransform ScaleX="1" ScaleY="1" />
        </Setter.Value>
      </Setter>
      <Setter Property="Transitions">
        <Setter.Value>
          <Transitions>
            <BrushTransition Property="Background" Duration="0:0:0.10" />
            <BrushTransition Property="BorderBrush" Duration="0:0:0.10" />
          </Transitions>
        </Setter.Value>
      </Setter>
    </Style>

    <Style Selector="Button.row-action:pointerover">
      <Setter Property="Background" Value="#3A4150" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.AccentGradient}" />
    </Style>

    <Style Selector="Button.row-action:pressed">
      <Setter Property="RenderTransform">
        <Setter.Value>
          <ScaleTransform ScaleX="0.97" ScaleY="0.97" />
        </Setter.Value>
      </Setter>
    </Style>

    <Style Selector="Button.row-action:disabled">
      <Setter Property="Background" Value="#2A2D34" />
      <Setter Property="Foreground" Value="#80838C" />
      <Setter Property="BorderBrush" Value="#3A3D45" />
    </Style>
  </UserControl.Styles>

  <UserControl.Resources>
    <DataTemplate x:Key="SendingProductLookupTemplate">
      <TextBlock Text="{Binding ProductName}" />
    </DataTemplate>
  </UserControl.Resources>

  <Grid>
    <Border Background="{DynamicResource Brush.MainBackground}">
      <Grid RowDefinitions="Auto,*">
        <!-- Sticky Header Panel -->
        <Border Grid.Row="0" 
                Background="{DynamicResource Brush.PanelBackground}"
                Padding="12,8"
                CornerRadius="4"
                Margin="16,16,16,8"
                ZIndex="100">
          <Image Source="avares://MetalLink.Desktop/Assets/sending_heading.png"
                 Height="40"
                 HorizontalAlignment="Left"
                 Stretch="Uniform" />
        </Border>
        
        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="1" x:Name="TicketsScrollViewer" Padding="16,8,16,16">
          <StackPanel Spacing="16">

        <!-- SEARCH TICKETS -->
        <Border Background="{DynamicResource Brush.PanelBackground}" Padding="12" CornerRadius="4">
          <StackPanel Spacing="8">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="▼" Foreground="{DynamicResource Brush.TextPrimary}" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" ToolTip.Tip="Click to collapse/expand" />
              <TextBlock Grid.Column="1" Text="Search Tickets" Foreground="{DynamicResource Brush.TextPrimary}" FontWeight="Bold" />
            </Grid>

            <CheckBox Content="New Buyer?" IsChecked="{Binding IsNewBuyerOnly}" />

            <Grid Margin="0,8,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <!-- Row 0: Buyer ID / ID Number -->
              <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                <TextBlock Text="Buyer ID" Foreground="#c0c4cf" />
                <TextBox Text="{Binding SearchSendingTicketBuyerIdText}" />
              </StackPanel>
              <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                <TextBlock Text="ID Number" Foreground="#c0c4cf" />
                <TextBox Text="{Binding SearchSendingTicketIdNumberText}" />
              </StackPanel>

              <!-- Row 1: First / Last name -->
              <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2">
                <TextBlock Text="First Name" Foreground="#c0c4cf" />
                <TextBox Text="{Binding SearchSendingTicketFirstNameText}" />
              </StackPanel>
              <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
                <TextBlock Text="Last Name" Foreground="#c0c4cf" />
                <TextBox Text="{Binding SearchSendingTicketLastNameText}" />
              </StackPanel>

              <!-- Row 2: Company (Letter + Dropdown in single column) / Account Number -->
              <StackPanel Grid.Row="2" Grid.Column="0" Spacing="2">
                <TextBlock Text="Company" Foreground="#c0c4cf" />
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="88" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <ComboBox Grid.Column="0"
                            ItemsSource="{Binding CompanyLetterFilters}"
                            SelectedItem="{Binding SearchTicketCompanyLetter}"
                            Margin="0,0,4,0" />
                  <ComboBox Grid.Column="1"
                            ItemsSource="{Binding SearchCompanySuggestions}"
                            SelectedItem="{Binding SelectedSearchCompany}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding CompanyName}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </Grid>
              </StackPanel>
              <StackPanel Grid.Row="2" Grid.Column="1" Spacing="2">
                <TextBlock Text="Account Number" Foreground="#c0c4cf" />
                <TextBox Text="{Binding SearchSendingTicketAccountNumberText}" />
              </StackPanel>

              <!-- Row 3: Site / Ticket Number -->
              <StackPanel Grid.Row="3" Grid.Column="0" Spacing="2">
                <TextBlock Text="Site" Foreground="#c0c4cf" />
                <ComboBox
                    ItemsSource="{Binding SearchTicketSiteSuggestions}"
                    SelectedItem="{Binding SelectedSearchSite}"
                    HorizontalAlignment="Stretch">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding SiteName}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>
              <StackPanel Grid.Row="3" Grid.Column="1" Spacing="2">
                <TextBlock Text="Ticket Number" Foreground="#c0c4cf" />
                <TextBox Text="{Binding SearchSendingTicketNumberText}" />
              </StackPanel>
            </Grid>

            <!-- Search buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8"
                        Margin="0,8,0,0">
              <Button
                  Width="100"
                  Content="Clear"
                  Command="{Binding ClearSendingTicketSearchCommand}" />
              <Button
                  Classes="primary"
                  Width="100"
                  Content="Search"
                  Command="{Binding SearchSendingTicketsCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- TICKET RESULTS -->
        <Grid Margin="0,8,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding ResultsMainColumnWidth}" />
            <ColumnDefinition Width="{Binding ResultsSpacerColumnWidth}" />
          </Grid.ColumnDefinitions>

          <Border Grid.Column="0" Background="{DynamicResource Brush.PanelBackground}" Padding="12" CornerRadius="4">
            <StackPanel Spacing="8">
            <TextBlock Text="Ticket results"
                       Foreground="{DynamicResource Brush.TextPrimary}"
                       FontWeight="Bold" />

            <DataGrid x:Name="SendingTicketsGrid"
                AutoGenerateColumns="False"
                ItemsSource="{Binding SendingTicketSearchResults}"
                SelectedItem="{Binding SelectedSendingTicket, Mode=TwoWay}"
                SelectionChanged="SendingTicketsGrid_SelectionChanged">
              <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding TicketId}" Width="80" IsReadOnly="True" IsVisible="{Binding DataContext.ShouldShowTicketColumns, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                <DataGridTextColumn Header="Ticket #" Binding="{Binding TicketNumber}" Width="140" IsReadOnly="True" IsVisible="{Binding DataContext.ShouldShowTicketColumns, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                <DataGridTextColumn Header="Buyer ID" Binding="{Binding BuyerId}" Width="100" IsReadOnly="True" />
                <DataGridTextColumn Header="First Name" Binding="{Binding FirstName}" Width="120" IsReadOnly="True" />
                <DataGridTextColumn Header="Last Name" Binding="{Binding LastName}" Width="120" IsReadOnly="True" />
                <DataGridTextColumn Header="Account #" Binding="{Binding AccountNumber}" Width="100" IsReadOnly="True" />
                <DataGridTextColumn Header="Company" Binding="{Binding CompanyName}" Width="*" IsReadOnly="True" />
                <DataGridTextColumn Header="Site" Binding="{Binding SiteName}" Width="160" IsReadOnly="True" />
                <DataGridTextColumn Header="Net KG" Binding="{Binding NetWeightKg, StringFormat='{}{0:N2}'}" Width="100" IsReadOnly="True" IsVisible="{Binding DataContext.ShouldShowTicketColumns, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                <DataGridTextColumn Header="Created" Binding="{Binding CreatedTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="150" IsReadOnly="True" IsVisible="{Binding DataContext.ShouldShowTicketColumns, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                <DataGridTemplateColumn Header="Status" Width="100" IsVisible="{Binding DataContext.ShouldShowTicketColumns, RelativeSource={RelativeSource AncestorType=UserControl}}">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <Ellipse Width="16"
                               Height="16"
                               Fill="{Binding TicketStatus, Converter={x:Static local:TicketStatusColorConverter.Instance}}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
            </StackPanel>
          </Border>

          <!-- Spacer column (used to make results 60% width in New Buyer mode) -->
          <Border Grid.Column="1" Background="Transparent" />
        </Grid>

        <!-- SELECTED TICKET DETAILS + LINES -->
        <Border Background="{DynamicResource Brush.PanelBackground}"
                Padding="12"
                CornerRadius="4"
                Margin="0,8,0,0"
                IsVisible="{Binding ShouldShowTicketDetails}">
          <StackPanel Spacing="12">
            
            <!-- Ticket Details Header -->
            <Grid RowDefinitions="Auto,*">
              <TextBlock Text="Ticket Details"
                         Foreground="{DynamicResource Brush.TextPrimary}"
                         FontSize="13"
                         FontWeight="Bold" />

              <Button DockPanel.Dock="Right"
                      Content="Distribution"
                      Command="{Binding OpenDistributionCommand}"
                      Classes="primary"
                      Width="140"
                      HorizontalAlignment="Right" />
            </Grid>

            <!-- Ticket Details Grid - Different layouts for Platform vs Weighbridge (match Receiving) -->
            <Grid IsVisible="{Binding SelectedSendingTicketDetails, Converter={x:Static local:ObjectConverters.IsNotNull}}">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <!-- Row 0: Ticket Number and Buyer ID (both ticket types) -->
              <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                <TextBlock Text="Ticket Number" Foreground="#c0c4cf" FontSize="13" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedSendingTicketDetails.TicketNumber}" Foreground="#f5f5f5" FontSize="11" />
              </StackPanel>
              <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                <TextBlock Text="Buyer ID" Foreground="#c0c4cf" FontSize="13" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedSendingTicketDetails.CustomerId, StringFormat='{}{0:D8}'}" Foreground="#f5f5f5" FontSize="11" />
              </StackPanel>

              <!-- WEIGHBRIDGE TICKET (TicketTypeId=1) - Row 1: Vehicle Registration / Trailer Registration -->
              <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2" Margin="0,8,0,0"
                          IsVisible="{Binding SelectedSendingTicketDetails.TicketTypeId, Converter={x:Static local:NumberEqualsConverter.Instance}, ConverterParameter=1}">
                <TextBlock Text="Vehicle Registration" Foreground="#c0c4cf" FontSize="13" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedSendingTicketDetails.VehicleRegistration}" Foreground="#f5f5f5" FontSize="11" />
              </StackPanel>
              <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2" Margin="0,8,0,0"
                          IsVisible="{Binding SelectedSendingTicketDetails.TicketTypeId, Converter={x:Static local:NumberEqualsConverter.Instance}, ConverterParameter=1}">
                <TextBlock Text="Trailer Registration" Foreground="#c0c4cf" FontSize="13" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedSendingTicketDetails.TrailerRegistration}" Foreground="#f5f5f5" FontSize="11" />
              </StackPanel>

              <!-- WEIGHBRIDGE TICKET (TicketTypeId=1) - Row 2: Driver Name / OFM Weighbridge Ticket -->
              <StackPanel Grid.Row="2" Grid.Column="0" Spacing="2" Margin="0,8,0,0"
                          IsVisible="{Binding SelectedSendingTicketDetails.TicketTypeId, Converter={x:Static local:NumberEqualsConverter.Instance}, ConverterParameter=1}">
                <TextBlock Text="Driver Name" Foreground="#c0c4cf" FontSize="13" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedSendingTicketDetails.DriverName}" Foreground="#f5f5f5" FontSize="11" />
              </StackPanel>
              <StackPanel Grid.Row="2" Grid.Column="1" Spacing="2" Margin="0,8,0,0"
                          IsVisible="{Binding SelectedSendingTicketDetails.TicketTypeId, Converter={x:Static local:NumberEqualsConverter.Instance}, ConverterParameter=1}">
                <TextBlock Text="OFM Weighbridge Ticket" Foreground="#c0c4cf" FontSize="13" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedSendingTicketDetails.OfmWeighbridgeTicket}" Foreground="#f5f5f5" FontSize="11" />
              </StackPanel>

              <!-- WEIGHBRIDGE TICKET (TicketTypeId=1) - Row 3: Delivery Number / Foreign Ticket -->
              <StackPanel Grid.Row="3" Grid.Column="0" Spacing="2" Margin="0,8,0,0"
                          IsVisible="{Binding SelectedSendingTicketDetails.TicketTypeId, Converter={x:Static local:NumberEqualsConverter.Instance}, ConverterParameter=1}">
                <TextBlock Text="Delivery Number" Foreground="#c0c4cf" FontSize="13" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedSendingTicketDetails.DeliveryNumber}" Foreground="#f5f5f5" FontSize="11" />
              </StackPanel>
              <StackPanel Grid.Row="3" Grid.Column="1" Spacing="2" Margin="0,8,0,0"
                          IsVisible="{Binding SelectedSendingTicketDetails.TicketTypeId, Converter={x:Static local:NumberEqualsConverter.Instance}, ConverterParameter=1}">
                <TextBlock Text="Foreign Ticket" Foreground="#c0c4cf" FontSize="13" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedSendingTicketDetails.ForeignTicket}" Foreground="#f5f5f5" FontSize="11" />
              </StackPanel>

              <!-- WEIGHBRIDGE TICKET (TicketTypeId=1) - Row 4: CK Number -->
              <StackPanel Grid.Row="4" Grid.Column="0" Spacing="2" Margin="0,8,0,0"
                          IsVisible="{Binding SelectedSendingTicketDetails.TicketTypeId, Converter={x:Static local:NumberEqualsConverter.Instance}, ConverterParameter=1}">
                <TextBlock Text="CK Number" Foreground="#c0c4cf" FontSize="13" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedSendingTicketDetails.CkNumber}" Foreground="#f5f5f5" FontSize="11" />
              </StackPanel>

              <!-- WEIGHBRIDGE TICKET (TicketTypeId=1) - Row 5: Notes -->
              <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Spacing="2" Margin="0,8,0,0"
                          IsVisible="{Binding SelectedSendingTicketDetails.TicketTypeId, Converter={x:Static local:NumberEqualsConverter.Instance}, ConverterParameter=1}">
                <TextBlock Text="Notes" Foreground="#c0c4cf" FontSize="13" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedSendingTicketDetails.Notes}" Foreground="#f5f5f5" FontSize="11" TextWrapping="Wrap" />
              </StackPanel>

              <!-- WEIGHBRIDGE TICKET (TicketTypeId=1) - Row 6: Net Weight (in Blue) -->
              <StackPanel Grid.Row="6" Grid.Column="0" Spacing="2" Margin="0,8,0,0"
                          IsVisible="{Binding SelectedSendingTicketDetails.TicketTypeId, Converter={x:Static local:NumberEqualsConverter.Instance}, ConverterParameter=1}">
                <TextBlock Text="Net Weight (kg)" Foreground="#c0c4cf" FontSize="13" FontWeight="Bold" />
                <TextBlock Text="{Binding CalculatedNetWeightKg, StringFormat='{}{0:N2}'}"
                           Foreground="#4a9eff"
                           FontWeight="Bold"
                           FontSize="13" />
              </StackPanel>
            </Grid>

            <!-- Ticket Lines -->
            <StackPanel Spacing="8" Margin="0,8,0,0">
              <TextBlock Text="Ticket Line Items"
                         Foreground="{DynamicResource Brush.TextPrimary}"
                         FontSize="13"
                         FontWeight="Bold" />

              <DataGrid
                AutoGenerateColumns="False"
                ItemsSource="{Binding SelectedSendingTicketLinesWithTotals}"
                HeadersVisibility="Column"
                MaxHeight="250">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*" />
                  <DataGridTextColumn Header="Weight (kg)" Binding="{Binding NetWeightKg, StringFormat='{}{0:N2}'}"
                                      Width="140" />
                  <DataGridTextColumn Header="Tare (kg)" Binding="{Binding Tare, StringFormat='{}{0:N2}'}" Width="100" IsReadOnly="True" />
                  <DataGridTextColumn Header="Unit Price /kg" Binding="{Binding UnitPricePerKg, StringFormat='{}{0:N2}'}" Width="140" />
                  <DataGridTextColumn Header="Total (ex VAT)" Binding="{Binding LineTotal, StringFormat='{}{0:N2}'}" Width="140" />
                  <DataGridTextColumn Header="VAT (15%)" Binding="{Binding VatAmount, StringFormat='{}{0:N2}'}" Width="140" />
                  <DataGridTextColumn Header="Total (incl VAT)" Binding="{Binding TotalInclVat, StringFormat='{}{0:N2}'}" Width="140" />
                  <DataGridTemplateColumn Header="Actions" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <Button Content="Notes"
                                HorizontalAlignment="Center"
                                HorizontalContentAlignment="Center"
                                Command="{Binding $parent[DataGrid].DataContext.ShowLineNotesCommand}"
                                CommandParameter="{Binding Notes}"
                                IsEnabled="{Binding Notes, Converter={x:Static local:HasNotesConverter.Instance}}"
                                Classes="row-action"
                                Padding="4,2"
                                FontSize="10" />
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                </DataGrid.Columns>
              </DataGrid>

              <!-- Totals Summary (2 columns, 3 rows) -->
              <Grid ColumnDefinitions="160,90" RowDefinitions="Auto,Auto,Auto" Width="250" HorizontalAlignment="Left"
                    Margin="0,8,0,0" IsVisible="{Binding SelectedSendingTicketLines.Count}">
                <TextBlock Grid.Column="0" Grid.Row="0" Text="Total (ex VAT)" Foreground="#4a9eff" FontWeight="Bold" FontSize="13" />
                <TextBlock Grid.Column="1" Grid.Row="0"
                           Text="{Binding SelectedSendingTicketLinesTotalExVat, StringFormat='{}{0:N2}'}"
                           Foreground="#4a9eff" FontWeight="Bold" FontSize="13" TextAlignment="Right" Margin="0,0,8,0" />

                <TextBlock Grid.Column="0" Grid.Row="1" Text="VAT (15%)" Foreground="#4a9eff" FontWeight="Bold" FontSize="13" />
                <TextBlock Grid.Column="1" Grid.Row="1"
                           Text="{Binding SelectedSendingTicketLinesTotalVat, StringFormat='{}{0:N2}'}"
                           Foreground="#4a9eff" FontWeight="Bold" FontSize="13" TextAlignment="Right" Margin="0,0,8,0" />

                <TextBlock Grid.Column="0" Grid.Row="2" Text="Total (incl VAT)" Foreground="#4a9eff" FontWeight="Bold" FontSize="13" />
                <TextBlock Grid.Column="1" Grid.Row="2"
                           Text="{Binding SelectedSendingTicketLinesTotalInclVat, StringFormat='{}{0:N2}'}"
                           Foreground="#4a9eff" FontWeight="Bold" FontSize="13" TextAlignment="Right" Margin="0,0,8,0" />
              </Grid>

              <!-- Empty state -->
              <TextBlock Text="No line items for this ticket."
                         Foreground="#c0c4cf"
                         FontStyle="Italic"
                         Margin="8"
                         IsVisible="{Binding SelectedSendingTicketLines.Count, Converter={x:Static local:NumberEqualsConverter.Instance}, ConverterParameter=0}" />

              <!-- Edit Line Item Panel -->
              <Border Background="{DynamicResource Brush.GlassPanel}"
                      BorderBrush="{DynamicResource Brush.GlassBorder}"
                      BorderThickness="1"
                      Padding="12"
                      CornerRadius="4"
                      Margin="0,8,0,0"
                      IsVisible="{Binding IsEditingTicketLine}">
                <StackPanel Spacing="8">
                  <TextBlock Text="Edit Line Item"
                             Foreground="{DynamicResource Brush.TextPrimary}"
                             FontSize="13"
                             FontWeight="Bold" />
                  
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Product Search -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                      <TextBlock Text="Product Search" Foreground="#c0c4cf" />
                      <TextBox Text="{Binding EditLineProductSearchText, UpdateSourceTrigger=PropertyChanged}" 
                               Watermark="Search products..." />
                    </StackPanel>

                    <!-- Product Letter + Dropdown -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                      <TextBlock Text="Product" Foreground="#c0c4cf" />
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="88" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding ProductLetterFilters}"
                                  SelectedItem="{Binding EditLineSelectedProductLetter}"
                                  Margin="0,0,4,0" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding EditLineProductSuggestions}"
                                  SelectedItem="{Binding EditLineSelectedProduct}">
                          <ComboBox.ItemTemplate>
                            <DataTemplate>
                              <TextBlock Text="{Binding ProductName}" />
                            </DataTemplate>
                          </ComboBox.ItemTemplate>
                        </ComboBox>
                      </Grid>
                    </StackPanel>

                    <!-- Weight -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2" Margin="0,8,0,0">
                      <TextBlock Text="Weight (kg)" Foreground="#c0c4cf" />
                      <TextBox Text="{Binding EditLineWeightText}" 
                               Watermark="Enter weight..." />
                    </StackPanel>
                  </Grid>

                  <!-- Action Buttons -->
                  <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="Cancel" 
 
                            Width="100" />
                    <Button Content="Save Changes" 
 
                            Width="120" 
                            Classes="primary" />
                  </StackPanel>
                </StackPanel>
              </Border>

              <!-- Totals Summary for Selected Ticket Lines -->
              <StackPanel Orientation="Vertical"
                          HorizontalAlignment="Right"
                          Spacing="8"
                          Margin="0,8,0,0"
                          IsVisible="{Binding SelectedSendingTicketLines.Count}">
              </StackPanel>
            </StackPanel>

          </StackPanel>
        </Border>

        <!-- CREATE / EDIT TICKET -->
        <Border Background="{DynamicResource Brush.PanelBackground}" Padding="12" CornerRadius="4">
          <StackPanel Spacing="12">

            <!-- Header -->
            <TextBlock Text="Create Ticket"
                       Foreground="{DynamicResource Brush.TextPrimary}"
                       FontSize="13"
                       FontWeight="Bold" />
            <TextBlock Text="{Binding CreateTicketModeText}"
                       IsVisible="{Binding IsCreateTicketModeVisible}"
                       Foreground="#c0c4cf"
                       FontSize="12" />

            <!-- Ticket Form - 2 Column Grid -->
            <Grid Margin="0,8,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <!-- Row 0: Buyer ID / Ticket Number (auto-generated, read-only) -->
              <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                <TextBlock Text="Buyer ID" Foreground="#c0c4cf" />
                <TextBox Text="{Binding TicketBuyerIdText}" IsReadOnly="True" />
              </StackPanel>
              <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                <TextBlock Text="Ticket Number" Foreground="#c0c4cf" />
                <TextBox Text="{Binding TicketNumber}" IsReadOnly="True" />
              </StackPanel>

              <!-- Row 1: Ticket Type / [blank] -->
              <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2">
                <TextBlock Text="Ticket Type" Foreground="#c0c4cf" />
                <ComboBox
                  ItemsSource="{Binding TicketTypeOptions}"
                  SelectedItem="{Binding SelectedTicketTypeOption, Mode=TwoWay}"
                  IsEnabled="{Binding IsTicketTypeEnabled}"
                  HorizontalAlignment="Left"
                  Width="200">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Display}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>

              <!-- Row 2: Vehicle Registration / Trailer Registration -->
              <StackPanel Grid.Row="2" Grid.Column="0" Spacing="2" IsVisible="{Binding AreWeighbridgeFieldsVisible}">
                <TextBlock Text="Vehicle Registration" Foreground="#c0c4cf" />
                <TextBox Text="{Binding TicketVehicleRegistration}" />
              </StackPanel>
              <StackPanel Grid.Row="2" Grid.Column="1" Spacing="2" IsVisible="{Binding AreWeighbridgeFieldsVisible}">
                <TextBlock Text="Trailer Registration" Foreground="#c0c4cf" />
                <TextBox Text="{Binding TicketTrailerRegistration}" />
              </StackPanel>

              <!-- Row 3: Driver Name / OFM Ticket -->
              <StackPanel Grid.Row="3" Grid.Column="0" Spacing="2" IsVisible="{Binding AreWeighbridgeFieldsVisible}">
                <TextBlock Text="Driver Name" Foreground="#c0c4cf" />
                <TextBox Text="{Binding TicketDriverName}" />
              </StackPanel>
              <StackPanel Grid.Row="3" Grid.Column="1" Spacing="2" IsVisible="{Binding AreWeighbridgeFieldsVisible}">
                <TextBlock Text="OFM Weighbridge Ticket" Foreground="#c0c4cf" />
                <TextBox Text="{Binding TicketOfmWeighbridgeTicket}" />
              </StackPanel>

              <!-- Row 4: Delivery Number / Foreign Ticket -->
              <StackPanel Grid.Row="4" Grid.Column="0" Spacing="2" IsVisible="{Binding AreWeighbridgeFieldsVisible}">
                <TextBlock Text="Delivery Number" Foreground="#c0c4cf" />
                <TextBox Text="{Binding TicketDeliveryNumber}" />
              </StackPanel>
              <StackPanel Grid.Row="4" Grid.Column="1" Spacing="2" IsVisible="{Binding AreWeighbridgeFieldsVisible}">
                <TextBlock Text="Foreign Ticket" Foreground="#c0c4cf" />
                <TextBox Text="{Binding TicketForeignTicket}" />
              </StackPanel>

              <!-- Row 5: CK Number -->
              <StackPanel Grid.Row="5" Grid.Column="0" Spacing="2" IsVisible="{Binding AreWeighbridgeFieldsVisible}">
                <TextBlock Text="CK Number" Foreground="#c0c4cf" />
                <TextBox Text="{Binding TicketCkNumber}" />
              </StackPanel>
            </Grid>

            <!-- Notes (full width) -->
            <StackPanel Spacing="2" Margin="0,8,0,0">
              <TextBlock Text="Notes" Foreground="#c0c4cf" />
              <TextBox
                Text="{Binding TicketNotes}"
                AcceptsReturn="True"
                TextWrapping="Wrap"
                Height="80" />
            </StackPanel>

          </StackPanel>
        </Border>

        <!-- SCALE MEASUREMENT -->
        <Border Background="{DynamicResource Brush.PanelBackground}" Padding="12" CornerRadius="4">
          <StackPanel Spacing="8">
            <TextBlock Text="Scale Measurement"
                       Foreground="{DynamicResource Brush.TextPrimary}"
                       FontSize="13"
                       FontWeight="Bold" />

            <!-- WEIGHBRIDGE: First Weight at Top -->
            <StackPanel Spacing="2" IsVisible="{Binding AreWeighbridgeFieldsVisible}">
              <TextBlock Text="First Weight (kg)" Foreground="#c0c4cf" />
              <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBox Text="{Binding TicketFirstWeightText}" Width="150" IsReadOnly="True" IsEnabled="{Binding IsFirstWeightEnabled}" />
                <Button Content="Read Weight" Command="{Binding ReadWeighbridgeCommand}"
                        IsEnabled="{Binding IsFirstWeightEnabled}" />
                <Button Content="Reset" Command="{Binding ResetWeighbridgeWeightsCommand}"
                        IsEnabled="{Binding IsFirstWeightEnabled}" />
              </StackPanel>
            </StackPanel>

            <!-- WEIGHBRIDGE: Second Weight -->
            <StackPanel Spacing="2" IsVisible="{Binding AreWeighbridgeFieldsVisible}">
              <TextBlock Text="Second Weight (kg)" Foreground="#c0c4cf" />
              <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBox Text="{Binding TicketSecondWeightText}" Width="150" IsReadOnly="True" IsEnabled="{Binding IsSecondWeightEnabled}" />
                <Button Content="Read Weight" Command="{Binding ReadWeighbridgeSecondCommand}"
                        IsEnabled="{Binding IsSecondWeightEnabled}" />
                <Button Content="Reset" Command="{Binding ResetWeighbridgeWeightsCommand}"
                        IsEnabled="{Binding IsSecondWeightEnabled}" />
              </StackPanel>
            </StackPanel>

            <!-- Create Header Button (when state is C - creating new ticket) -->
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0"
                        IsVisible="{Binding CreateHeaderButtonVisible}">
              <Button Content="Create Header" Command="{Binding CreateSendingTicketHeaderCommand}" Width="150"
                      Classes="primary" HorizontalContentAlignment="Center" />
            </StackPanel>

            <!-- Save and Reset Button (when state is H or M - working on incomplete ticket) -->
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0"
                        IsVisible="{Binding SaveResetButtonVisible}">
              <Button Content="Save &amp; Reset" Command="{Binding CreateSendingTicketHeaderCommand}" Width="150"
                      Classes="primary" HorizontalContentAlignment="Center" />
            </StackPanel>

            <!-- PLATFORM: Platform Weight at Bottom -->
            <StackPanel Spacing="2" IsVisible="{Binding ArePlatformFieldsVisible}" Margin="0,8,0,0">
              <TextBlock Text="Platform Weight (kg)" Foreground="#c0c4cf" />
              <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBox Text="{Binding TicketPlatformWeightText}" Width="150" IsReadOnly="True" />
                <Button Content="Read Weight" Command="{Binding ReadPlatformCommand}" />
                <Button Content="Reset" Command="{Binding ResetPlatformWeightCommand}" />
              </StackPanel>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ADD PRODUCT LINES -->
        <Border x:Name="AddProductLinesSection" Background="{DynamicResource Brush.PanelBackground}" Padding="12"
                CornerRadius="4">
          <StackPanel Spacing="8">
            <TextBlock Text="Add Product Lines"
                       Foreground="{DynamicResource Brush.TextPrimary}"
                       FontSize="13"
                       FontWeight="Bold" />

            <!-- Product Selection Controls -->
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <!-- Row 0: Product Search / Product Letter + Dropdown -->
              <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                <TextBlock Text="Product Search" Foreground="#c0c4cf" />
                <TextBox Text="{Binding SendingProductSearchText, UpdateSourceTrigger=PropertyChanged}"
                         Watermark="Search products..." />
              </StackPanel>
              <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                <TextBlock Text="Product" Foreground="#c0c4cf" />
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="88" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <ComboBox Grid.Column="0"
                            ItemsSource="{Binding ProductLetterFilters}"
                            SelectedItem="{Binding SelectedSendingProductLetter}"
                            Margin="0,0,4,0" />
                  <ComboBox Grid.Column="1"
                            ItemsSource="{Binding SendingProductSuggestions}"
                            SelectedItem="{Binding SendingSelectedProduct}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding ProductName}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </Grid>
              </StackPanel>

              <!-- Row 1: Weight / Notes -->
              <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2" Margin="0,8,0,0">
                <TextBlock Text="Weight (kg)" Foreground="#c0c4cf" />
                <TextBox Text="{Binding SendingWeightText}"
                         Watermark="Enter weight..." />
              </StackPanel>
              <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2" Margin="0,8,0,0">
                <TextBlock Text="Notes" Foreground="#c0c4cf" />
                <TextBox Text="{Binding SendingLineNotes}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="60" />
              </StackPanel>

              <!-- Row 2: Add Line Button -->
              <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,12,0,0">
                <Button Content="Add Line"
                        Command="{Binding AddSendingLineToTicketCommand}"
                        IsEnabled="{Binding AddLineButtonEnabled}"
                        HorizontalAlignment="Left"
                        Width="150" />
              </StackPanel>
            </Grid>

            <!-- Net Weight Display - Shows sum of product lines (0.00 for new tickets with no lines) -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
              <TextBlock Text="Total Net Weight (kg)" Foreground="#c0c4cf" FontSize="13" FontWeight="Bold" />
              <TextBlock Text="{Binding CreatingTicketTotalWeight, StringFormat='{}{0:N2}'}"
                         Foreground="#4a9eff"
                         FontWeight="Bold"
                         FontSize="13" />
            </StackPanel>

            <DataGrid AutoGenerateColumns="False"
                      ItemsSource="{Binding SendingLinesWithTotals}"
                      HeadersVisibility="Column"
                      Margin="0,8,0,0"
                      Height="200">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Product"
                                    Binding="{Binding ProductName}"
                                    Width="*" />
                <!-- First Weight (FW) - Weighbridge only -->
                <DataGridTextColumn Header="First Weight (kg)"
                                    Binding="{Binding FirstWeightKg, StringFormat='{}{0:N2}'}"
                                    Width="140"
                                    IsVisible="{Binding AreWeighbridgeFieldsVisible}" />
                <!-- Second Weight (SW) - Weighbridge only -->
                <DataGridTextColumn Header="Second Weight (kg)"
                                    Binding="{Binding SecondWeightKg, StringFormat='{}{0:N2}'}"
                                    Width="140"
                                    IsVisible="{Binding AreWeighbridgeFieldsVisible}" />
                <DataGridTextColumn Header="Weight (kg)"
                                    Binding="{Binding DisplayWeightKg, StringFormat='{}{0:N2}'}"
                                    Width="140" />
                <DataGridTemplateColumn Header="Tare (kg)" Width="100">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <TextBox x:Name="TareTextBox"
                               Text="{Binding Tare, StringFormat='{}{0:N2}', Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                               IsEnabled="{Binding IsEditable}"
                               HorizontalAlignment="Stretch"
                               Foreground="{DynamicResource Brush.TextPrimary}"
                               Background="{DynamicResource Brush.GlassPanel}"
                               BorderBrush="{DynamicResource Brush.GlassBorder}"
                               BorderThickness="1"
                               Padding="4"
                               FontSize="11"
                               GotFocus="TareTextBox_GotFocus" LostFocus="TareTextBox_LostFocus" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Unit Price /kg"
                                    Binding="{Binding UnitPricePerKg, StringFormat='{}{0:N2}'}"
                                    Width="140" />
                <DataGridTextColumn Header="Total (ex VAT)"
                                    Binding="{Binding LineTotal, StringFormat='{}{0:N2}'}"
                                    Width="140" />
                <DataGridTextColumn Header="VAT (15%)"
                                    Binding="{Binding VatAmount, StringFormat='{}{0:N2}'}"
                                    Width="140" />
                <DataGridTextColumn Header="Total (incl VAT)"
                                    Binding="{Binding TotalInclVat, StringFormat='{}{0:N2}'}"
                                    Width="140" />
                <DataGridTemplateColumn Header="Actions" Width="180">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                        <Button Content="Notes"
                                HorizontalAlignment="Center"
                                HorizontalContentAlignment="Center"
                                Command="{Binding DataContext.ShowLineNotesCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding Notes}"
                                IsEnabled="{Binding Notes, Converter={x:Static local:HasNotesConverter.Instance}}"
                                Classes="row-action"
                                Padding="4,2"
                                FontSize="10"
                                Width="70" />
                        <Button
                          Classes="row-action"
                          Content="Delete"
                          HorizontalAlignment="Center"
                          Padding="4,2"
                          FontSize="10"
                          Width="70"
                          Command="{Binding DataContext.RemoveSendingLineCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}"
                          IsEnabled="{Binding IsEditable}"
                          IsVisible="{Binding IsEditable}" />
                      </StackPanel>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>

            <!-- Totals Summary (2 columns, 3 rows) -->
            <Grid ColumnDefinitions="160,90" RowDefinitions="Auto,Auto,Auto" Width="250" HorizontalAlignment="Left"
                  Margin="0,8,0,0" IsVisible="{Binding SendingLines.Count}">
              <TextBlock Grid.Column="0" Grid.Row="0" Text="Total (ex VAT)" Foreground="#4a9eff" FontWeight="Bold"
                         FontSize="13" />
              <TextBlock Grid.Column="1" Grid.Row="0"
                         Text="{Binding SendingTotalExclVat, StringFormat='{}{0:N2}'}" Foreground="#4a9eff"
                         FontWeight="Bold" FontSize="13"
                         TextAlignment="Right" Margin="0,0,8,0" />

              <TextBlock Grid.Column="0" Grid.Row="1" Text="VAT (15%)" Foreground="#4a9eff" FontWeight="Bold"
                         FontSize="13" />
              <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding SendingTotalVat, StringFormat='{}{0:N2}'}"
                         Foreground="#4a9eff" FontWeight="Bold" FontSize="13" TextAlignment="Right" Margin="0,0,8,0" />

              <TextBlock Grid.Column="0" Grid.Row="2" Text="Total (incl VAT)" Foreground="#4a9eff"
                         FontWeight="Bold" FontSize="13" />
              <TextBlock Grid.Column="1" Grid.Row="2"
                         Text="{Binding SendingTotalInclVat, StringFormat='{}{0:N2}'}" Foreground="#4a9eff"
                         FontWeight="Bold" FontSize="13"
                         TextAlignment="Right" Margin="0,0,8,0" />
            </Grid>

            <!-- Finalize Ticket Button -->
            <Button Content="Finalize Ticket"
                    Command="{Binding FinalizeSendingTicketCommand}"
                    HorizontalAlignment="Left"
                    Width="150"
                    Margin="0,12,0,0"
                    IsEnabled="{Binding IsFinalizeTicketEnabled}"
                    HorizontalContentAlignment="Center" />
          </StackPanel>
        </Border>

        <!-- TICKET REPORT (PDF) -->
        <Border Background="{DynamicResource Brush.PanelBackground}" Padding="12" CornerRadius="4">
          <StackPanel Spacing="8">
            <TextBlock Text="Ticket Report (PDF)"
                       Foreground="{DynamicResource Brush.TextPrimary}"
                       FontSize="13"
                       FontWeight="Bold" />

            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="Ticket ID:"
                         Width="100"
                         VerticalAlignment="Center"
                         Foreground="#c0c4cf" />
              <TextBox Text="{Binding TicketReportTicketIdText}"
                       Width="120" />
              <Button Content="Download Ticket PDF"
                      Width="170"
                      Command="{Binding DownloadTicketReportCommand}" />
            </StackPanel>

            <TextBlock Text="Last Ticket PDF Path:"
                       FontWeight="Bold"
                       Foreground="#c0c4cf"
                       Margin="0,10,0,0" />
            <TextBlock Text="{Binding LastTicketReportPath}"
                       TextWrapping="Wrap"
                       Foreground="#e5e7eb" />
          </StackPanel>
        </Border>

          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Border>

    <!-- Notes Modal (match Receiving) -->
    <Panel IsVisible="{Binding IsNotesModalVisible}">
    <Border Background="#80000000" />
    <Border Background="{DynamicResource Brush.GlassPanel}" BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Padding="16" CornerRadius="6"
            Width="500" HorizontalAlignment="Center" VerticalAlignment="Center">
      <StackPanel Spacing="12">
        <TextBlock Text="Line Notes" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Brush.TextPrimary}" />
        <TextBox Text="{Binding SelectedLineNotesContent}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 IsReadOnly="True"
                 Height="200" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
          <Button Content="Close" Command="{Binding CloseLineNotesCommand}" Width="100" />
        </StackPanel>
      </StackPanel>
    </Border>
    </Panel>
  </Grid>
</UserControl>
