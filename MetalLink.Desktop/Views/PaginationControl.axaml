<UserControl
    x:Class="MetalLink.Desktop.Views.PaginationControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

  <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8" Margin="0,12,0,0">
    <!-- Previous Button -->
    <Button
        Content="&lt; Previous"
        Command="{Binding PreviousPageCommand}"
        IsEnabled="{Binding CanGoPrevious}"
        Padding="8,4"
        FontSize="11" />

    <!-- Page Info -->
    <Border Background="#30333A" Padding="12,4" CornerRadius="3">
      <StackPanel Orientation="Horizontal" Spacing="4">
        <TextBlock Text="Page" Foreground="#c0c4cf" />
        <TextBlock Text="{Binding CurrentPage}" Foreground="#f5f5f5" FontWeight="Bold" />
        <TextBlock Text="of" Foreground="#c0c4cf" />
        <TextBlock Text="{Binding TotalPages}" Foreground="#f5f5f5" FontWeight="Bold" />
        <TextBlock Text="(" Foreground="#c0c4cf" />
        <TextBlock Text="{Binding TotalRecords}" Foreground="#f5f5f5" FontWeight="Bold" />
        <TextBlock Text="total)" Foreground="#c0c4cf" />
      </StackPanel>
    </Border>

    <!-- Next Button -->
    <Button
        Content="Next &gt;"
        Command="{Binding NextPageCommand}"
        IsEnabled="{Binding CanGoNext}"
        Padding="8,4"
        FontSize="11" />

    <!-- Records per page selector -->
    <Border Background="#30333A" Padding="8,4" CornerRadius="3" Margin="8,0,0,0">
      <StackPanel Orientation="Horizontal" Spacing="4">
        <TextBlock Text="Show:" Foreground="#c0c4cf" VerticalAlignment="Center" />
        <ComboBox
            ItemsSource="{Binding PageSizeOptions}"
            SelectedItem="{Binding PageSize}"
            Width="60"
            FontSize="11" />
        <TextBlock Text="per page" Foreground="#c0c4cf" VerticalAlignment="Center" />
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
