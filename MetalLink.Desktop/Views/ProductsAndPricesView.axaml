<UserControl
  x:Class="MetalLink.Desktop.Views.ProductsAndPricesView"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <UserControl.Resources>
    <DataTemplate x:Key="ProductLookupTemplate">
      <TextBlock Text="{Binding ProductName}" />
    </DataTemplate>
  </UserControl.Resources>

  <UserControl.Styles>
    <!-- Text inputs/dropdowns: match entity button text size -->
    <Style Selector="TextBox">
      <Setter Property="FontSize" Value="11" />
    </Style>

    <Style Selector="ComboBox">
      <Setter Property="FontSize" Value="11" />
    </Style>

    <!-- DataGrid font sizes: rows slightly smaller than headers -->
    <Style Selector="DataGrid">
      <Setter Property="Background" Value="{DynamicResource Brush.PanelBackground}" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
      <Setter Property="GridLinesVisibility" Value="Horizontal" />
      <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="DataGridCell">
      <Setter Property="FontSize" Value="11" />
    </Style>

    <Style Selector="DataGridColumnHeader">
      <Setter Property="Background" Value="{DynamicResource Brush.NavBackground}" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>
  </UserControl.Styles>

  <Border Background="{DynamicResource Brush.MainBackground}" Padding="16">
    
<StackPanel Spacing="16">

        <!-- Header with animated glow underline -->
  <StackPanel Spacing="4">
          <Grid>
            <TextBlock
                Text="Products &amp; Prices"
                FontSize="20"
                FontWeight="Bold"
                Foreground="#f5f5f5" />
            <!-- Animated glow overlay -->
            <TextBlock
                Text="Products &amp; Prices"
                FontSize="20"
                FontWeight="Bold"
                Foreground="#4a9eff"
                Opacity="0">
              <TextBlock.Styles>
                <Style Selector="TextBlock">
                  <Style.Animations>
                    <Animation Duration="0:0:5" IterationCount="INFINITE" Delay="0:0:0">
                      <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0" />
                      </KeyFrame>
                      <KeyFrame Cue="10%">
                        <Setter Property="Opacity" Value="0.8" />
                      </KeyFrame>
                      <KeyFrame Cue="30%">
                        <Setter Property="Opacity" Value="0.8" />
                      </KeyFrame>
                      <KeyFrame Cue="40%">
                        <Setter Property="Opacity" Value="0" />
                      </KeyFrame>
                      <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="0" />
                      </KeyFrame>
                    </Animation>
                  </Style.Animations>
                </Style>
              </TextBlock.Styles>
            </TextBlock>
          </Grid>
          <Border Height="2"
                  Margin="0,0,0,8"
                  CornerRadius="1">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                <LinearGradientBrush.GradientStops>
                  <GradientStop Color="#1E88E5" Offset="0" />
                  <GradientStop Color="#8EC5FC" Offset="0.5" />
                  <GradientStop Color="#1E88E5" Offset="1" />
                </LinearGradientBrush.GradientStops>
                <LinearGradientBrush.Transform>
                  <TranslateTransform X="-200">
                    <TranslateTransform.Transitions>
                      <Transitions />
                    </TranslateTransform.Transitions>
                  </TranslateTransform>
                </LinearGradientBrush.Transform>
              </LinearGradientBrush>
            </Border.Background>
            <Border.Styles>
              <Style Selector="Border">
                <Style.Animations>
                  <Animation Duration="0:0:5" IterationCount="INFINITE">
                    <KeyFrame Cue="0%">
                      <Setter Property="Opacity" Value="0.5" />
                    </KeyFrame>
                    <KeyFrame Cue="50%">
                      <Setter Property="Opacity" Value="1.0" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                      <Setter Property="Opacity" Value="0.5" />
                    </KeyFrame>
                  </Animation>
                </Style.Animations>
              </Style>
            </Border.Styles>
          </Border>
        </StackPanel>

        <!-- Search Products -->
        <Border Background="{DynamicResource Brush.GlassPanel}" BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Padding="12" CornerRadius="4">
    <StackPanel Spacing="10">
            <TextBlock Text="Search product" Foreground="#f5f5f5" FontWeight="Bold" />

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
              <StackPanel Grid.Column="0" Spacing="6">
                <TextBlock Text="Product" Foreground="#c0c4cf" />
                <Grid ColumnDefinitions="70,*,*">
                  <ComboBox
                    Grid.Column="0"
                    ItemsSource="{Binding ProductLetterFilters}"
                    SelectedItem="{Binding SelectedProductLetter}" />

                  <ComboBox
                    Grid.Column="1"
                    Margin="4,0,0,0"
                    HorizontalAlignment="Stretch"
                    ItemsSource="{Binding SearchProductSuggestions}"
                    SelectedItem="{Binding SelectedSearchProduct}"
                    ItemTemplate="{StaticResource ProductLookupTemplate}" />
                </Grid>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Content="Search"
                          Command="{Binding SearchProductsCommand}"
                          HorizontalAlignment="Left"
                          Width="100" />
                </StackPanel>
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Product Results -->
        <Border Background="{DynamicResource Brush.GlassPanel}" BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Padding="12" CornerRadius="4">
    <StackPanel Spacing="8">
            <TextBlock Text="Results" Foreground="#f5f5f5" FontWeight="Bold" />

            <DataGrid
              AutoGenerateColumns="False"
              ItemsSource="{Binding ProductResults}"
              SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
              Height="220">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Product ID" Binding="{Binding ProductId}" IsReadOnly="True" Width="100" />
                <DataGridTextColumn Header="Product Code" Binding="{Binding ProductCode}" IsReadOnly="True" Width="120" />
                <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" IsReadOnly="True" Width="*" />
                <DataGridTextColumn Header="Gradient" Binding="{Binding Grade, StringFormat='{}{0:N2}'}" IsReadOnly="True" Width="150" />
                <DataGridTemplateColumn Header="" Width="160">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button
                          Content="Edit"
                          Padding="6,2"
                          Command="{Binding DataContext.EditProductCommand,
                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}" />

                        <Button
                          Content="Delete"
                          Padding="6,2"
                          Command="{Binding DataContext.DeleteProductCommand,
                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}" />
                      </StackPanel>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
          </StackPanel>
        </Border>

        <!-- Create/Edit Product -->
        <Border Background="{DynamicResource Brush.GlassPanel}" BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Padding="12" CornerRadius="4">
    <StackPanel Spacing="10">
            <TextBlock Text="Create/Edit Product" Foreground="#f5f5f5" FontWeight="Bold" />

            <Border Padding="12" Background="{DynamicResource Brush.MainBackground}" CornerRadius="8">
        <StackPanel Spacing="10">

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">

                  <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                    <TextBlock Text="Product code" Foreground="#c0c4cf" />
                    <TextBox
                      Watermark="Product code"
                      Text="{Binding ProductCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                  </StackPanel>

                  <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6">
                    <TextBlock Text="Product name" Foreground="#c0c4cf" />
                    <TextBox
                      Watermark="Product name"
                      Text="{Binding ProductName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                  </StackPanel>

                  <StackPanel Grid.Row="1" Grid.Column="0" Spacing="6">
                    <TextBlock Text="Gradient (optional)" Foreground="#c0c4cf" />
                    <TextBox
                      Watermark="Gradient"
                      Text="{Binding ProductGrade, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                  </StackPanel>

                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                  <Button Width="100"
                          HorizontalContentAlignment="Center"
                          Content="Clear"
                          Command="{Binding ClearProductFormCommand}" />

                  <Button Width="100"
                          HorizontalContentAlignment="Center"
                          Content="Create"
                          Command="{Binding CreateProductCommand}"
                          IsVisible="{Binding IsProductCreateMode}" />

                  <Button Width="100"
                          HorizontalContentAlignment="Center"
                          Content="Update"
                          Command="{Binding UpdateProductCommand}"
                          IsVisible="{Binding !IsProductCreateMode}" />
                </StackPanel>

              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <!-- Edit Price -->
        <Border Background="{DynamicResource Brush.GlassPanel}" BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Padding="12" CornerRadius="4">
    <StackPanel Spacing="10">
            <TextBlock Text="Edit Price" Foreground="#f5f5f5" FontWeight="Bold" />

            <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto" ColumnSpacing="10" RowSpacing="10">

              <!-- Row 0 -->
              <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                <TextBlock Text="Price A" Foreground="#c0c4cf" />
                <TextBox Text="{Binding PriceA, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
              </StackPanel>

              <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6">
                <TextBlock Text="Price B" Foreground="#c0c4cf" />
                <TextBox Text="{Binding PriceB, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
              </StackPanel>

              <StackPanel Grid.Row="0" Grid.Column="2" Spacing="6">
                <TextBlock Text="Price C" Foreground="#c0c4cf" />
                <TextBox Text="{Binding PriceC, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
              </StackPanel>

            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
              <Button Width="100"
                      HorizontalContentAlignment="Center"
                      Content="Update"
                      Command="{Binding UpdatePriceCommand}" />
            </StackPanel>

          </StackPanel>
        </Border>
      </StackPanel>
  </Border>
</UserControl>
