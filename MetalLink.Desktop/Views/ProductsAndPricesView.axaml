<UserControl
  x:Class="MetalLink.Desktop.Views.ProductsAndPricesView"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <UserControl.Resources>
    <DataTemplate x:Key="ProductLookupTemplate">
      <TextBlock Text="{Binding ProductName}" />
    </DataTemplate>
  </UserControl.Resources>

  <UserControl.Styles>
    <!-- Text inputs/dropdowns: match entity button text size -->
    <Style Selector="TextBox">
      <Setter Property="FontSize" Value="11" />
    </Style>

    <Style Selector="ComboBox">
      <Setter Property="FontSize" Value="11" />
    </Style>

    <!-- DataGrid font sizes: rows slightly smaller than headers -->
    <Style Selector="DataGrid">
      <Setter Property="Background" Value="{DynamicResource Brush.PanelBackground}" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
      <Setter Property="GridLinesVisibility" Value="Horizontal" />
      <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="DataGridCell">
      <Setter Property="FontSize" Value="11" />
    </Style>

    <Style Selector="DataGridColumnHeader">
      <Setter Property="Background" Value="{DynamicResource Brush.NavBackground}" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>
  </UserControl.Styles>

  <!-- Keep brushed aluminium visible behind; section blocks use Brush.PanelBackground -->
  <Border Background="{DynamicResource Brush.MainBackground}">
    <Grid RowDefinitions="Auto,*">
      <!-- Sticky Header Panel -->
      <Border Grid.Row="0" 
              Background="{DynamicResource Brush.PanelBackground}"
              Padding="12,8"
              CornerRadius="4"
              Margin="16,16,16,8"
              ZIndex="100">
        <Image Source="avares://MetalLink.Desktop/Assets/products_and_prices_heading.png"
               Height="40"
               HorizontalAlignment="Left"
               Stretch="Uniform" />
      </Border>
      
      <!-- Scrollable Content -->
      <ScrollViewer Grid.Row="1" Padding="16,8,16,16">
        <StackPanel Spacing="16">

        <!-- Search Products -->
        <Border Background="{DynamicResource Brush.GlassPanel}" BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Padding="12" CornerRadius="4">
    <StackPanel Spacing="10">
            <Grid PointerPressed="ToggleSearchCriteria" Cursor="Hand">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" 
                         Text="{Binding ProductsIsSearchCriteriaExpanded, Converter={StaticResource SectionToViewConverter}, ConverterParameter='arrow'}" 
                         Foreground="{DynamicResource Brush.TextPrimary}" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="Search product" Foreground="{DynamicResource Brush.TextPrimary}" FontWeight="Bold" />
            </Grid>

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" IsVisible="{Binding ProductsIsSearchCriteriaExpanded}">
              <StackPanel Grid.Column="0" Spacing="6">
                <TextBlock Text="Product" Foreground="{DynamicResource Brush.TextMuted}" />
                <Grid ColumnDefinitions="70,*,*">
                  <ComboBox
                    Grid.Column="0"
                    ItemsSource="{Binding ProductLetterFilters}"
                    SelectedItem="{Binding SelectedProductLetter}" />

                  <ComboBox
                    Grid.Column="1"
                    Margin="4,0,0,0"
                    HorizontalAlignment="Stretch"
                    ItemsSource="{Binding SearchProductSuggestions}"
                    SelectedItem="{Binding SelectedSearchProduct}"
                    ItemTemplate="{StaticResource ProductLookupTemplate}" />
                </Grid>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Content="Search"
                          Command="{Binding SearchProductsCommand}"
                          HorizontalAlignment="Left"
                          Width="100" />
                </StackPanel>
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Product Results -->
        <Border Background="{DynamicResource Brush.GlassPanel}" BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Padding="12" CornerRadius="4">
    <StackPanel Spacing="8">
            <Grid PointerPressed="ToggleSearchResults" Cursor="Hand">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" 
                         Text="{Binding ProductsIsSearchResultsExpanded, Converter={StaticResource SectionToViewConverter}, ConverterParameter='arrow'}" 
                         Foreground="{DynamicResource Brush.TextPrimary}" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="Results" Foreground="{DynamicResource Brush.TextPrimary}" FontWeight="Bold" />
            </Grid>

            <DataGrid
              AutoGenerateColumns="False"
              ItemsSource="{Binding ProductResults}"
              SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
              IsVisible="{Binding ProductsIsSearchResultsExpanded}"
              Height="220">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Product ID" Binding="{Binding ProductId}" IsReadOnly="True" Width="100" />
                <DataGridTextColumn Header="Product Code" Binding="{Binding ProductCode}" IsReadOnly="True" Width="120" />
                <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" IsReadOnly="True" Width="*" />
                <DataGridTextColumn Header="Gradient" Binding="{Binding Grade, StringFormat='{}{0:N2}'}" IsReadOnly="True" Width="150" />
                <DataGridTemplateColumn Header="" Width="160">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button
                          Content="Edit"
                          Padding="6,2"
                          Command="{Binding DataContext.EditProductCommand,
                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}" />

                        <Button
                          Content="Delete"
                          Padding="6,2"
                          Command="{Binding DataContext.DeleteProductCommand,
                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}" />
                      </StackPanel>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
          </StackPanel>
        </Border>

        <!-- Create/Edit Product -->
        <Border Background="{DynamicResource Brush.GlassPanel}" BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Padding="12" CornerRadius="4">
    <StackPanel Spacing="10">
            <Grid PointerPressed="ToggleCreateEdit" Cursor="Hand">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" 
                         Text="{Binding ProductsIsCreateEditExpanded, Converter={StaticResource SectionToViewConverter}, ConverterParameter='arrow'}" 
                         Foreground="{DynamicResource Brush.TextPrimary}" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="Create/Edit Product" Foreground="{DynamicResource Brush.TextPrimary}" FontWeight="Bold" />
            </Grid>

            <Border Padding="12" Background="{DynamicResource Brush.PanelBackground}" CornerRadius="8" IsVisible="{Binding ProductsIsCreateEditExpanded}">
        <StackPanel Spacing="10">

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">

                  <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                    <TextBlock Text="Product code" Foreground="{DynamicResource Brush.TextMuted}" />
                    <TextBox
                      Watermark="Product code"
                      Text="{Binding ProductCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                  </StackPanel>

                  <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6">
                    <TextBlock Text="Product name" Foreground="{DynamicResource Brush.TextMuted}" />
                    <TextBox
                      Watermark="Product name"
                      Text="{Binding ProductName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                  </StackPanel>

                  <StackPanel Grid.Row="1" Grid.Column="0" Spacing="6">
                    <TextBlock Text="Gradient (optional)" Foreground="{DynamicResource Brush.TextMuted}" />
                    <TextBox
                      Watermark="Gradient"
                      Text="{Binding ProductGrade, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                  </StackPanel>

                  <StackPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Margin="0,20,0,0">
                    <CheckBox Content="Must Declare" 
                              IsChecked="{Binding ProductMustDeclare, Mode=TwoWay}"
                              Foreground="{DynamicResource Brush.TextPrimary}" />
                  </StackPanel>

                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                  <Button Width="100"
                          HorizontalContentAlignment="Center"
                          Content="Clear"
                          Command="{Binding ClearProductFormCommand}" />

                  <Button Width="100"
                          HorizontalContentAlignment="Center"
                          Content="Create"
                          Command="{Binding CreateProductCommand}"
                          IsVisible="{Binding IsProductCreateMode}" />

                  <Button Width="100"
                          HorizontalContentAlignment="Center"
                          Content="Update"
                          Command="{Binding UpdateProductCommand}"
                          IsVisible="{Binding !IsProductCreateMode}" />
                </StackPanel>

              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <!-- Edit Price -->
        <Border Background="{DynamicResource Brush.GlassPanel}" BorderBrush="{DynamicResource Brush.GlassBorder}" BorderThickness="1" Padding="12" CornerRadius="4">
          <StackPanel Spacing="10">
            <Grid PointerPressed="ToggleEditPrice" Cursor="Hand">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" 
                         Text="{Binding ProductsIsDetailsExpanded, Converter={StaticResource SectionToViewConverter}, ConverterParameter='arrow'}" 
                         Foreground="{DynamicResource Brush.TextPrimary}" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="Edit Price" Foreground="{DynamicResource Brush.TextPrimary}" FontWeight="Bold" />
            </Grid>

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto" ColumnSpacing="10" RowSpacing="10" IsVisible="{Binding ProductsIsDetailsExpanded}">

              <!-- Price List Selection -->
              <StackPanel Grid.Column="0" Spacing="6">
                <TextBlock Text="Price List" Foreground="{DynamicResource Brush.TextMuted}" />
                <ComboBox ItemsSource="{Binding ProductPriceLists}"
                          SelectedItem="{Binding SelectedProductPriceList}"
                          HorizontalAlignment="Stretch">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding ProductPriceListName}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>

              <!-- Price Input -->
              <StackPanel Grid.Column="1" Spacing="6">
                <TextBlock Text="Current Price" Foreground="{DynamicResource Brush.TextMuted}" />
                <TextBox Text="{Binding CurrentPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
              </StackPanel>

            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
              <Button Width="100"
                      HorizontalContentAlignment="Center"
                      Content="Update"
                      Command="{Binding UpdatePriceCommand}" />
            </StackPanel>

          </StackPanel>
        </Border>
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Border>
</UserControl>
