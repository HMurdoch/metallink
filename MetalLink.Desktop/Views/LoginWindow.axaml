<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MetalLink.Desktop.ViewModels"
        x:Class="MetalLink.Desktop.Views.LoginWindow"
        x:DataType="vm:LoginViewModel"
        Width="420" Height="320"
        Title="Metal Link - Login"
        Background="{DynamicResource Brush.MetalBackground}">

  <Window.Styles>
    <!-- Match main app typography: labels slightly larger/bolder than field text -->
    <Style Selector="TextBox">
      <!-- Same as entity text boxes / grid rows -->
      <Setter Property="FontSize" Value="11" />
    </Style>

    <Style Selector="TextBlock.login-label">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>
  </Window.Styles>

  <!-- Login should always be crystal on brushed aluminium -->
  <Border Background="{DynamicResource Brush.GlassPanelCrystal}"
          BorderBrush="{DynamicResource Brush.GlassBorderCrystal}"
          BorderThickness="1"
          CornerRadius="16" Margin="18" Padding="18">
    <StackPanel Spacing="10">
    <!-- Header (clean, readable) -->
    <StackPanel Spacing="6" HorizontalAlignment="Center" Margin="0,0,0,8">
      <Image Source="avares://MetalLink.Desktop/Assets/metal_link_heading.png"
             Height="40"
             HorizontalAlignment="Center"
             Margin="0,0,0,2" />
      <TextBlock Text="Sign in" FontSize="12" Foreground="{DynamicResource Brush.TextMuted}" HorizontalAlignment="Center" />
      <Border Height="2" Width="160" Background="{DynamicResource Brush.AccentGradient}" Opacity="0.8" />
    </StackPanel>

    <TextBlock Classes="login-label" Text="Username" Foreground="{DynamicResource Brush.TextMuted}" />
    <TextBox Text="{Binding Username}"
             Background="#EEF1F5"
             Foreground="#111827"
             Padding="10,8"
             BorderBrush="#9CA3AF"
             BorderThickness="1"
             CornerRadius="8" />

    <TextBlock Classes="login-label" Text="Password" Foreground="{DynamicResource Brush.TextMuted}" />
    <Grid ColumnDefinitions="*,Auto">
        <TextBox x:Name="PasswordBox"
                 Grid.Column="0"
                 Padding="10,8"
                 BorderBrush="#9CA3AF"
                 BorderThickness="1"
                 CornerRadius="8"
                 Background="#EEF1F5"
                 Foreground="#111827" />
        <Button Grid.Column="1"
                x:Name="TogglePasswordButton"
                Margin="0,0,8,0"
                Width="32"
                Height="32"
                VerticalAlignment="Center"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                Classes="toggle-password-btn">
            <TextBlock x:Name="EyeIcon" Text="👁️" FontSize="16" />
        </Button>
    </Grid>

    <Button Content="Login"
            Classes="primary"
            HorizontalAlignment="Right"
            Width="100"
            Command="{Binding LoginCommand}" />

    <TextBlock Text="{Binding StatusMessage}"
               Foreground="Red"
               TextWrapping="Wrap" />
    </StackPanel>
  </Border>
</Window>
