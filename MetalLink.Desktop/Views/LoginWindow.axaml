<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MetalLink.Desktop.ViewModels"
        x:Class="MetalLink.Desktop.Views.LoginWindow"
        x:DataType="vm:LoginViewModel"
        Width="400" Height="260"
        Title="Metal Link - Login">

  <Window.Styles>
    <!-- Match main app typography: labels slightly larger/bolder than field text -->
    <Style Selector="TextBox">
      <!-- Same as entity text boxes / grid rows -->
      <Setter Property="FontSize" Value="11" />
    </Style>

    <Style Selector="TextBlock.login-label">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>
  </Window.Styles>

  <StackPanel Margin="20" Spacing="10">
    <!-- Header with animated glow -->
    <StackPanel Spacing="4" HorizontalAlignment="Center">
      <Grid>
        <TextBlock
            Text="Metal Link Login"
            FontSize="18"
            FontWeight="Bold"
            HorizontalAlignment="Center"
            Foreground="#f5f5f5" />
        <!-- Animated glow overlay -->
        <TextBlock
            Text="Metal Link Login"
            FontSize="18"
            FontWeight="Bold"
            HorizontalAlignment="Center"
            Foreground="#4a9eff"
            Opacity="0">
          <TextBlock.Styles>
            <Style Selector="TextBlock">
              <Style.Animations>
                <Animation Duration="0:0:5" IterationCount="INFINITE" Delay="0:0:0">
                  <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                  </KeyFrame>
                  <KeyFrame Cue="10%">
                    <Setter Property="Opacity" Value="0.8" />
                  </KeyFrame>
                  <KeyFrame Cue="30%">
                    <Setter Property="Opacity" Value="0.8" />
                  </KeyFrame>
                  <KeyFrame Cue="40%">
                    <Setter Property="Opacity" Value="0" />
                  </KeyFrame>
                  <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0" />
                  </KeyFrame>
                </Animation>
              </Style.Animations>
            </Style>
          </TextBlock.Styles>
        </TextBlock>
      </Grid>
      <Border Height="2"
              Width="200"
              Margin="0,4,0,0"
              CornerRadius="1">
        <Border.Background>
          <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
            <LinearGradientBrush.GradientStops>
              <GradientStop Color="#1E88E5" Offset="0" />
              <GradientStop Color="#8EC5FC" Offset="0.5" />
              <GradientStop Color="#1E88E5" Offset="1" />
            </LinearGradientBrush.GradientStops>
            <LinearGradientBrush.Transform>
              <TranslateTransform X="-200">
                <TranslateTransform.Transitions>
                  <Transitions />
                </TranslateTransform.Transitions>
              </TranslateTransform>
            </LinearGradientBrush.Transform>
          </LinearGradientBrush>
        </Border.Background>
        <Border.Styles>
          <Style Selector="Border">
            <Style.Animations>
              <Animation Duration="0:0:5" IterationCount="INFINITE">
                <KeyFrame Cue="0%">
                  <Setter Property="Opacity" Value="0.5" />
                </KeyFrame>
                <KeyFrame Cue="50%">
                  <Setter Property="Opacity" Value="1.0" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                  <Setter Property="Opacity" Value="0.5" />
                </KeyFrame>
              </Animation>
            </Style.Animations>
          </Style>
        </Border.Styles>
      </Border>
    </StackPanel>

    <TextBlock Classes="login-label" Text="Username" />
    <TextBox Text="{Binding Username}" />

    <TextBlock Classes="login-label" Text="Password" />
    <TextBox Text="{Binding Password}"
             PasswordChar="•" />

    <Button Content="Login"
            Classes="primary"
            HorizontalAlignment="Right"
            Width="100"
            Command="{Binding LoginCommand}" />

    <TextBlock Text="{Binding StatusMessage}"
               Foreground="Red"
               TextWrapping="Wrap" />
  </StackPanel>
</Window>
