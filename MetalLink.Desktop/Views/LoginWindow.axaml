<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MetalLink.Desktop.ViewModels"
        x:Class="MetalLink.Desktop.Views.LoginWindow"
        x:DataType="vm:LoginViewModel"
        Width="420" Height="300"
        Title="Metal Link - Login"
        Background="{DynamicResource Brush.WindowBaseBackground}">

  <Window.Styles>
    <!-- Match main app typography: labels slightly larger/bolder than field text -->
    <Style Selector="TextBox">
      <!-- Same as entity text boxes / grid rows -->
      <Setter Property="FontSize" Value="11" />
    </Style>

    <Style Selector="TextBlock.login-label">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>
  </Window.Styles>

  <Border Background="{DynamicResource Brush.PanelBackground}"
          BorderBrush="{DynamicResource Brush.BorderSubtle}"
          BorderThickness="1"
          CornerRadius="16" Margin="18" Padding="18">
    <StackPanel Spacing="10">
    <!-- Header (clean, readable) -->
    <StackPanel Spacing="6" HorizontalAlignment="Center" Margin="0,0,0,8">
      <TextBlock Text="Metal Link"
                 FontSize="22"
                 FontWeight="Bold"
                 HorizontalAlignment="Center">
        <TextBlock.Foreground>
          <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#1E88E5" Offset="0" />
            <GradientStop Color="#8EC5FC" Offset="1" />
          </LinearGradientBrush>
        </TextBlock.Foreground>
      </TextBlock>
      <TextBlock Text="Sign in" FontSize="12" Foreground="{DynamicResource Brush.TextMuted}" HorizontalAlignment="Center" />
      <Border Height="2" Width="160" Background="{DynamicResource Brush.AccentGradient}" Opacity="0.8" />
    </StackPanel>

    <TextBlock Classes="login-label" Text="Username" Foreground="{DynamicResource Brush.TextMuted}" />
    <TextBox Text="{Binding Username}"
             Background="#EEF1F5"
             Foreground="#111827"
             Padding="10,8"
             BorderBrush="#9CA3AF"
             BorderThickness="1"
             CornerRadius="8" />

    <TextBlock Classes="login-label" Text="Password" Foreground="{DynamicResource Brush.TextMuted}" />
    <TextBox Text="{Binding Password}"
             PasswordChar="•"
             Background="#EEF1F5"
             Foreground="#111827"
             Padding="10,8"
             BorderBrush="#9CA3AF"
             BorderThickness="1"
             CornerRadius="8" />

    <Button Content="Login"
            Classes="primary"
            HorizontalAlignment="Right"
            Width="100"
            Command="{Binding LoginCommand}" />

    <TextBlock Text="{Binding StatusMessage}"
               Foreground="Red"
               TextWrapping="Wrap" />
    </StackPanel>
  </Border>
</Window>
