<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MetalLink.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="MetalLink.Desktop.Views.PriceListStockLevelsView"
             x:DataType="vm:PriceListStockLevelsViewModel">
  <Design.DataContext>
    <vm:PriceListStockLevelsViewModel />
  </Design.DataContext>

  <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">
    <!-- Header -->
    <TextBlock Grid.Row="0" Text="Price List Stock Distribution" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" />

    <!-- Entity Type Selection -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
      <TextBlock Text="Entity Type:" VerticalAlignment="Center" Margin="0,0,10,0" />
      <ComboBox ItemsSource="{Binding EntityTypes}" SelectedItem="{Binding SelectedEntityType}" Width="150" />
    </StackPanel>

    <!-- Price List Selection -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,20">
      <TextBlock Text="Price Lists:" VerticalAlignment="Center" Margin="0,0,10,0" />
      <ListBox ItemsSource="{Binding PriceLists}" SelectionMode="Multiple" Width="300" Height="100">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <CheckBox Content="{Binding ProductPriceListName}" IsChecked="{Binding IsSelected, Mode=TwoWay}" />
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
      <Button Content="Select All" Command="{Binding SelectAllPriceListsCommand}" Margin="10,0,0,0" />
      <Button Content="Clear All" Command="{Binding ClearAllPriceListsCommand}" Margin="10,0,0,0" />
    </StackPanel>

    <!-- Data Grid -->
    <DataGrid Grid.Row="3" ItemsSource="{Binding StockLevels}" AutoGenerateColumns="False" IsReadOnly="True">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Product Code" Binding="{Binding ProductCode}" Width="120" />
        <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*" />
        <DataGridTextColumn Header="Price List" Binding="{Binding PriceListName}" Width="150" />
        <DataGridTextColumn Header="Weight (kg)" Binding="{Binding WeightKg, StringFormat=N2}" Width="100" />
        <DataGridTextColumn Header="Total Weight (kg)" Binding="{Binding TotalWeightKg, StringFormat=N2}" Width="120" />
      </DataGrid.Columns>
    </DataGrid>

    <!-- Pagination -->
    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
      <Button Content="Previous" Command="{Binding PreviousPageCommand}" IsEnabled="{Binding CanGoPrevious}" />
      <TextBlock Text="{Binding CurrentPageInfo}" VerticalAlignment="Center" Margin="20,0" />
      <Button Content="Next" Command="{Binding NextPageCommand}" IsEnabled="{Binding CanGoNext}" />
    </StackPanel>
  </Grid>
</UserControl>