<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MetalLink.Desktop.Views.SettingsView">
  <Border Background="{DynamicResource Brush.MainBackground}">
    <DockPanel>
      <!-- Sticky Header Panel -->
      <Border DockPanel.Dock="Top" 
              Background="{DynamicResource Brush.PanelBackground}"
              Padding="12,8"
              CornerRadius="4"
              Margin="16,16,16,8">
        <Image Source="avares://MetalLink.Desktop/Assets/settings_heading.png"
               Height="40"
               HorizontalAlignment="Left"
               Stretch="Uniform" />
      </Border>
      
      <!-- Scrollable Content -->
      <ScrollViewer Padding="16,8,16,16">
        <StackPanel Spacing="16">

    <Border Background="{DynamicResource Brush.PanelBackground}" CornerRadius="8" Padding="16">
      <StackPanel Spacing="10">
        <TextBlock Text="Appearance" FontSize="16" FontWeight="SemiBold"/>

        <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
          <TextBlock Text="Theme" VerticalAlignment="Center"/>

          <RadioButton Content="Light" GroupName="Theme" IsChecked="{Binding IsLightTheme}" />
          <RadioButton Content="Dark" GroupName="Theme" IsChecked="{Binding IsDarkTheme}" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
          <TextBlock Text="Crystaline" VerticalAlignment="Center"/>
          <ToggleSwitch IsChecked="{Binding IsCrystaline}" />
        </StackPanel>

        <TextBlock Text="Theme/Appearance are stored per operator in the database." Opacity="0.7" FontSize="12"/>
        </StackPanel>
      </Border>
        </StackPanel>
      </ScrollViewer>
    </DockPanel>
  </Border>
</UserControl>
